---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL ?? "/";
const basePath = base.endsWith("/") ? base : `${base}/`;
---

<BaseLayout title="Stories From Abroad" description="Essays, photography, and field notes from the margins of the map.">
  <section class="hero">
    <div class="hero-eyebrow">Est. 2025 &middot; Dispatches from the World</div>
    <h1 class="hero-title">
      Stories<br />
      <em>From Abroad</em>
    </h1>
    <p class="hero-subtitle">
      Writing, photography, and reflection from the spaces between belonging.
    </p>
    <div class="hero-ornament">
      <span>&#10022;</span>
    </div>
    <p class="hero-mission">
      Essays, images, and field notes gathered across cities, borders, and quiet rooms. A private letter,
      published.
    </p>
    <div class="hero-cta">
      <a class="btn-solid" href={`${basePath}read-the-story/`}>Read the Story</a>
      <button class="btn-ghost" type="button" data-modal-open="subscribe">Subscribe</button>
    </div>
  </section>

  <section class="home-previews">
    <div class="container">
      <span class="section-label">What you will find here</span>
      <h2 class="home-title">Four Ways of Seeing</h2>
    </div>

    <div class="four-grid">
      <a class="four-card" href={`${basePath}selected-papers/`}>
        <div class="four-line"></div>
        <div class="four-icon">&#10022;</div>
        <h3>Articles &amp; Op-Eds</h3>
        <p>Long-form essays, cultural criticism, and analysis from far-flung vantage points.</p>
      </a>
      <a class="four-card" href={`${basePath}photography/`}>
        <div class="four-line"></div>
        <div class="four-icon">&#9675;</div>
        <h3>Photography</h3>
        <p>Visual stories, collections from the places words alone cannot quite reach.</p>
      </a>
      <a class="four-card" href={`${basePath}faces-of-the-world/`}>
        <div class="four-line"></div>
        <div class="four-icon">&#9672;</div>
        <h3>Faces of the World</h3>
        <p>Portraits and short notes from people met along the way.</p>
      </a>
      <a class="four-card" href={`${basePath}travel-stories/`}>
        <div class="four-line"></div>
        <div class="four-icon">&#9671;</div>
        <h3>Travel</h3>
        <p>Field notes, reflections, and honest accounts from the road.</p>
      </a>
    </div>
  </section>

  <style>
    .home-previews {
      background: linear-gradient(180deg, #f4eee4 0%, #efe6d8 70%, #1b3a28 71%, #1b3a28 100%);
      padding: 5rem 2rem 8rem;
    }

    .home-title {
      font-family: var(--font-title);
      font-size: clamp(2.2rem, 4vw, 3.4rem);
      font-weight: 500;
      text-align: center;
      margin: 0.6rem 0 2.5rem;
    }

    .four-grid {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 2.5rem;
      text-align: center;
    }

    .four-card {
      text-decoration: none;
      color: inherit;
      padding: 1rem 0.6rem;
    }

    .four-line {
      width: 90%;
      height: 1px;
      background: var(--rule);
      margin: 0 auto 1.6rem;
    }

    .four-icon {
      font-size: 1.3rem;
      color: var(--green);
      margin-bottom: 1rem;
    }

    .four-card h3 {
      font-family: var(--font-title);
      font-size: 1.2rem;
      margin-bottom: 0.6rem;
      color: var(--text);
    }

    .four-card p {
      font-size: 0.95rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    @media (max-width: 980px) {
      .four-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .four-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>

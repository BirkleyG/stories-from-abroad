---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteCopy } from "../content/siteCopy";

const base = import.meta.env.BASE_URL ?? "/";
const basePath = base.endsWith("/") ? base : `${base}/`;
const copy = siteCopy.home;
---

<BaseLayout title={copy.meta.title} description={copy.meta.description}>
  <section class="hero">
    <div class="hero-eyebrow" set:html={copy.hero.eyebrowHtml}></div>
    <h1 class="hero-title">
      {copy.hero.titleMain}<br />
      <em>{copy.hero.titleEm}</em>
    </h1>
    <p class="hero-subtitle">
      {copy.hero.subtitle}
    </p>
    <div class="hero-ornament">
      <span>&#10022;</span>
    </div>
    <p class="hero-mission">
      {copy.hero.mission}
    </p>
    <div class="hero-cta">
      <a class="btn-solid" href={`${basePath}read-the-story/`}>{copy.hero.ctaPrimary}</a>
      <button class="btn-ghost" type="button" data-modal-open="subscribe">{copy.hero.ctaSecondary}</button>
    </div>
  </section>

  <section class="home-previews">
    <div class="container">
      <span class="section-label">{copy.fourWays.label}</span>
      <h2 class="home-title">{copy.fourWays.title}</h2>
    </div>

    <div class="four-grid">
      {copy.fourWays.cards.map((card) => (
        <a class="four-card" href={`${basePath}${card.path}/`}>
          <div class="four-line"></div>
          <div class="four-icon" set:html={card.iconHtml}></div>
          <h3>{card.title}</h3>
          <p>{card.text}</p>
        </a>
      ))}
    </div>
  </section>

  <style>
    .home-previews {
      background: #f4eee4;
      padding: 5rem 2rem 6rem;
    }

    .home-title {
      font-family: var(--font-title);
      font-size: clamp(2.2rem, 4vw, 3.4rem);
      font-weight: 500;
      text-align: center;
      margin: 0.6rem 0 2.5rem;
    }

    .four-grid {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 2.5rem;
      text-align: center;
    }

    .four-card {
      text-decoration: none;
      color: inherit;
      padding: 1rem 0.6rem;
    }

    .four-line {
      width: 90%;
      height: 1px;
      background: var(--rule);
      margin: 0 auto 1.6rem;
    }

    .four-icon {
      font-size: 1.3rem;
      color: var(--green);
      margin-bottom: 1rem;
    }

    .four-card h3 {
      font-family: var(--font-title);
      font-size: 1.2rem;
      margin-bottom: 0.6rem;
      color: var(--text);
    }

    .four-card p {
      font-size: 0.95rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    @media (max-width: 980px) {
      .four-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .home-previews {
        padding: 3.4rem 1.1rem 4.2rem;
      }

      .home-title {
        margin-bottom: 1.8rem;
      }

      .four-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      .four-card {
        padding: 0.65rem 0.25rem;
      }

      .four-card p {
        font-size: 0.92rem;
      }
    }
  </style>
</BaseLayout>

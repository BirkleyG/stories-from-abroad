        <g filter="url(#f-drop)">
          <path
            d="M 54 12 C 72 8, 86 22, 82 44 C 78 66, 60 76, 50 94
               C 42 110, 46 134, 34 148 C 24 160, 12 154, 10 138
               C 8 122, 20 108, 28 90 C 36 72, 28 54, 32 36
               C 36 18, 38 14, 54 12 Z"
            fill="#111110"
          />
          <circle cx="78" cy="14" r="8" fill="#111110" opacity="0.6" />
          <circle cx="86" cy="6" r="5" fill="#111110" opacity="0.4" />
        </g>
      </svg>

      <svg
        class="mblot mblot-south"
        style="right: -8px; bottom: 90px; width: 120px; height: 100px"
        viewBox="0 0 120 100"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <g filter="url(#f-drop)">
          <ellipse cx="62" cy="54" rx="46" ry="30" fill="#111110" />
          <ellipse cx="26" cy="28" rx="18" ry="13" fill="#111110" opacity="0.8" />
          <circle cx="10" cy="16" r="8" fill="#111110" opacity="0.6" />
          <circle cx="3" cy="8" r="5" fill="#111110" opacity="0.4" />
        </g>
      </svg>

      <div class="lib-head">
        <div>
          <div class="lib-kicker">{copy.archive.label}</div>
          <h2 class="lib-title">{copy.archive.title}</h2>
        </div>
        <div class="lib-count" id="paper-count">{copy.archive.countPlaceholder}</div>
      </div>

      <div class="search-bar">
        <div class="s-wrap">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
          <input
            class="s-input"
            id="s-in"
            type="text"
            placeholder={copy.archive.searchPlaceholder}
            oninput="doFilter()"
          />
        </div>
        <div class="s-sep"></div>
        <select class="f-sel" id="f-cat" onchange="doFilter()">
          <option value="">{copy.archive.filters.categories}</option>
        </select>
        <div class="s-sep"></div>
        <select class="f-sel" id="f-yr" onchange="doFilter()">
          <option value="">{copy.archive.filters.years}</option>
        </select>
        <div class="s-sep"></div>
        <select class="f-sel" id="f-tp" onchange="doFilter()">
          <option value="">{copy.archive.filters.type}</option>
        </select>
      </div>

      <div class="papers-list" id="papers-list"></div>
    </section>

    <div style="height: 1px; background: var(--border)"></div>

    <section id="author">
      <div class="author-portrait">
        <span class="portrait-ph" id="papers-author-portrait">{copy.author.portraitLabel}</span>
      </div>

      <svg
        class="portrait-drips"
        viewBox="0 0 600 600"
        preserveAspectRatio="xMaxYMid meet"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="M 580 80 C 590 100, 592 130, 585 160 C 578 190, 582 220, 575 250
             C 568 280, 572 310, 565 340 C 558 370, 562 400, 555 430"
          stroke="#111110"
          stroke-width="1.5"
          fill="none"
          opacity="0.18"
        />
        <path
          d="M 550 432 C 558 422, 570 428, 568 444 C 566 458, 554 462, 546 452 C 540 444, 542 438, 550 432 Z"
          fill="#111110"
          opacity="0.28"
        />
        <path
          d="M 572 180 C 578 172, 588 176, 586 188 C 584 198, 574 202, 568 194 C 563 188, 566 186, 572 180 Z"
          fill="#111110"
          opacity="0.22"
        />
        <circle cx="578" cy="288" r="5" fill="#111110" opacity="0.18" />
        <circle cx="560" cy="370" r="3.2" fill="#111110" opacity="0.14" />
        <circle cx="544" cy="462" r="2" fill="#111110" opacity="0.1" />
      </svg>

      <div class="author-content">
        <div class="author-kicker">{copy.author.kicker}</div>
        <h3 class="author-name" set:html={copy.author.nameHtml}></h3>
        <p class="author-role">{copy.author.role}</p>
        {copy.author.bio.map((paragraph) => (
          <p class="author-bio">{paragraph}</p>
        ))}
        <div class="int-tags">
          {copy.author.tags.map((tag) => (
            <span class="int-tag">{tag}</span>
          ))}
        </div>
      </div>
    </section>

    <footer>
      <p>{copy.footer.left}</p>
      <p>{copy.footer.right}</p>
    </footer>

    <div id="overlay">
      <div class="ov-nav">
        <button class="ov-close" onclick="closeOverlay()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12" />
            <polyline points="12 19 5 12 12 5" />
          </svg>
          {copy.overlay.backLabel}
        </button>
        <span class="ov-label" id="ov-label"></span>
      </div>
      <div class="ov-body" id="ov-body"></div>
    </div>

    <script id="papers-copy" type="application/json" set:html={copyJson}></script>
    <script id="public-firestore-config" type="application/json" set:html={publicFirestoreConfigJson}></script>
    <script src={`${basePath}scripts/public-firestore.js`}></script>
    <script is:inline>
      (function () {
        function esc(value) {
          return String(value ?? "").replace(/[&<>"']/g, function (char) {
            return char === "&" ? "&amp;"
              : char === "<" ? "&lt;"
                : char === ">" ? "&gt;"
                  : char === "\"" ? "&quot;"
                    : "&#39;";
          });
        }

        function readJson(id) {
          const el = document.getElementById(id);
          if (!el) return null;
          try {
            return JSON.parse(el.textContent || "{}");
          } catch (error) {
            console.warn(id + " JSON could not be parsed.", error);
            return null;
          }
        }

        function sortPapers(list) {
          return list.slice().sort(function (a, b) {
            const featuredDelta = Number(Boolean(b.featured)) - Number(Boolean(a.featured));
            if (featuredDelta) return featuredDelta;
            const aDate = Date.parse(a.date || String(a.year || 0)) || 0;
            const bDate = Date.parse(b.date || String(b.year || 0)) || 0;
            if (bDate !== aDate) return bDate - aDate;
            return String(a.title || "").localeCompare(String(b.title || ""));
          });
        }

        function normalizePaper(copy, paper, index) {
          const keywords = Array.isArray(paper.keywords)
            ? paper.keywords
            : Array.isArray(paper.kw)
              ? paper.kw
              : [];
          const bodyText = typeof paper.bodyText === "string"
            ? paper.bodyText
            : typeof paper.fullText === "string"
              ? paper.fullText
              : "";

          return {
            id: paper.id || ("paper-" + index),
            title: paper.title || copy.defaults.title,
            subtitle: paper.subtitle || "",
            cat: paper.category || paper.cat || copy.defaults.category,
            year: Number(paper.year) || new Date().getFullYear(),
            date: paper.date || "",
            kw: keywords,
            time: paper.readTime || paper.time || copy.defaults.time,
            type: paper.type || copy.defaults.type,
            featured: Boolean(paper.featured),
            featuredRank: String(paper.featuredRank ?? "").trim() !== "" && Number.isFinite(Number(paper.featuredRank))
              ? Number(paper.featuredRank)
              : Number.MAX_SAFE_INTEGER,
            summary: paper.summary || "",
            bodyText: bodyText,
            publicationName: paper.publicationName || "",
            publicationLink: paper.publicationLink || "",
            badgeStyle: paper.badgeStyle || paper.category || paper.cat || copy.defaults.category,
            documentUrl: paper.documentUrl || "",
            documentName: paper.documentName || "",
            externalPublication: Boolean(paper.externalPublication),
          };
        }

        function applySectionMedia(config) {
          const hero = document.getElementById("papers-hero-media");
          const authorPortrait = document.getElementById("papers-author-portrait");
          if (hero && config && config.papersHeroImage && config.papersHeroImage.url) {
            hero.classList.remove("is-empty");
            hero.innerHTML = '<img src="' + esc(config.papersHeroImage.url) + '" alt="' + esc(config.papersHeroImage.alt || "Selected Papers hero image") + '" loading="lazy">';
          }
          if (authorPortrait && config && config.papersAuthorPortrait && config.papersAuthorPortrait.url) {
            authorPortrait.outerHTML = '<img id="papers-author-portrait" src="' + esc(config.papersAuthorPortrait.url) + '" alt="' + esc(config.papersAuthorPortrait.alt || "Author portrait") + '" loading="lazy">';
          }
        }

        function initTypewriter(copy) {
          const twEl = document.getElementById("tw-el");
          const lines = copy.typewriterLines || [];
          if (!twEl || !lines.length) return;
          let li = 0;
          let ci = 0;
          let deleting = false;
          function tick() {
            const line = lines[li] || "";
            if (!deleting) {
              twEl.textContent = line.slice(0, ++ci);
              if (ci >= line.length) {
                deleting = true;
                setTimeout(tick, 2400);
                return;
              }
            } else {
              twEl.textContent = line.slice(0, --ci);
              if (ci <= 0) {
                deleting = false;
                li = (li + 1) % lines.length;
              }
            }
            setTimeout(tick, deleting ? 14 : 46);
          }
          setTimeout(tick, 1200);
        }

        const copy = readJson("papers-copy");
        const publicConfig = readJson("public-firestore-config");
        if (!copy || !window.SFAPublicFirestore) return;
        initTypewriter(copy);

        const state = {
          papers: [],
          featured: [],
          featIdx: 0,
          autoTimer: null,
        };

        const counterTemplate = copy.featured.counterTemplate;
        const citationStyles = copy.overlay.citationStyles || [];

        function formatCounter(current, total) {
          return counterTemplate.replace("{current}", current).replace("{total}", total);
        }

        function setFeaturedEmpty() {
          document.getElementById("feat-kicker").textContent = "Published Writing";
          document.getElementById("feat-title").textContent = "No published papers yet";
          document.getElementById("feat-summary").textContent = "Published papers will appear here as soon as they are live in Firestore.";
          document.getElementById("feat-kws").innerHTML = "";
          document.getElementById("feat-meta").innerHTML = "";
          document.getElementById("feat-ghost").textContent = "00";
          document.getElementById("feat-dots").innerHTML = "";
          document.getElementById("feat-ctr-sd").textContent = formatCounter("00", "00");
          const button = document.getElementById("feat-btn");
          button.textContent = "Awaiting Publication";
          button.disabled = true;
          button.onclick = null;
        }

        function triggerFeatAnim() {
          const els = document.querySelectorAll(".feat-kicker,.feat-title,.feat-summary,.feat-kws,.feat-meta,.btn-read");
          els.forEach(function (el) { el.style.animation = "none"; });
          void document.getElementById("feat-content").offsetWidth;
          els.forEach(function (el) { el.style.animation = ""; });
        }

        function updateFeat(idx) {
          const paper = state.featured[idx];
          if (!paper) {
            setFeaturedEmpty();
            return;
          }
          document.getElementById("feat-kicker").textContent = paper.cat;
          document.getElementById("feat-title").textContent = paper.title;
          document.getElementById("feat-summary").textContent = paper.summary;
          document.getElementById("feat-kws").innerHTML = paper.kw.map(function (keyword) {
            return '<span class="feat-kw">' + esc(keyword) + "</span>";
          }).join("");
          document.getElementById("feat-meta").innerHTML =
            "<span>" + esc(paper.date || paper.year) + "</span>" +
            '<span class="feat-meta-dot"></span>' +
            "<span>" + esc(paper.time) + esc(copy.featured.metaReadSuffix) + "</span>" +
            '<span class="feat-meta-dot"></span>' +
            "<span>" + esc(paper.type) + "</span>";
          document.getElementById("feat-ghost").textContent = String(idx + 1).padStart(2, "0");
          document.getElementById("feat-ctr-sd").textContent = formatCounter(
            String(idx + 1).padStart(2, "0"),
            String(state.featured.length).padStart(2, "0")
          );
          document.querySelectorAll(".feat-dot").forEach(function (dot, dotIndex) {
            dot.classList.toggle("active", dotIndex === idx);
          });
          const button = document.getElementById("feat-btn");
          button.textContent = copy.featured.button;
          button.disabled = false;
          button.onclick = function () { openPaper(paper.id); };
          triggerFeatAnim();
        }

        function buildFeatDots() {
          document.getElementById("feat-dots").innerHTML = state.featured.map(function (_, index) {
            return '<div class="feat-dot' + (index === 0 ? " active" : "") + '" data-feat-index="' + index + '"></div>';
          }).join("");
          document.querySelectorAll("[data-feat-index]").forEach(function (dot) {
            dot.addEventListener("click", function () {
              goFeat(Number(dot.getAttribute("data-feat-index") || 0));
            });
          });
        }

        function goFeat(nextIndex) {
          const max = state.featured.length;
          if (!max) return;
          nextIndex = ((nextIndex % max) + max) % max;
          state.featIdx = nextIndex;
          updateFeat(state.featIdx);
          resetAutoTimer();
        }

        function moveFeat(dir) {
          goFeat(state.featIdx + dir);
        }

        function resetAutoTimer() {
          clearInterval(state.autoTimer);
          if (state.featured.length < 2) return;
          state.autoTimer = setInterval(function () {
            goFeat(state.featIdx + 1);
          }, 8000);
        }

        function buildList(list) {
          const listEl = document.getElementById("papers-list");
          document.getElementById("paper-count").textContent = list.length + " " + (list.length !== 1 ? copy.archive.countPlural : copy.archive.countSingular);
          listEl.innerHTML = "";
          if (!list.length) {
            listEl.innerHTML = '<div class="no-results">' + esc(copy.archive.emptyState) + "</div>";
            return;
          }
          list.forEach(function (paper, index) {
            const row = document.createElement("div");
            row.className = "paper-row";
            row.onclick = function () { openPaper(paper.id); };
            row.innerHTML =
              '<div class="row-n">' + String(index + 1).padStart(2, "0") + "</div>" +
              '<div class="row-body">' +
                '<div class="row-cat">' + esc(paper.cat) + "</div>" +
                '<div class="row-title">' + esc(paper.title) + "</div>" +
                '<div class="row-kws">' + paper.kw.map(function (keyword) { return '<span class="row-kw">' + esc(keyword) + "</span>"; }).join("") + "</div>" +
                '<div class="row-preview">' + esc(paper.summary) + "</div>" +
              "</div>" +
              '<div class="row-aside">' +
                '<div class="row-date">' + esc(paper.date || paper.year) + "</div>" +
                '<div class="row-time">' + esc(paper.time) + esc(copy.archive.readSuffix) + "</div>" +
                '<div class="row-arrow">&rarr;</div>' +
              "</div>";
            listEl.appendChild(row);
          });
        }

        function fillSelect(id, label, items) {
          const select = document.getElementById(id);
          select.innerHTML = '<option value="">' + esc(label) + "</option>" + items.map(function (item) {
            return "<option>" + esc(item) + "</option>";
          }).join("");
        }

        function populateFilters(list) {
          fillSelect("f-cat", copy.archive.filters.categories, Array.from(new Set(list.map(function (paper) { return paper.cat; }).filter(Boolean))).sort());
          fillSelect("f-yr", copy.archive.filters.years, Array.from(new Set(list.map(function (paper) { return paper.year; }).filter(Boolean))).sort(function (a, b) { return b - a; }));
          fillSelect("f-tp", copy.archive.filters.type, Array.from(new Set(list.map(function (paper) { return paper.type; }).filter(Boolean))).sort());
        }

        function doFilter() {
          const query = String(document.getElementById("s-in").value || "").toLowerCase();
          const cat = document.getElementById("f-cat").value;
          const year = document.getElementById("f-yr").value;
          const type = document.getElementById("f-tp").value;
          buildList(state.papers.filter(function (paper) {
            const textMatch = !query || [paper.title, paper.summary].concat(paper.kw || [], [paper.cat]).some(function (value) {
              return String(value || "").toLowerCase().includes(query);
            });
            return textMatch && (!cat || paper.cat === cat) && (!year || paper.year === Number(year)) && (!type || paper.type === type);
          }));
        }

        function cite(paper, style) {
          const title = esc(paper.title);
          const year = esc(paper.year);
          const date = esc(paper.date || String(paper.year));
          const source = esc(paper.publicationName || copy.overlay.citeSource);
          const authorShort = esc(copy.overlay.citationAuthorShort);
          const authorFull = esc(copy.overlay.citationAuthorFull);
          const authorBib = esc(copy.overlay.citationAuthorBib);
          const key = esc(copy.overlay.citationKey);
          if (style === "APA") return authorShort + " (" + year + "). <em>" + title + "</em>. <em>" + source + "</em>.";
          if (style === "MLA") return authorFull + '. "' + title + '." <em>' + source + "</em>, " + date + ".";
          if (style === "Chicago") return authorFull + '. "' + title + '." <em>' + source + "</em>. " + date + ".";
          if (style === "Harvard") return authorShort + " (" + year + ") '" + title + "', <em>" + source + "</em>.";
          if (style === "BibTeX") return "@article{" + key + year + ",\n  author={" + authorBib + "},\n  title={" + title + "},\n  year={" + year + "},\n  journal={" + source + "}\n}";
          return "";
        }

        function setCit(paperId, style) {
          const paper = state.papers.find(function (item) { return item.id === paperId; });
          if (!paper) return;
          document.getElementById("cit-out").innerHTML = cite(paper, style);
          document.querySelectorAll(".cs-btn").forEach(function (button) {
            button.classList.toggle("active", button.dataset.s === style);
          });
        }

        function openPaper(id) {
          const paper = state.papers.find(function (item) { return item.id === id; });
          if (!paper) return;
          const dateLabel = paper.date || String(paper.year);
          const timeLabel = paper.time ? paper.time + copy.overlay.timeSuffix : "";
          const kwLabel = paper.kw.length ? paper.kw.join(copy.overlay.kwSeparator) : copy.overlay.keywordsEmpty;
          const bodyParagraphs = String(paper.bodyText || "").split(/\n{2,}/).map(function (paragraph) {
            return paragraph.trim();
          }).filter(Boolean);
          const abstractParagraphs = [
            esc(paper.summary),
            bodyParagraphs[0] ? esc(bodyParagraphs[0]) : esc(copy.overlay.placeholder.abstractParagraphs[0]),
            bodyParagraphs[1] ? esc(bodyParagraphs[1]) : esc(copy.overlay.placeholder.abstractParagraphs[1]),
          ].filter(Boolean);
          const bodyMarkup = bodyParagraphs.length
            ? bodyParagraphs.slice(2, 7).map(function (paragraph) { return "<p>" + esc(paragraph) + "</p>"; }).join("")
            : '<span class="sec-mark">' + esc(copy.overlay.placeholder.sectionMarks[0]) + '</span>' +
              "<p>" + esc(copy.overlay.placeholder.bodyParagraphs[0]) + "</p>" +
              "<h2>" + esc(copy.overlay.placeholder.headings[0]) + "</h2>" +
              "<p>" + esc(copy.overlay.placeholder.bodyParagraphs[1]) + "</p>" +
              "<blockquote>" + esc(copy.overlay.placeholder.blockquote) + "</blockquote>" +
              "<p>" + esc(copy.overlay.placeholder.bodyParagraphs[2]) + "</p>" +
              "<h2>" + esc(copy.overlay.placeholder.headings[1]) + "</h2>" +
              '<span class="sec-mark">' + esc(copy.overlay.placeholder.sectionMarks[1]) + '</span>' +
              "<p>" + esc(copy.overlay.placeholder.bodyParagraphs[3]) + "</p>" +
              "<p>" + esc(copy.overlay.placeholder.bodyParagraphs[4]) + "</p>";
          const downloadMarkup = [
            paper.documentUrl
              ? '<a class="btn-dl dl-pdf" href="' + esc(paper.documentUrl) + '" target="_blank" rel="noreferrer">' + esc(paper.documentName || copy.overlay.downloadButtons[0]) + "</a>"
              : '<button class="btn-dl dl-pdf" disabled>' + esc(copy.overlay.downloadButtons[0]) + "</button>",
            paper.publicationLink
              ? '<a class="btn-dl dl-txt" href="' + esc(paper.publicationLink) + '" target="_blank" rel="noreferrer">' + esc(paper.publicationName || copy.overlay.downloadButtons[1]) + "</a>"
              : '<button class="btn-dl dl-txt" disabled>' + esc(copy.overlay.downloadButtons[1]) + "</button>",
            '<button class="btn-dl dl-cit" disabled>' + esc(copy.overlay.downloadButtons[2]) + "</button>",
          ].join("");

          document.getElementById("ov-label").textContent = dateLabel + " - " + timeLabel;
          document.getElementById("ov-body").innerHTML =
            '<div class="ov-kicker">' + esc(paper.cat) + "</div>" +
            '<h1 class="ov-title">' + esc(paper.title) + "</h1>" +
            (paper.subtitle ? '<p class="ov-subtitle">' + esc(paper.subtitle) + "</p>" : "") +
            '<div class="ov-meta">' +
              '<div class="ov-mc"><div class="ov-ml">' + esc(copy.overlay.metaLabels.author) + '</div><div class="ov-mv">' + esc(copy.hero.byName) + "</div></div>" +
              '<div class="ov-mc"><div class="ov-ml">' + esc(copy.overlay.metaLabels.date) + '</div><div class="ov-mv">' + esc(dateLabel) + "</div></div>" +
              '<div class="ov-mc"><div class="ov-ml">' + esc(copy.overlay.metaLabels.readingTime) + '</div><div class="ov-mv">' + esc(paper.time) + "</div></div>" +
              '<div class="ov-mc"><div class="ov-ml">' + esc(copy.overlay.metaLabels.keywords) + '</div><div class="ov-mv">' + esc(kwLabel) + "</div></div>" +
            "</div>" +
            '<div class="ov-cite"><div class="ov-cite-body"><div class="ov-cite-lbl">' + esc(copy.overlay.citeLabel) + '</div><div class="ov-cite-txt" id="cit-out">' + cite(paper, "APA") + '</div></div><div class="ov-cite-styles">' +
              citationStyles.map(function (style) {
                return '<button class="cs-btn' + (style === "APA" ? " active" : "") + '" data-s="' + esc(style) + '" data-pid="' + encodeURIComponent(String(paper.id)) + '">' + esc(style) + "</button>";
              }).join("") +
            "</div></div>" +
            '<div class="ov-abstract"><div class="ov-abs-lbl">' + esc(copy.overlay.abstractLabel) + "</div>" +
              abstractParagraphs.map(function (paragraph) { return "<p>" + paragraph + "</p>"; }).join("") +
            "</div>" +
            '<div class="ov-text">' + bodyMarkup + "</div>" +
            '<div class="ov-dls">' + downloadMarkup + "</div>";

          document.querySelectorAll(".cs-btn").forEach(function (button) {
            button.addEventListener("click", function () {
              setCit(decodeURIComponent(button.dataset.pid || ""), button.dataset.s || "APA");
            });
          });
          document.getElementById("overlay").classList.add("open");
          document.getElementById("overlay").scrollTop = 0;
          document.body.style.overflow = "hidden";
        }

        function closeOverlay() {
          document.getElementById("overlay").classList.remove("open");
          document.body.style.overflow = "";
        }

        async function boot() {
          try {
            const results = await Promise.all([
              window.SFAPublicFirestore.getDocument(publicConfig, "site_config/section_media"),
              window.SFAPublicFirestore.listCollection(publicConfig, "papers"),
            ]);
            applySectionMedia(results[0] || {});
            state.papers = sortPapers((results[1] || []).map(function (paper, index) {
              return normalizePaper(copy, paper, index);
            }));
            state.featured = state.papers.filter(function (paper) { return paper.featured; }).sort(function (a, b) {
              return a.featuredRank - b.featuredRank || String(a.title).localeCompare(String(b.title));
            });
            if (!state.featured.length && state.papers.length) {
              state.featured = state.papers.slice(0, 3);
            }
            populateFilters(state.papers);
            buildFeatDots();
            updateFeat(0);
            resetAutoTimer();
            buildList(state.papers);
          } catch (error) {
            console.warn("Selected Papers public load failed.", error);
            setFeaturedEmpty();
            buildList([]);
          }
        }

        window.closeOverlay = closeOverlay;
        window.openPaper = openPaper;
        window.doFilter = doFilter;
        window.moveFeat = moveFeat;
        window.goFeat = goFeat;

        document.addEventListener("keydown", function (event) {
          if (event.key === "Escape") closeOverlay();
          if (document.getElementById("overlay").classList.contains("open")) return;
          if (event.key === "ArrowRight") moveFeat(1);
          if (event.key === "ArrowLeft") moveFeat(-1);
        });

        document.getElementById("s-in").addEventListener("input", doFilter);

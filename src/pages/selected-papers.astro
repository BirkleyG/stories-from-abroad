        <circle cx="396" cy="146" r="3.2" fill="#111110" opacity="0.3" />
        <circle cx="340" cy="194" r="4.5" fill="#111110" opacity="0.38" />
        <circle cx="320" cy="210" r="2.8" fill="#111110" opacity="0.24" />
        <circle cx="298" cy="222" r="1.8" fill="#111110" opacity="0.16" />
        <circle cx="472" cy="28" r="3.5" fill="#111110" opacity="0.32" />
        <circle cx="488" cy="18" r="2" fill="#111110" opacity="0.2" />
      </svg>

      <svg
        class="mblot"
        style="right: -14px; top: 420px; width: 140px; height: 120px"
        viewBox="0 0 140 120"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <g filter="url(#f-drop)">
          <path
            d="M 52 24 C 78 8, 114 18, 118 46 C 122 72, 100 94, 72 90
               C 44 86, 22 72, 18 50 C 14 28, 28 38, 52 24 Z"

          <circle cx="282" cy="691" r="3" fill="#111110" opacity="0.18" />
        </g>
      </svg>

      <div class="hero-content">
        <div class="hero-kicker">{copy.hero.kicker}</div>
        <h1 class="hero-title">{copy.hero.titleMain} <strong>{copy.hero.titleEm}</strong></h1>
        <div class="hero-divider"></div>
        <div class="hero-placeholder" aria-hidden="true"></div>
        <div class="hero-tw-wrap">
          <span class="hero-tw" id="tw-el"></span><span class="cursor"></span>
        </div>
      </div>

      <div class="hero-scroll-hint">{copy.hero.scrollHint}</div>
      <div class="hero-byline">
        <div class="hero-byline-label">{copy.hero.byLabel}</div>
        <div class="hero-byline-name">{copy.hero.byName}</div>
      </div>
    </section>

    <div class="sd">
      <svg class="sd-blot" width="26" height="26" viewBox="0 0 60 60">
        <g filter="url(#f-sm)">
          <circle cx="30" cy="30" r="18" fill="#111110" opacity="0.7" />
          <circle cx="42" cy="21" r="8" fill="#111110" opacity="0.5" />
          <circle cx="19" cy="22" r="6" fill="#111110" opacity="0.45" />
        </g>
        <g filter="url(#f-drop)">
          <circle cx="51" cy="16" r="4" fill="#111110" opacity="0.32" />
          <circle cx="57" cy="24" r="2.5" fill="#111110" opacity="0.22" />
          <circle cx="10" cy="42" r="3" fill="#111110" opacity="0.24" />
        </g>
      </svg>
      <span class="sd-lbl">{copy.featured.label}</span>
      <div class="sd-line"></div>
      <span class="sd-lbl" id="feat-ctr-sd">{initialFeatCounter}</span>
    </div>

    <section id="featured">
      <svg
        class="feat-ink"
        viewBox="0 0 1200 800"
        preserveAspectRatio="xMaxYMid slice"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="
      M 576 0
      C 540 55,  562 115, 524 178
      C 486 241, 512 295, 474 358
      C 436 421, 460 476, 436 538
      C 412 600, 438 654, 416 720
      C 402 762, 420 790, 428 800
      L 1200 800 L 1200 0 Z
    "
          fill="#111110"
        />
        <g filter="url(#f-drop)">
          <ellipse cx="498" cy="118" rx="30" ry="20" fill="#111110" opacity="0.86" />
          <ellipse cx="460" cy="156" rx="18" ry="12" fill="#111110" opacity="0.68" />
          <path
            d="M 432 182 C 442 174, 454 178, 450 196 C 447 210, 434 213, 426 202 C 419 193, 423 188, 432 182 Z"
            fill="#111110"

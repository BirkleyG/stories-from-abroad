          <path
            d="M 278 406 C 290 396, 308 402, 304 426 C 300 446, 282 450, 270 436 C 260 424, 264 412, 278 406 Z"
            fill="#111110"
            opacity="0.58"
          />
          <circle cx="252" cy="454" r="8" fill="#111110" opacity="0.4" />
          <circle cx="238" cy="468" r="5" fill="#111110" opacity="0.28" />
          <circle cx="226" cy="480" r="3" fill="#111110" opacity="0.18" />
          <circle cx="216" cy="490" r="1.8" fill="#111110" opacity="0.11" />
          <ellipse cx="398" cy="606" rx="38" ry="24" fill="#111110" opacity="0.86" />
          <path
            d="M 342 636 C 356 626, 376 632, 372 654 C 368 672, 348 676, 336 662 C 326 650, 330 642, 342 636 Z"
            fill="#111110"

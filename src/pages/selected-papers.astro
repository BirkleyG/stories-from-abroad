        <span class="ov-label" id="ov-label"></span>
      </div>
      <div class="ov-body" id="ov-body"></div>
    </div>

    <script type="module">
      import { collection, getDocs } from "firebase/firestore";
      import { db, firestoreReady } from "../lib/firebaseClient";
      import { fallbackPapers } from "../lib/fallbackData";

      const lines = [
        "Essays, notes, and arguments -- attempts to understand the world a little better.",
        "Some academic. Some speculative. All written in good faith.",
        "Written across years of travel, study, and careful attention.",
        "A scholar's desk, left open.",
      ];

      let li = 0;
      let ci = 0;
      let del = false;
      const twEl = document.getElementById("tw-el");

      function tick() {
        const s = lines[li];
        if (!del) {
          twEl.textContent = s.slice(0, ++ci);
          if (ci === s.length) {
            del = true;
            setTimeout(tick, 2800);
            return;
          }
        } else {
          twEl.textContent = s.slice(0, --ci);
          if (ci === 0) {
            del = false;
            li = (li + 1) % lines.length;
          }
        }
        setTimeout(tick, del ? 14 : 46);
      }
      setTimeout(tick, 1400);

      const state = {
        papers: [],
        featured: [],
        featIdx: 0,
        autoTimer: null,
      };

      function normalizePaper(p, idx) {
        const kw = Array.isArray(p.keywords)
          ? p.keywords
          : Array.isArray(p.kw)
            ? p.kw
            : Array.isArray(p.tags)
              ? p.tags
              : [];

        return {
          id: p.id ?? `paper-${idx}`,
          title: p.title ?? "Untitled",
          cat: p.category ?? p.cat ?? "Essay",
          year: Number(p.year) || new Date().getFullYear(),
          date: p.date ?? "",
          kw,
          time: p.readTime ?? p.time ?? "10 min",
          type: p.type ?? "Essay",
          featured: Boolean(p.featured),
          summary: p.summary ?? "",
        };
      }

      async function loadPapers() {
        if (!firestoreReady || !db) {
          return fallbackPapers.map(normalizePaper);
        }
        try {
          const snap = await getDocs(collection(db, "papers"));
          const data = snap.docs.map((doc, idx) => normalizePaper({ id: doc.id, ...doc.data() }, idx));
          return data.length ? data : fallbackPapers.map(normalizePaper);
        } catch (err) {
          console.warn("Firestore unavailable, using fallback.", err);
          return fallbackPapers.map(normalizePaper);
        }
      }

      function triggerFeatAnim() {
        const blendEls = document.querySelectorAll(
          ".feat-kicker,.feat-title,.feat-summary,.feat-kws,.feat-meta,.btn-read"
        );
        blendEls.forEach((el) => {
          el.style.animation = "none";
        });
        void document.getElementById("feat-content").offsetWidth;
        blendEls.forEach((el) => {
          el.style.animation = "";
        });
      }

      function updateFeat(idx) {
        const p = state.featured[idx];
        if (!p) return;
        const title = document.getElementById("feat-title");
        document.getElementById("feat-kicker").textContent = p.cat;
        title.textContent = p.title;
        title.onclick = () => openPaper(p.id);
        document.getElementById("feat-summary").textContent = p.summary;
        document.getElementById("feat-kws").innerHTML = p.kw.map((k) => `<span class="feat-kw">${k}</span>`).join("");
        document.getElementById("feat-meta").innerHTML = `
          <span>${p.date || p.year}</span>
          <span class="feat-meta-dot"></span>
          <span>${p.time} read</span>
          <span class="feat-meta-dot"></span>
          <span>${p.type}</span>`;
        document.getElementById("feat-btn").onclick = () => openPaper(p.id);
        document.getElementById("feat-ghost").textContent = String(idx + 1).padStart(2, "0");
        const ctr = document.getElementById("feat-ctr-sd");
        if (ctr) {
          const total = String(state.featured.length).padStart(2, "0");
          ctr.textContent = `${String(idx + 1).padStart(2, "0")} of ${total}`;
        }
        document.querySelectorAll(".feat-dot").forEach((d, i) => d.classList.toggle("active", i === idx));
        triggerFeatAnim();
      }

      function buildFeatDots() {
        document.getElementById("feat-dots").innerHTML = state.featured
          .map((_, i) => `<div class="feat-dot${i === 0 ? " active" : ""}" onclick="goFeat(${i})"></div>`)
          .join("");
      }

      function goFeat(newIdx) {
        const max = state.featured.length;
        if (!max) return;
        newIdx = ((newIdx % max) + max) % max;
        if (newIdx === state.featIdx) return;
        state.featIdx = newIdx;
        updateFeat(state.featIdx);
        resetAutoTimer();
      }

      function moveFeat(dir) {
        goFeat(state.featIdx + dir);
      }

      function resetAutoTimer() {
        clearInterval(state.autoTimer);
        if (state.featured.length < 2) return;
        state.autoTimer = setInterval(() => goFeat(state.featIdx + 1), 8000);
      }

      function buildList(list) {
        const el = document.getElementById("papers-list");
        document.getElementById("paper-count").textContent = `${list.length} paper${list.length !== 1 ? "s" : ""}`;
        el.innerHTML = "";
        if (!list.length) {
          el.innerHTML = '<div class="no-results">No papers match your search.</div>';
          return;
        }
        list.forEach((p, i) => {
          const row = document.createElement("div");
          row.className = "paper-row";
          row.onclick = () => openPaper(p.id);
          row.innerHTML = `
            <div class="row-n">${String(i + 1).padStart(2, "0")}</div>
            <div class="row-body">
              <div class="row-cat">${p.cat}</div>
              <div class="row-title">${p.title}</div>
              <div class="row-kws">${p.kw.map((k) => `<span class="row-kw">${k}</span>`).join("")}</div>
              <div class="row-preview">${p.summary}</div>
            </div>
            <div class="row-aside">
              <div class="row-date">${p.date || p.year}</div>
              <div class="row-time">${p.time} read</div>
              <div class="row-arrow">&rarr;</div>
            </div>`;
          el.appendChild(row);
        });
      }

      function fillSelect(id, label, items) {
        const sel = document.getElementById(id);
        sel.innerHTML = `<option value="">${label}</option>` + items.map((it) => `<option>${it}</option>`).join("");
      }

      function populateFilters(list) {
        const cats = Array.from(new Set(list.map((p) => p.cat).filter(Boolean))).sort();
        const years = Array.from(new Set(list.map((p) => p.year).filter(Boolean))).sort((a, b) => b - a);
        const types = Array.from(new Set(list.map((p) => p.type).filter(Boolean))).sort();
        fillSelect("f-cat", "All Categories", cats);
        fillSelect("f-yr", "All Years", years);
        fillSelect("f-tp", "Writing Type", types);
      }

      function doFilter() {
        const q = document.getElementById("s-in").value.toLowerCase();
        const cat = document.getElementById("f-cat").value;
        const yr = document.getElementById("f-yr").value;
        const tp = document.getElementById("f-tp").value;
        buildList(
          state.papers.filter((p) => {
            const m = !q || [p.title, p.summary, ...p.kw, p.cat].some((x) => String(x).toLowerCase().includes(q));
            return m && (!cat || p.cat === cat) && (!yr || p.year === Number(yr)) && (!tp || p.type === tp);
          })
        );
      }
      window.doFilter = doFilter;
      window.moveFeat = moveFeat;
      window.goFeat = goFeat;

      const citStyles = ["APA", "MLA", "Chicago", "Harvard", "BibTeX"];
      function cite(p, s) {
        const t = p.title;
        const yr = p.year;
        const d = p.date || String(p.year);
        switch (s) {
          case "APA":
            return `Grunewald, B. (${yr}). <em>${t}</em>. <em>Stories From Abroad</em>.`;
          case "MLA":
            return `Grunewald, Birkley. "${t}." <em>Stories From Abroad</em>, ${d}.`;
          case "Chicago":
            return `Grunewald, Birkley. "${t}." <em>Stories From Abroad</em>. ${d}.`;
          case "Harvard":
            return `Grunewald, B. (${yr}) '${t}', <em>Stories From Abroad</em>.`;
          case "BibTeX":
            return `@article{grunewald${yr},\n  author={Grunewald, Birkley},\n  title={${t}},\n  year={${yr}},\n  journal={Stories From Abroad}\n}`;
          default:
            return "";
        }
      }
      function setCit(pid, s) {
        const p = state.papers.find((x) => x.id === pid);
        if (!p) return;
        document.getElementById("cit-out").innerHTML = cite(p, s);
        document.querySelectorAll(".cs-btn").forEach((b) => b.classList.toggle("active", b.dataset.s === s));
      }
      window.setCit = setCit;

      function openPaper(id) {
        const p = state.papers.find((x) => x.id === id);
        if (!p) return;
        const dateLabel = p.date || String(p.year);
        const timeLabel = p.time ? `${p.time} read` : "";
        const kwLabel = p.kw.length ? p.kw.join(" - ") : "None";
        document.getElementById("ov-label").textContent = `${dateLabel} - ${timeLabel}`;
        document.getElementById("ov-body").innerHTML = `
          <div class="ov-kicker">${p.cat}</div>
          <h1 class="ov-title">${p.title}</h1>
          <div class="ov-meta">
            <div class="ov-mc"><div class="ov-ml">Author</div><div class="ov-mv">Birkley Grunewald</div></div>
            <div class="ov-mc"><div class="ov-ml">Date</div><div class="ov-mv">${dateLabel}</div></div>
            <div class="ov-mc"><div class="ov-ml">Reading Time</div><div class="ov-mv">${p.time}</div></div>
            <div class="ov-mc"><div class="ov-ml">Keywords</div><div class="ov-mv">${kwLabel}</div></div>
          </div>
          <div class="ov-cite">
            <div class="ov-cite-body">
              <div class="ov-cite-lbl">Cite This Paper</div>
              <div class="ov-cite-txt" id="cit-out">${cite(p, "APA")}</div>
            </div>
            <div class="ov-cite-styles">
              ${citStyles
                .map(
                  (s) => `<button class="cs-btn${s === "APA" ? " active" : ""}" data-s="${s}" onclick="setCit('${p.id}','${s}')">${s}</button>`
                )
                .join("")}
            </div>
          </div>
          <div class="ov-abstract">
            <div class="ov-abs-lbl">Abstract</div>
            <p>${p.summary}</p>
            <p>The argument is situated within broader debates in comparative political economy and international relations, drawing on historical case studies and theoretical frameworks to illuminate patterns often obscured by narrowly empirical approaches.</p>
            <p>The paper ultimately suggests that structural conditions constrain but do not determine political possibilities, leaving open questions about agency, contingency, and the potential for deliberate institutional reform.</p>
          </div>
          <div class="ov-text">
            <span class="sec-mark">I.</span>
            <p>The question at the heart of this essay is neither new nor easily answered. It has occupied political economists, philosophers, and policymakers for decades, yet it returns with new urgency whenever institutions that were supposed to hold fail visibly, or when the gap between official explanation and lived experience becomes too wide to ignore.</p>
            <h2>The Problem of Governance</h2>
            <p>To understand what is at stake, we must first resist the temptation of abstraction. The forces under examination are not theoretical constructs but practical realities, they shape who gets what, when, and how. They determine whether hospitals receive funding, whether courts function with independence, whether citizens can trust the systems they live within.</p>
            <blockquote>The strength of an institution lies not in its formal powers but in the expectations that surround it, in what people believe others believe about how it will behave.</blockquote>
            <p>This is not merely an academic concern. The erosion of institutional trust has measurable consequences: for economic performance, for public health outcomes, for the willingness of citizens to participate in collective life.</p>
            <h2>Structure and Agency</h2>
            <span class="sec-mark">II.</span>
            <p>A second complication arises from the relationship between structure and agency. Structural arguments locate the causes of political outcomes in long-run economic forces, historical legacies, or international power configurations. They are indispensable but insufficient, explaining why certain paths are difficult without explaining why some actors navigate them successfully while others do not.</p>
            <p>The cases examined here suggest that agency matters most at critical junctures: moments when structural constraints are loosened by crisis, when existing arrangements have manifestly failed, and when political actors face genuine choices about institutional reform.</p>
          </div>
          <div class="ov-dls">
            <button class="btn-dl dl-pdf" disabled>Download PDF</button>
            <button class="btn-dl dl-txt" disabled>Clean Text</button>
            <button class="btn-dl dl-cit" disabled>Export Citation</button>
          </div>
        `;
        const ov = document.getElementById("overlay");
        ov.classList.add("open");
        ov.scrollTop = 0;
        document.body.style.overflow = "hidden";
      }

      function closeOverlay() {
        document.getElementById("overlay").classList.remove("open");
        document.body.style.overflow = "";
      }
      window.closeOverlay = closeOverlay;
      window.openPaper = openPaper;

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeOverlay();
        if (document.getElementById("overlay").classList.contains("open")) return;
        if (e.key === "ArrowRight") moveFeat(1);
        if (e.key === "ArrowLeft") moveFeat(-1);
      });

      async function init() {
        const data = await loadPapers();
        state.papers = data;
        state.featured = data.filter((p) => p.featured);
        if (!state.featured.length) {
          state.featured = data.slice(0, 3);
        }
        populateFilters(state.papers);
        buildFeatDots();
        updateFeat(0);
        resetAutoTimer();
        buildList(state.papers);
      }

      init();
    </script>
  </body>
</html>

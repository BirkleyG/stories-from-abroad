---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Selected Papers & Op-Eds"
  description="Essays, notes, and arguments from the field."
  bodyClass="theme-papers"
  navMode="single"
  navLabel="Articles"
  showSubscribe={false}
>
  <div class="papers-page">
    <section class="papers-hero" id="papers-hero">
      <svg
        class="hero-ink"
        viewBox="0 0 1200 700"
        preserveAspectRatio="xMinYMin slice"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="M0,0 H1200 V700 H0 Z"
          fill="#FAFAF7"
        />
        <path
          d="M780,-40 C950,20 1120,140 1200,280 V700 H560 C520,540 520,420 620,320 C700,240 720,120 780,-40 Z"
          fill="#111110"
        />
      </svg>
      <div class="hero-content">
        <div class="hero-kicker">Selected Papers</div>
        <h1 class="hero-title">Papers &amp; Op-Eds</h1>
        <div class="hero-divider"></div>
        <div class="hero-tw-wrap">
          <p class="hero-tw" id="hero-tw"></p>
          <span class="cursor"></span>
        </div>
      </div>
      <div class="hero-scroll-hint">Scroll</div>
      <div class="hero-byline">
        <div class="hero-byline-label">Author</div>
        <div class="hero-byline-name">Birkley Grunewald</div>
      </div>
    </section>

    <div class="sd">
      <div class="sd-lbl">Featured</div>
      <div class="sd-line"></div>
      <div class="sd-blot">&#10022;</div>
    </div>

    <section class="featured" id="featured">
      <svg
        class="feat-ink"
        viewBox="0 0 1200 700"
        preserveAspectRatio="xMaxYMid slice"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="M0,0 H1200 V700 H0 Z"
          fill="#FAFAF7"
        />
        <path
          d="M1200,0 V700 H280 C340,540 420,420 560,340 C700,260 850,160 1020,40 C1080,0 1140,-10 1200,0 Z"
          fill="#111110"
        />
      </svg>
      <div class="feat-ghost" id="feat-ghost">01</div>
      <div class="feat-content" id="feat-content">
        <div class="feat-kicker" id="feat-kicker">Political Economy</div>
        <h2 class="feat-title" id="feat-title">On Belonging Nowhere in Particular</h2>
        <p class="feat-summary" id="feat-summary">
          Essays, notes, and arguments &mdash; attempts to understand the world a little better.
        </p>
        <div class="feat-kws" id="feat-kws"></div>
        <div class="feat-meta" id="feat-meta"></div>
        <button class="btn-read" id="feat-btn">Read Paper</button>
      </div>
      <div class="feat-controls">
        <div class="feat-dots" id="feat-dots"></div>
        <div class="feat-arrows">
          <button class="feat-arr" id="feat-prev">&#8249;</button>
          <button class="feat-arr" id="feat-next">&#8250;</button>
        </div>
      </div>
    </section>
    <section id="library">
      <div class="lib-head">
        <div>
          <div class="lib-kicker">Library</div>
          <div class="lib-title">Selected Papers</div>
        </div>
        <div class="lib-count" id="paper-count"></div>
      </div>

      <div class="search-bar">
        <div class="s-wrap">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input
            class="s-input"
            id="s-in"
            type="search"
            placeholder="Search papers, themes, or keywords"
          />
        </div>
        <div class="s-sep"></div>
        <select class="f-sel" id="f-cat"></select>
        <div class="s-sep"></div>
        <select class="f-sel" id="f-yr"></select>
        <div class="s-sep"></div>
        <select class="f-sel" id="f-tp"></select>
      </div>

      <div class="papers-list" id="papers-list"></div>
    </section>

    <section class="author" id="author">
      <div class="author-portrait">
        <span class="portrait-ph">Portrait &mdash; Birkley Grunewald</span>
      </div>
      <div class="author-content">
        <div class="author-kicker">About the Author</div>
        <h3 class="author-name">Birkley <strong>Grunewald</strong></h3>
        <p class="author-role">Writer &middot; Researcher &middot; Correspondent</p>
        <p class="author-bio">
          These papers represent an ongoing attempt to think clearly about politics, economy, and the
          structures that shape how people live. Written across years of study and travel, they range
          from formal academic arguments to shorter reflections on questions that resist easy answers.
        </p>
        <p class="author-bio">
          The work sits alongside photography, travel writing, and short fiction &mdash; each form asking a
          different kind of attention from the same underlying preoccupations.
        </p>
        <div class="int-tags">
          <span class="int-tag">Political Economy</span>
          <span class="int-tag">State &amp; Sovereignty</span>
          <span class="int-tag">Global Justice</span>
          <span class="int-tag">Development</span>
          <span class="int-tag">Philosophy</span>
          <span class="int-tag">International Order</span>
        </div>
      </div>
    </section>
  </div>

  <div id="overlay">
    <div class="ov-nav">
      <button class="ov-close" id="ov-close">
        <span>&#8592;</span> Back to Papers
      </button>
      <span class="ov-label" id="ov-label"></span>
    </div>
    <div class="ov-body" id="ov-body"></div>
  </div>
  <script type="module">
    import { collection, getDocs } from "firebase/firestore";
    import { db, firestoreReady } from "../lib/firebaseClient";
    import { fallbackPapers } from "../lib/fallbackData";

    const typeLines = [
      "Essays, notes, and arguments -- attempts to understand the world a little better.",
      "Some academic. Some speculative. All written in good faith.",
      "Written across years of travel, study, and careful attention.",
      "A scholar\'s desk, left open.",
    ];

    let li = 0;
    let ci = 0;
    let del = false;
    const twEl = document.getElementById("hero-tw");

    function tick() {
      const line = typeLines[li];
      if (!del) {
        twEl.textContent = line.slice(0, ++ci);
        if (ci === line.length) {
          del = true;
          setTimeout(tick, 2200);
          return;
        }
      } else {
        twEl.textContent = line.slice(0, --ci);
        if (ci === 0) {
          del = false;
          li = (li + 1) % typeLines.length;
        }
      }
      setTimeout(tick, del ? 14 : 40);
    }

    setTimeout(tick, 1200);

    const state = {
      papers: [],
      featured: [],
      featIdx: 0,
      autoTimer: null,
    };

    function normalizePaper(p, idx) {
      return {
        id: p.id ?? `paper-${idx}`,
        title: p.title ?? "Untitled",
        category: p.category ?? "Essay",
        year: Number(p.year) || new Date().getFullYear(),
        date: p.date ?? "",
        keywords: Array.isArray(p.keywords) ? p.keywords : [],
        readTime: p.readTime ?? "10 min",
        type: p.type ?? "Essay",
        featured: Boolean(p.featured),
        summary: p.summary ?? "",
      };
    }

    async function loadPapers() {
      if (!firestoreReady || !db) {
        return fallbackPapers.map(normalizePaper);
      }

      try {
        const snap = await getDocs(collection(db, "papers"));
        const data = snap.docs.map((doc, idx) => normalizePaper({ id: doc.id, ...doc.data() }, idx));
        return data.length ? data : fallbackPapers.map(normalizePaper);
      } catch (err) {
        console.warn("Firestore unavailable, using fallback.", err);
        return fallbackPapers.map(normalizePaper);
      }
    }

    function renderFeatured(index) {
      const paper = state.featured[index];
      if (!paper) return;
      document.getElementById("feat-kicker").textContent = paper.category;
      const titleEl = document.getElementById("feat-title");
      titleEl.textContent = paper.title;
      titleEl.onclick = () => openOverlay(paper.id);
      document.getElementById("feat-summary").textContent = paper.summary;
      document.getElementById("feat-kws").innerHTML = paper.keywords
        .map((kw) => `<span class="feat-kw">${kw}</span>`)
        .join("");
      document.getElementById("feat-meta").innerHTML = `
        <span>${paper.date || paper.year}</span>
        <span class="feat-meta-dot"></span>
        <span>${paper.readTime} read</span>
        <span class="feat-meta-dot"></span>
        <span>${paper.type}</span>
      `;
      document.getElementById("feat-btn").onclick = () => openOverlay(paper.id);
      document.getElementById("feat-ghost").textContent = String(index + 1).padStart(2, "0");
      document.querySelectorAll(".feat-dot").forEach((dot, i) => {
        dot.classList.toggle("active", i === index);
      });
    }

    function buildFeatDots() {
      const dotsEl = document.getElementById("feat-dots");
      dotsEl.innerHTML = state.featured
        .map((_, i) => `<div class="feat-dot${i === 0 ? " active" : ""}" data-idx="${i}"></div>`)
        .join("");
      dotsEl.querySelectorAll(".feat-dot").forEach((dot) => {
        dot.addEventListener("click", () => {
          goFeat(Number(dot.dataset.idx));
        });
      });
    }

    function goFeat(idx) {
      const max = state.featured.length;
      if (!max) return;
      state.featIdx = ((idx % max) + max) % max;
      renderFeatured(state.featIdx);
      resetAutoTimer();
    }

    function resetAutoTimer() {
      clearInterval(state.autoTimer);
      if (state.featured.length > 1) {
        state.autoTimer = setInterval(() => {
          goFeat(state.featIdx + 1);
        }, 8000);
      }
    }
    function populateFilters(papers) {
      const catEl = document.getElementById("f-cat");
      const yrEl = document.getElementById("f-yr");
      const tpEl = document.getElementById("f-tp");

      const categories = Array.from(new Set(papers.map((p) => p.category))).sort();
      const years = Array.from(new Set(papers.map((p) => p.year))).sort((a, b) => b - a);
      const types = Array.from(new Set(papers.map((p) => p.type))).sort();

      catEl.innerHTML = `<option value="">All Topics</option>${categories
        .map((c) => `<option value="${c}">${c}</option>`)
        .join("")}`;
      yrEl.innerHTML = `<option value="">All Years</option>${years
        .map((y) => `<option value="${y}">${y}</option>`)
        .join("")}`;
      tpEl.innerHTML = `<option value="">All Types</option>${types
        .map((t) => `<option value="${t}">${t}</option>`)
        .join("")}`;
    }

    function renderList(list) {
      const el = document.getElementById("papers-list");
      const countEl = document.getElementById("paper-count");
      countEl.textContent = `${list.length} paper${list.length === 1 ? "" : "s"}`;
      if (!list.length) {
        el.innerHTML = '<div class="no-results">No papers match your search.</div>';
        return;
      }

      el.innerHTML = "";
      list.forEach((p, i) => {
        const row = document.createElement("div");
        row.className = "paper-row";
        row.innerHTML = `
          <div class="row-n">${String(i + 1).padStart(2, "0")}</div>
          <div class="row-body">
            <div class="row-cat">${p.category}</div>
            <div class="row-title">${p.title}</div>
            <div class="row-kws">${p.keywords.map((k) => `<span class="row-kw">${k}</span>`).join("")}</div>
            <div class="row-preview">${p.summary}</div>
          </div>
          <div class="row-aside">
            <div class="row-date">${p.date || p.year}</div>
            <div class="row-time">${p.readTime} read</div>
            <div class="row-arrow">&#8594;</div>
          </div>
        `;
        row.addEventListener("click", () => openOverlay(p.id));
        el.appendChild(row);
      });
    }

    function applyFilters() {
      const q = document.getElementById("s-in").value.toLowerCase();
      const cat = document.getElementById("f-cat").value;
      const yr = document.getElementById("f-yr").value;
      const tp = document.getElementById("f-tp").value;

      const filtered = state.papers.filter((p) => {
        const matchesQuery =
          !q ||
          [p.title, p.summary, p.category, ...p.keywords]
            .join(" ")
            .toLowerCase()
            .includes(q);
        const matchesCat = !cat || p.category === cat;
        const matchesYr = !yr || String(p.year) === yr;
        const matchesType = !tp || p.type === tp;
        return matchesQuery && matchesCat && matchesYr && matchesType;
      });

      renderList(filtered);
    }

    function openOverlay(id) {
      const paper = state.papers.find((p) => p.id === id);
      if (!paper) return;
      const label = document.getElementById("ov-label");
      label.textContent = `${paper.date || paper.year} - ${paper.readTime} read`;
      const body = document.getElementById("ov-body");
      body.innerHTML = `
        <div class="ov-kicker">${paper.category}</div>
        <h1 class="ov-title">${paper.title}</h1>
        <div class="ov-meta">
          <div class="ov-mc"><div class="ov-ml">Author</div><div class="ov-mv">Birkley Grunewald</div></div>
          <div class="ov-mc"><div class="ov-ml">Date</div><div class="ov-mv">${paper.date || paper.year}</div></div>
          <div class="ov-mc"><div class="ov-ml">Reading Time</div><div class="ov-mv">${paper.readTime}</div></div>
          <div class="ov-mc"><div class="ov-ml">Keywords</div><div class="ov-mv">${paper.keywords.join(" - ")}</div></div>
        </div>
        <div class="ov-abstract">
          <div class="ov-abs-lbl">Abstract</div>
          <p>${paper.summary}</p>
          <p>The argument is situated within broader debates in comparative political economy and international relations.</p>
          <p>The paper suggests that structural conditions constrain but do not determine political possibilities.</p>
        </div>
        <div class="ov-dls">
          <div class="ov-abs-lbl">Downloads</div>
          <div class="ov-dl-row">
            <button class="btn-dl" disabled>Download PDF</button>
            <button class="btn-dl" disabled>Clean Text</button>
            <button class="btn-dl" disabled>Export Citation</button>
          </div>
        </div>
      `;
      const overlay = document.getElementById("overlay");
      overlay.classList.add("open");
      overlay.scrollTop = 0;
      document.body.style.overflow = "hidden";
    }

    function closeOverlay() {
      document.getElementById("overlay").classList.remove("open");
      document.body.style.overflow = "";
    }

    document.getElementById("ov-close").addEventListener("click", closeOverlay);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeOverlay();
    });

    document.getElementById("feat-prev").addEventListener("click", () => goFeat(state.featIdx - 1));
    document.getElementById("feat-next").addEventListener("click", () => goFeat(state.featIdx + 1));

    document.getElementById("s-in").addEventListener("input", applyFilters);
    document.getElementById("f-cat").addEventListener("change", applyFilters);
    document.getElementById("f-yr").addEventListener("change", applyFilters);
    document.getElementById("f-tp").addEventListener("change", applyFilters);

    loadPapers().then((papers) => {
      state.papers = papers;
      state.featured = papers.filter((p) => p.featured);
      if (!state.featured.length) {
        state.featured = papers.slice(0, 3);
      }
      buildFeatDots();
      renderFeatured(0);
      resetAutoTimer();
      populateFilters(papers);
      renderList(papers);
    });
  </script>
  <style>
    .papers-page {
      background: var(--bg);
      color: var(--text);
    }

    .papers-hero {
      position: relative;
      min-height: calc(100vh - var(--nav-h));
      background: var(--bg);
      overflow: hidden;
      display: flex;
      align-items: center;
    }

    .hero-ink {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
    }

    .hero-content {
      position: relative;
      padding: 80px 52px 100px;
      width: 100%;
    }

    .hero-kicker {
      font-family: "Cormorant Garamond", serif;
      font-size: 10.5px;
      letter-spacing: 0.52em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 30px;
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .hero-kicker::before {
      content: "";
      width: 28px;
      height: 1px;
      background: var(--gold);
    }

    .hero-title {
      font-family: var(--font-ink);
      font-weight: 300;
      font-size: clamp(58px, 9.2vw, 144px);
      line-height: 1.0;
      letter-spacing: -0.04em;
      color: white;
      mix-blend-mode: difference;
      position: relative;
      animation: heroTitleIn 0.9s ease 0.22s both;
    }

    .hero-divider {
      width: 52px;
      height: 2px;
      background: var(--gold);
      margin: 40px 0 28px;
      position: relative;
      animation: heroTitleIn 0.7s ease 0.4s both;
    }

    .hero-tw-wrap {
      max-width: 440px;
      min-height: 60px;
      position: relative;
      animation: heroTitleIn 0.7s ease 0.52s both;
    }

    .hero-tw {
      font-family: var(--font-lora);
      font-size: 15.5px;
      font-style: italic;
      line-height: 1.76;
      color: white;
      mix-blend-mode: difference;
    }

    .cursor {
      display: inline-block;
      width: 2px;
      height: 1em;
      background: var(--gold);
      margin-left: 2px;
      vertical-align: text-bottom;
      animation: blink 0.85s step-end infinite;
      mix-blend-mode: difference;
    }

    .hero-scroll-hint {
      position: absolute;
      bottom: 40px;
      left: 52px;
      font-family: "Cormorant Garamond", serif;
      font-size: 9.5px;
      letter-spacing: 0.38em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .hero-byline {
      position: absolute;
      bottom: 40px;
      right: 52px;
      text-align: right;
    }

    .hero-byline-label {
      font-family: "Cormorant Garamond", serif;
      font-size: 9.5px;
      letter-spacing: 0.42em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 4px;
    }

    .hero-byline-name {
      font-family: var(--font-ink);
      font-weight: 300;
      font-size: 22px;
      color: var(--text-mid);
      letter-spacing: -0.01em;
    }
    .sd {
      display: flex;
      align-items: center;
      gap: 24px;
      padding: 20px 52px;
      background: var(--bg-warm);
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
    }

    .sd-lbl {
      font-family: "Cormorant Garamond", serif;
      font-size: 9.5px;
      letter-spacing: 0.46em;
      text-transform: uppercase;
      color: var(--text-muted);
      flex-shrink: 0;
    }

    .sd-line {
      flex: 1;
      height: 1px;
      background: var(--rule);
    }

    .sd-blot {
      flex-shrink: 0;
      opacity: 0.45;
    }

    .featured {
      position: relative;
      min-height: calc(100vh - var(--nav-h));
      background: var(--bg);
      overflow: hidden;
      display: flex;
      align-items: center;
    }

    .feat-ink {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
    }

    .feat-ghost {
      position: absolute;
      right: 4%;
      bottom: -4%;
      font-family: var(--font-ink);
      font-weight: 700;
      font-size: clamp(200px, 24vw, 380px);
      line-height: 1;
      letter-spacing: -0.06em;
      color: white;
      mix-blend-mode: difference;
      pointer-events: none;
      user-select: none;
    }

    .feat-content {
      position: relative;
      padding: 80px 52px 110px;
      width: 100%;
    }

    .feat-kicker {
      font-family: "Cormorant Garamond", serif;
      font-size: 10px;
      letter-spacing: 0.46em;
      text-transform: uppercase;
      margin-bottom: 22px;
      color: white;
      mix-blend-mode: difference;
    }

    .feat-title {
      font-family: var(--font-ink);
      font-weight: 400;
      font-size: clamp(32px, 4.8vw, 76px);
      line-height: 1.1;
      letter-spacing: -0.025em;
      color: white;
      mix-blend-mode: difference;
      max-width: 68%;
      margin-bottom: 26px;
      cursor: pointer;
    }

    .feat-summary {
      font-family: var(--font-lora);
      font-size: 15px;
      font-style: italic;
      line-height: 1.84;
      color: white;
      mix-blend-mode: difference;
      max-width: 520px;
      margin-bottom: 28px;
    }

    .feat-kws {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      margin-bottom: 28px;
    }

    .feat-kw {
      font-family: "Cormorant Garamond", serif;
      font-size: 10.5px;
      letter-spacing: 0.1em;
      color: white;
      mix-blend-mode: difference;
      border: 1px solid rgba(128, 128, 128, 0.45);
      padding: 3px 11px;
    }

    .feat-meta {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 34px;
      font-family: "Cormorant Garamond", serif;
      font-size: 12px;
      letter-spacing: 0.06em;
      color: white;
      mix-blend-mode: difference;
    }

    .feat-meta-dot {
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: currentColor;
    }

    .btn-read {
      font-family: "Cormorant Garamond", serif;
      font-size: 11px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      background: var(--green);
      color: #fff;
      border: none;
      padding: 13px 30px;
      cursor: pointer;
      transition: background 0.22s, padding-right 0.22s;
      display: inline-flex;
      align-items: center;
      gap: 10px;
    }

    .btn-read:hover {
      background: var(--green-mid);
      padding-right: 36px;
    }

    .feat-controls {
      position: absolute;
      bottom: 40px;
      left: 52px;
      right: 52px;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 16px;
    }

    .feat-dots {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .feat-dot {
      height: 2px;
      background: var(--rule);
      cursor: pointer;
      transition: width 0.3s ease, background 0.3s ease;
      width: 18px;
    }

    .feat-dot.active {
      width: 42px;
      background: var(--gold);
    }

    .feat-arr {
      width: 38px;
      height: 38px;
      background: transparent;
      border: 1px solid var(--rule);
      color: var(--text-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 15px;
      font-family: serif;
      transition: all 0.2s;
    }

    .feat-arr:hover {
      border-color: var(--gold);
      color: var(--gold);
    }
    #library {
      padding: 88px 52px 120px;
      position: relative;
      overflow: hidden;
      background: var(--bg);
    }

    .lib-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 44px;
      position: relative;
    }


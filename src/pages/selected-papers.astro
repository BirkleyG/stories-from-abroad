            fill="#111110"
            opacity="0.56"
          />
          <circle cx="318" cy="446" r="8" fill="#111110" opacity="0.4" />
          <circle cx="303" cy="460" r="5" fill="#111110" opacity="0.27" />
          <circle cx="291" cy="472" r="2.8" fill="#111110" opacity="0.16" />
          <ellipse cx="382" cy="668" rx="34" ry="22" fill="#111110" opacity="0.84" />
          <path
            d="M 332 706 C 346 696, 366 702, 362 726 C 358 744, 338 748, 325 734 C 314 722, 318 712, 332 706 Z"
            fill="#111110"
            opacity="0.62"
          />
          <circle cx="304" cy="748" r="9" fill="#111110" opacity="0.44" />
          <circle cx="286" cy="760" r="5.5" fill="#111110" opacity="0.29" />
          <circle cx="272" cy="770" r="3" fill="#111110" opacity="0.17" />
        </g>
      </svg>

      <div class="feat-ghost" id="feat-ghost">01</div>

      <div class="feat-content" id="feat-content">
        <div class="feat-kicker" id="feat-kicker">Political Economy</div>
        <h2 class="feat-title" id="feat-title">
          The Erosion of Fiscal Sovereignty in Post-Crisis Europe
        </h2>
        <p class="feat-summary" id="feat-summary">
          An examination of how the 2008 financial crisis restructured the relationship between national fiscal
          autonomy and supranational governance with attention to the political consequences of technocratic
          discipline.
        </p>
        <div class="feat-kws" id="feat-kws"></div>
        <div class="feat-meta" id="feat-meta"></div>
        <button class="btn-read" id="feat-btn">{copy.featured.button}</button>
      </div>

      <div class="feat-controls">
        <div class="feat-dots" id="feat-dots"></div>
        <div class="feat-arrows">
          <button class="feat-arr" onclick="moveFeat(-1)">&larr;</button>
          <button class="feat-arr" onclick="moveFeat(1)">&rarr;</button>
        </div>
      </div>
    </section>

    <div class="sd">
      <svg class="sd-blot" width="22" height="22" viewBox="0 0 50 50">
        <g filter="url(#f-sm)">
          <circle cx="25" cy="25" r="14" fill="#111110" opacity="0.6" />
          <circle cx="35" cy="17" r="6" fill="#111110" opacity="0.4" />
        </g>
        <g filter="url(#f-drop)">
          <circle cx="42" cy="12" r="3" fill="#111110" opacity="0.26" />
          <circle cx="7" cy="35" r="2" fill="#111110" opacity="0.18" />
        </g>
      </svg>
      <span class="sd-lbl">{copy.archive.label}</span>
      <div class="sd-line"></div>
    </div>

    <section id="library">
      <svg
        class="lib-ink"
        viewBox="0 0 820 260"
        preserveAspectRatio="xMinYMin slice"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="
      M 0 0
      L 480 0
      C 450 18, 420 38, 438 62
      C 456 86, 422 108, 388 128
      C 354 148, 362 180, 320 200
      C 278 220, 240 248, 190 260
      L 0 260 Z
    "
          fill="#111110"
        />
        <path
          d="M 452 46 C 466 36, 482 44, 478 62 C 474 78, 458 84, 448 72 C 438 62, 440 54, 452 46 Z"
          fill="#111110"
          opacity="0.8"
        />

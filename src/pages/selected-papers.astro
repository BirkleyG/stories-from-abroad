          <circle cx="132" cy="4" r="4" fill="#111110" opacity="0.35" />
        </g>
      </svg>

      <svg
        class="mblot"
        style="left: -10px; top: 680px; width: 100px; height: 160px"
        viewBox="0 0 100 160"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <g filter="url(#f-drop)">
          <path
            d="M 54 12 C 72 8, 86 22, 82 44 C 78 66, 60 76, 50 94
               C 42 110, 46 134, 34 148 C 24 160, 12 154, 10 138
               C 8 122, 20 108, 28 90 C 36 72, 28 54, 32 36
               C 36 18, 38 14, 54 12 Z"
            fill="#111110"
          />
          <circle cx="78" cy="14" r="8" fill="#111110" opacity="0.6" />
          <circle cx="86" cy="6" r="5" fill="#111110" opacity="0.4" />
        </g>
      </svg>

      <svg
        class="mblot"
        style="right: -8px; bottom: 90px; width: 120px; height: 100px"
        viewBox="0 0 120 100"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <g filter="url(#f-drop)">
          <ellipse cx="62" cy="54" rx="46" ry="30" fill="#111110" />
          <ellipse cx="26" cy="28" rx="18" ry="13" fill="#111110" opacity="0.8" />
          <circle cx="10" cy="16" r="8" fill="#111110" opacity="0.6" />
          <circle cx="3" cy="8" r="5" fill="#111110" opacity="0.4" />
        </g>
      </svg>

      <div class="lib-head">
        <div>
          <div class="lib-kicker">{copy.archive.label}</div>
          <h2 class="lib-title">{copy.archive.title}</h2>
        </div>
        <div class="lib-count" id="paper-count">{copy.archive.countPlaceholder}</div>
      </div>

      <div class="search-bar">
        <div class="s-wrap">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
          <input
            class="s-input"
            id="s-in"
            type="text"
            placeholder={copy.archive.searchPlaceholder}
            oninput="doFilter()"
          />
        </div>
        <div class="s-sep"></div>
        <select class="f-sel" id="f-cat" onchange="doFilter()">
          <option value="">{copy.archive.filters.categories}</option>
        </select>
        <div class="s-sep"></div>
        <select class="f-sel" id="f-yr" onchange="doFilter()">
          <option value="">{copy.archive.filters.years}</option>
        </select>
        <div class="s-sep"></div>
        <select class="f-sel" id="f-tp" onchange="doFilter()">
          <option value="">{copy.archive.filters.type}</option>
        </select>
      </div>

      <div class="papers-list" id="papers-list"></div>
    </section>

    <div style="height: 1px; background: var(--border)"></div>

    <section id="author">
      <div class="author-portrait">
        <span class="portrait-ph">{copy.author.portraitLabel}</span>
      </div>

      <svg
        class="portrait-drips"
        viewBox="0 0 600 600"
        preserveAspectRatio="xMaxYMid meet"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="M 580 80 C 590 100, 592 130, 585 160 C 578 190, 582 220, 575 250
             C 568 280, 572 310, 565 340 C 558 370, 562 400, 555 430"
          stroke="#111110"
          stroke-width="1.5"
          fill="none"
          opacity="0.18"
        />
        <path
          d="M 550 432 C 558 422, 570 428, 568 444 C 566 458, 554 462, 546 452 C 540 444, 542 438, 550 432 Z"
          fill="#111110"
          opacity="0.28"
        />
        <path
          d="M 572 180 C 578 172, 588 176, 586 188 C 584 198, 574 202, 568 194 C 563 188, 566 186, 572 180 Z"
          fill="#111110"
          opacity="0.22"
        />
        <circle cx="578" cy="288" r="5" fill="#111110" opacity="0.18" />
        <circle cx="560" cy="370" r="3.2" fill="#111110" opacity="0.14" />
        <circle cx="544" cy="462" r="2" fill="#111110" opacity="0.1" />
      </svg>

      <div class="author-content">
        <div class="author-kicker">{copy.author.kicker}</div>
        <h3 class="author-name" set:html={copy.author.nameHtml}></h3>
        <p class="author-role">{copy.author.role}</p>
        {copy.author.bio.map((paragraph) => (
          <p class="author-bio">{paragraph}</p>
        ))}
        <div class="int-tags">
          {copy.author.tags.map((tag) => (
            <span class="int-tag">{tag}</span>
          ))}
        </div>
      </div>
    </section>

    <footer>
      <p>{copy.footer.left}</p>
      <p>{copy.footer.right}</p>
    </footer>

    <div id="overlay">
      <div class="ov-nav">
        <button class="ov-close" onclick="closeOverlay()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12" />
            <polyline points="12 19 5 12 12 5" />
          </svg>
          {copy.overlay.backLabel}
        </button>
        <span class="ov-label" id="ov-label"></span>
      </div>
      <div class="ov-body" id="ov-body"></div>
    </div>

    <script>
      (function () {
        const copy = {copyJson};
        const lines = copy.typewriterLines;
        let li = 0;
        let ci = 0;
        let del = false;
        const twEl = document.getElementById("tw-el");
        if (!twEl) return;
        twEl.textContent = lines[0];
        function tick() {
          const s = lines[li];
          if (!del) {
            twEl.textContent = s.slice(0, ++ci);
            if (ci === s.length) {
              del = true;
              setTimeout(tick, 2800);
              return;
            }
          } else {
            twEl.textContent = s.slice(0, --ci);
            if (ci === 0) {
              del = false;
              li = (li + 1) % lines.length;
            }
          }
          setTimeout(tick, del ? 14 : 46);
        }
        setTimeout(tick, 1400);
      })();
    </script>
    <script type="module">
      import { collection, getDocs } from "firebase/firestore";
      import { db, firestoreReady } from "../lib/firebaseClient";
      import { fallbackPapers } from "../lib/fallbackData";

      const copy = {copyJson};
      const counterTemplate = copy.featured.counterTemplate;
      const formatCounter = (current, total) =>
        counterTemplate.replace("{current}", current).replace("{total}", total);

      const state = {
        papers: [],
        featured: [],
        featIdx: 0,
        autoTimer: null,
      };

      function normalizePaper(p, idx) {
        const kw = Array.isArray(p.keywords)
          ? p.keywords
          : Array.isArray(p.kw)
            ? p.kw
            : Array.isArray(p.tags)
              ? p.tags
              : [];

        return {
          id: p.id ?? `paper-${idx}`,
          title: p.title ?? copy.defaults.title,
          cat: p.category ?? p.cat ?? copy.defaults.category,
          year: Number(p.year) || new Date().getFullYear(),
          date: p.date ?? "",
          kw,
          time: p.readTime ?? p.time ?? copy.defaults.time,
          type: p.type ?? copy.defaults.type,
          featured: Boolean(p.featured),
          summary: p.summary ?? "",
        };
      }

      async function loadPapers() {
        if (!firestoreReady || !db) {
          return fallbackPapers.map(normalizePaper);
        }
        try {
          const snap = await getDocs(collection(db, "papers"));
          const data = snap.docs.map((doc, idx) => normalizePaper({ id: doc.id, ...doc.data() }, idx));
          return data.length ? data : fallbackPapers.map(normalizePaper);
        } catch (err) {
          console.warn("Firestore unavailable, using fallback.", err);
          return fallbackPapers.map(normalizePaper);
        }
      }

      function triggerFeatAnim() {
        const blendEls = document.querySelectorAll(
          ".feat-kicker,.feat-title,.feat-summary,.feat-kws,.feat-meta,.btn-read"
        );
        blendEls.forEach((el) => {
          el.style.animation = "none";
        });
        void document.getElementById("feat-content").offsetWidth;
        blendEls.forEach((el) => {
          el.style.animation = "";
        });
      }

      function updateFeat(idx) {
        const p = state.featured[idx];
        if (!p) return;
        const title = document.getElementById("feat-title");
        document.getElementById("feat-kicker").textContent = p.cat;
        title.textContent = p.title;
        title.onclick = () => openPaper(p.id);
        document.getElementById("feat-summary").textContent = p.summary;
        document.getElementById("feat-kws").innerHTML = p.kw.map((k) => `<span class="feat-kw">${k}</span>`).join("");
        document.getElementById("feat-meta").innerHTML = `
          <span>${p.date || p.year}</span>
          <span class="feat-meta-dot"></span>
          <span>${p.time}${copy.featured.metaReadSuffix}</span>
          <span class="feat-meta-dot"></span>
          <span>${p.type}</span>`;
        document.getElementById("feat-btn").onclick = () => openPaper(p.id);
        document.getElementById("feat-ghost").textContent = String(idx + 1).padStart(2, "0");
        const ctr = document.getElementById("feat-ctr-sd");
        if (ctr) {
          const total = String(state.featured.length).padStart(2, "0");
          const current = String(idx + 1).padStart(2, "0");
          ctr.textContent = formatCounter(current, total);
        }
        document.querySelectorAll(".feat-dot").forEach((d, i) => d.classList.toggle("active", i === idx));
        triggerFeatAnim();
      }

      function buildFeatDots() {
        document.getElementById("feat-dots").innerHTML = state.featured
          .map((_, i) => `<div class="feat-dot${i === 0 ? " active" : ""}" onclick="goFeat(${i})"></div>`)
          .join("");
      }

      function goFeat(newIdx) {
        const max = state.featured.length;
        if (!max) return;
        newIdx = ((newIdx % max) + max) % max;
        if (newIdx === state.featIdx) return;
        state.featIdx = newIdx;
        updateFeat(state.featIdx);
        resetAutoTimer();
      }

      function moveFeat(dir) {
        goFeat(state.featIdx + dir);
      }

      function resetAutoTimer() {
        clearInterval(state.autoTimer);
        if (state.featured.length < 2) return;
        state.autoTimer = setInterval(() => goFeat(state.featIdx + 1), 8000);
      }

      function buildList(list) {
        const el = document.getElementById("papers-list");
        document.getElementById("paper-count").textContent = `${list.length} ${
          list.length !== 1 ? copy.archive.countPlural : copy.archive.countSingular
        }`;
        el.innerHTML = "";
        if (!list.length) {
          el.innerHTML = `<div class="no-results">${copy.archive.emptyState}</div>`;
          return;
        }
        list.forEach((p, i) => {
          const row = document.createElement("div");
          row.className = "paper-row";
          row.onclick = () => openPaper(p.id);
          row.innerHTML = `
            <div class="row-n">${String(i + 1).padStart(2, "0")}</div>
            <div class="row-body">
              <div class="row-cat">${p.cat}</div>
              <div class="row-title">${p.title}</div>
              <div class="row-kws">${p.kw.map((k) => `<span class="row-kw">${k}</span>`).join("")}</div>
              <div class="row-preview">${p.summary}</div>
            </div>
            <div class="row-aside">
              <div class="row-date">${p.date || p.year}</div>
              <div class="row-time">${p.time}${copy.archive.readSuffix}</div>
              <div class="row-arrow">&rarr;</div>
            </div>`;
          el.appendChild(row);
        });
      }

      function fillSelect(id, label, items) {
        const sel = document.getElementById(id);
        sel.innerHTML = `<option value="">${label}</option>` + items.map((it) => `<option>${it}</option>`).join("");
      }

      function populateFilters(list) {
        const cats = Array.from(new Set(list.map((p) => p.cat).filter(Boolean))).sort();
        const years = Array.from(new Set(list.map((p) => p.year).filter(Boolean))).sort((a, b) => b - a);
        const types = Array.from(new Set(list.map((p) => p.type).filter(Boolean))).sort();
        fillSelect("f-cat", copy.archive.filters.categories, cats);
        fillSelect("f-yr", copy.archive.filters.years, years);
        fillSelect("f-tp", copy.archive.filters.type, types);
      }

      function doFilter() {
        const q = document.getElementById("s-in").value.toLowerCase();
        const cat = document.getElementById("f-cat").value;
        const yr = document.getElementById("f-yr").value;
        const tp = document.getElementById("f-tp").value;
        buildList(
          state.papers.filter((p) => {
            const m = !q || [p.title, p.summary, ...p.kw, p.cat].some((x) => String(x).toLowerCase().includes(q));
            return m && (!cat || p.cat === cat) && (!yr || p.year === Number(yr)) && (!tp || p.type === tp);
          })
        );
      }
      window.doFilter = doFilter;
      window.moveFeat = moveFeat;
      window.goFeat = goFeat;

      const citStyles = copy.overlay.citationStyles;
      function cite(p, s) {
        const t = p.title;
        const yr = p.year;
        const d = p.date || String(p.year);
        switch (s) {
          case "APA":
            return `${copy.overlay.citationAuthorShort} (${yr}). <em>${t}</em>. <em>${copy.overlay.citeSource}</em>.`;
          case "MLA":
            return `${copy.overlay.citationAuthorFull}. "${t}." <em>${copy.overlay.citeSource}</em>, ${d}.`;
          case "Chicago":
            return `${copy.overlay.citationAuthorFull}. "${t}." <em>${copy.overlay.citeSource}</em>. ${d}.`;
          case "Harvard":
            return `${copy.overlay.citationAuthorShort} (${yr}) '${t}', <em>${copy.overlay.citeSource}</em>.`;
          case "BibTeX":
            return `@article{${copy.overlay.citationKey}${yr},\n  author={${copy.overlay.citationAuthorBib}},\n  title={${t}},\n  year={${yr}},\n  journal={${copy.overlay.citeSource}}\n}`;
          default:
            return "";
        }
      }
      function setCit(pid, s) {
        const p = state.papers.find((x) => x.id === pid);
        if (!p) return;
        document.getElementById("cit-out").innerHTML = cite(p, s);
        document.querySelectorAll(".cs-btn").forEach((b) => b.classList.toggle("active", b.dataset.s === s));
      }
      window.setCit = setCit;

      function openPaper(id) {
        const p = state.papers.find((x) => x.id === id);
        if (!p) return;
        const dateLabel = p.date || String(p.year);
        const timeLabel = p.time ? `${p.time}${copy.overlay.timeSuffix}` : "";
        const kwLabel = p.kw.length ? p.kw.join(copy.overlay.kwSeparator) : copy.overlay.keywordsEmpty;
        document.getElementById("ov-label").textContent = `${dateLabel} - ${timeLabel}`;
        document.getElementById("ov-body").innerHTML = `
          <div class="ov-kicker">${p.cat}</div>
          <h1 class="ov-title">${p.title}</h1>
          <div class="ov-meta">
            <div class="ov-mc"><div class="ov-ml">${copy.overlay.metaLabels.author}</div><div class="ov-mv">${copy.hero.byName}</div></div>
            <div class="ov-mc"><div class="ov-ml">${copy.overlay.metaLabels.date}</div><div class="ov-mv">${dateLabel}</div></div>
            <div class="ov-mc"><div class="ov-ml">${copy.overlay.metaLabels.readingTime}</div><div class="ov-mv">${p.time}</div></div>
            <div class="ov-mc"><div class="ov-ml">${copy.overlay.metaLabels.keywords}</div><div class="ov-mv">${kwLabel}</div></div>
          </div>
          <div class="ov-cite">
            <div class="ov-cite-body">
              <div class="ov-cite-lbl">${copy.overlay.citeLabel}</div>
              <div class="ov-cite-txt" id="cit-out">${cite(p, "APA")}</div>
            </div>
            <div class="ov-cite-styles">
              ${citStyles
                .map(
                  (s) => `<button class="cs-btn${s === "APA" ? " active" : ""}" data-s="${s}" onclick="setCit('${p.id}','${s}')">${s}</button>`
                )
                .join("")}
            </div>
          </div>
          <div class="ov-abstract">
            <div class="ov-abs-lbl">${copy.overlay.abstractLabel}</div>
            <p>${p.summary}</p>
            <p>${copy.overlay.placeholder.abstractParagraphs[0]}</p>
            <p>${copy.overlay.placeholder.abstractParagraphs[1]}</p>
          </div>
          <div class="ov-text">
            <span class="sec-mark">${copy.overlay.placeholder.sectionMarks[0]}</span>
            <p>${copy.overlay.placeholder.bodyParagraphs[0]}</p>
            <h2>${copy.overlay.placeholder.headings[0]}</h2>
            <p>${copy.overlay.placeholder.bodyParagraphs[1]}</p>
            <blockquote>${copy.overlay.placeholder.blockquote}</blockquote>
            <p>${copy.overlay.placeholder.bodyParagraphs[2]}</p>
            <h2>${copy.overlay.placeholder.headings[1]}</h2>
            <span class="sec-mark">${copy.overlay.placeholder.sectionMarks[1]}</span>
            <p>${copy.overlay.placeholder.bodyParagraphs[3]}</p>
            <p>${copy.overlay.placeholder.bodyParagraphs[4]}</p>
          </div>
          <div class="ov-dls">
            <button class="btn-dl dl-pdf" disabled>${copy.overlay.downloadButtons[0]}</button>
            <button class="btn-dl dl-txt" disabled>${copy.overlay.downloadButtons[1]}</button>
            <button class="btn-dl dl-cit" disabled>${copy.overlay.downloadButtons[2]}</button>
          </div>
        `;
        const ov = document.getElementById("overlay");
        ov.classList.add("open");
        ov.scrollTop = 0;
        document.body.style.overflow = "hidden";
      }

      function closeOverlay() {
        document.getElementById("overlay").classList.remove("open");
        document.body.style.overflow = "";
      }
      window.closeOverlay = closeOverlay;
      window.openPaper = openPaper;

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeOverlay();
        if (document.getElementById("overlay").classList.contains("open")) return;
        if (e.key === "ArrowRight") moveFeat(1);
        if (e.key === "ArrowLeft") moveFeat(-1);
      });

      async function init() {
        const data = await loadPapers();
        state.papers = data;
        state.featured = data.filter((p) => p.featured);
        if (!state.featured.length) {
          state.featured = data.slice(0, 3);
        }
        populateFilters(state.papers);
        buildFeatDots();
        updateFeat(0);
        resetAutoTimer();
        buildList(state.papers);
      }

      init();
    </script>
  </body>
</html>

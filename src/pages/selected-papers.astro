---
import { siteCopy } from "../content/siteCopy";
const base = import.meta.env.BASE_URL ?? "/";
const basePath = base.endsWith("/") ? base : `${base}/`;
const copy = siteCopy.papers;
const copyJson = JSON.stringify({ ...copy, fallbackPapers: [] });
const publicFirestoreConfigJson = JSON.stringify({
  projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID ?? "",
  apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY ?? "",
});
const initialFeatCounter = copy.featured.counterTemplate
  .replace("{current}", "01")
  .replace("{total}", "03");
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{copy.meta.title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Lora:ital,wght@0,400;0,500;1,400;1,500&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --white: #fafaf7;
        --off: #f2f0eb;
        --ink: #111110;
        --ink2: #2e2c28;
        --ink3: #7a7570;
        --green: #c79a33;
        --green2: #dfb35a;
        --gold: #c79a33;
        --gold2: #dfb35a;
        --gold3: #b07d20;
        --border: #e7e0d4;
        --nav-h: 58px;
      }
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        background: var(--white);
        color: var(--ink);
        font-family: "Lora", Georgia, serif;
        overflow-x: hidden;
      }
      ::selection {
        background: var(--gold);
        color: #fff;
      }

      #nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 200;
        height: var(--nav-h);
        background: #fff;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 52px;
      }
      .nav-back {
        font-family: "Cormorant Garamond", serif;
        font-size: 11px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--ink3);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: color 0.2s, gap 0.2s;
      }
      .nav-back:hover {
        color: var(--gold);
        gap: 14px;
      }
      .nav-label {
        font-family: "Cormorant Garamond", serif;
        font-size: 10.5px;
        letter-spacing: 0.38em;
        text-transform: uppercase;
        color: var(--ink3);
      }

      #hero {
        position: relative;
        min-height: 100vh;
        padding-top: var(--nav-h);
        background: var(--white);
        overflow: hidden;
        display: flex;
        align-items: center;
      }
      .hero-ink {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        display: block;
      }
      .hero-content {
        position: relative;
        padding: 80px 52px 100px;
        width: 100%;
      }
      .hero-kicker {
        font-family: "Cormorant Garamond", serif;
        font-size: 10.5px;
        letter-spacing: 0.52em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 14px;
        animation: slideUp 0.7s ease 0.1s both;
      }
      .hero-kicker::before {
        content: "";
        width: 28px;
        height: 1px;
        background: var(--gold);
      }
      .hero-title {
        font-family: "Cormorant", serif;
        font-weight: 300;
        font-size: clamp(58px, 9.2vw, 144px);
        line-height: 1;
        letter-spacing: -0.04em;
        display: block;
        white-space: nowrap;
        color: white;
        mix-blend-mode: difference;
        position: relative;
        animation: heroTitleIn 0.9s ease 0.22s both;
      }
      .hero-title strong {
        font-weight: 700;
        font-style: italic;
        display: inline;
      }
      @keyframes heroTitleIn {
        from {
          top: 28px;
        }
        to {
          top: 0;
        }
      }
      .hero-divider {
        width: 52px;
        height: 2px;
        background: var(--gold);
        margin: 40px 0 12px;
        position: relative;
        animation: heroTitleIn 0.7s ease 0.4s both;
      }
      .hero-placeholder {
        width: min(420px, 72vw);
        min-height: 16px;
        margin: 14px 0 26px;
        overflow: hidden;
        border-radius: 14px;
      }
      .hero-placeholder.is-empty {
        height: 16px;
        border: 1px solid var(--gold);
        border-radius: 999px;
        opacity: 0.45;
      }
      .hero-placeholder img {
        width: 100%;
        aspect-ratio: 16 / 6;
        object-fit: cover;
        display: block;
      }
      .hero-tw-wrap {
        max-width: 440px;
        min-height: 60px;
        position: relative;
        animation: heroTitleIn 0.7s ease 0.52s both;
      }
      .hero-tw {
        font-family: "Lora", serif;
        font-size: 15.5px;
        font-style: italic;
        line-height: 1.76;
        color: white;
        mix-blend-mode: difference;
      }
      .cursor {
        display: inline-block;
        width: 2px;
        height: 1em;
        background: var(--gold);
        margin-left: 2px;
        vertical-align: text-bottom;
        animation: blink 0.85s step-end infinite;
        mix-blend-mode: difference;
      }
      @keyframes blink {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0;
        }
      }
      @keyframes slideUp {
        from {
          transform: translateY(18px);
        }
        to {
          transform: none;
        }
      }
      .hero-scroll-hint {
        position: absolute;
        bottom: 40px;
        left: 52px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-family: "Cormorant Garamond", serif;
        font-size: 9.5px;
        letter-spacing: 0.38em;
        text-transform: uppercase;
        color: var(--ink3);
        animation: slideUp 0.5s ease 0.7s both;
      }
      .hero-scroll-hint::before {
        content: "";
        width: 1px;
        height: 36px;
        background: linear-gradient(to bottom, transparent, var(--ink3));
      }
      .hero-byline {
        position: absolute;
        bottom: 40px;
        right: 52px;
        text-align: right;
        animation: slideUp 0.5s ease 0.7s both;
      }
      .hero-byline-label {
        font-family: "Cormorant Garamond", serif;
        font-size: 9.5px;
        letter-spacing: 0.42em;
        text-transform: uppercase;
        color: var(--ink3);
        margin-bottom: 4px;
      }
      .hero-byline-name {
        font-family: "Cormorant", serif;
        font-weight: 300;
        font-size: 22px;
        color: var(--ink2);
        letter-spacing: -0.01em;
      }

      .sd {
        display: flex;
        align-items: center;
        gap: 24px;
        padding: 20px 52px;
        background: var(--off);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }
      .sd-lbl {
        font-family: "Cormorant Garamond", serif;
        font-size: 9.5px;
        letter-spacing: 0.46em;
        text-transform: uppercase;
        color: var(--ink3);
        flex-shrink: 0;
      }
      .sd-line {
        flex: 1;
        height: 1px;
        background: var(--border);
      }
      .sd-blot {
        flex-shrink: 0;
        opacity: 0.45;
      }

      #featured {
        position: relative;
        min-height: calc(100vh - var(--nav-h));
        background: var(--white);
        overflow: hidden;
        display: flex;
        align-items: center;
      }
      .feat-ink {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        display: block;
      }
      .feat-ghost {
        position: absolute;
        right: 4%;
        bottom: -4%;
        font-family: "Cormorant", serif;
        font-weight: 700;
        font-size: clamp(200px, 24vw, 380px);
        line-height: 1;
        letter-spacing: -0.06em;
        color: white;
        mix-blend-mode: difference;
        pointer-events: none;
        user-select: none;
      }
      .feat-content {
        position: relative;
        padding: 80px 52px 110px;
        width: 100%;
      }
      .feat-kicker {
        font-family: "Cormorant Garamond", serif;
        font-size: 10px;
        letter-spacing: 0.46em;
        text-transform: uppercase;
        margin-bottom: 22px;
        color: white;
        mix-blend-mode: difference;
        display: flex;
        align-items: center;
        gap: 14px;
        animation: slideUp 0.6s ease 0.08s both;
      }
      .feat-kicker::before {
        content: "";
        width: 22px;
        height: 1px;
        background: currentColor;
      }
      .feat-title {
        font-family: "Cormorant", serif;
        font-weight: 400;
        font-size: clamp(32px, 4.8vw, 76px);
        line-height: 1.1;
        letter-spacing: -0.025em;
        color: white;
        mix-blend-mode: difference;
        max-width: 68%;
        margin-bottom: 26px;
        cursor: pointer;
        position: relative;
        animation: heroTitleIn 0.85s ease 0.16s both;
      }
      .feat-summary {
        font-family: "Lora", serif;
        font-size: 15px;
        font-style: italic;
        line-height: 1.84;
        color: white;
        mix-blend-mode: difference;
        max-width: 520px;
        margin-bottom: 28px;
        position: relative;
        animation: heroTitleIn 0.7s ease 0.26s both;
      }
      .feat-kws {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        margin-bottom: 28px;
        animation: heroTitleIn 0.6s ease 0.34s both;
      }
      .feat-kw {
        font-family: "Cormorant Garamond", serif;
        font-size: 10px;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.64);
        border: 1px solid rgba(255, 255, 255, 0.16);
        padding: 4px 10px;
      }
      .feat-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        font-family: "Cormorant Garamond", serif;
        font-size: 11px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.55);
        margin-bottom: 34px;
        animation: heroTitleIn 0.6s ease 0.38s both;
      }
      .feat-meta-dot {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.3);
        display: inline-block;
      }
      .btn-read {
        font-family: "Cormorant Garamond", serif;
        font-size: 11px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        padding: 12px 28px;
        background: var(--green);
        color: #fff;
        border: none;
        cursor: pointer;
        transition: background 0.2s;
        animation: heroTitleIn 0.6s ease 0.44s both;
      }
      .btn-read:hover {
        background: var(--green2);
      }
      .feat-controls {
        position: absolute;
        left: 52px;
        right: 52px;
        bottom: 26px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .feat-dots {
        display: flex;
        gap: 10px;
      }
      .feat-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        border: 1px solid rgba(255, 255, 255, 0.45);
        cursor: pointer;
        transition: background 0.2s, transform 0.2s;
      }
      .feat-dot.active {
        background: #fff;
        transform: scale(1.1);
      }
      .feat-arrows {
        display: flex;
        gap: 10px;
      }
      .feat-arr {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 1px solid rgba(255, 255, 255, 0.3);
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
        cursor: pointer;
        transition: background 0.2s, border 0.2s;
      }
      .feat-arr:hover {
        background: rgba(255, 255, 255, 0.18);
        border-color: rgba(255, 255, 255, 0.5);
      }

      #library {
        position: relative;
        background: var(--white);
        padding: 62px 52px 90px;
        overflow: hidden;
      }
      .lib-ink {
        position: absolute;
        top: 0;
        left: 0;
        width: 70%;
        height: 260px;
        pointer-events: none;
      }
      .mblot {
        position: absolute;
        opacity: 0.08;
        pointer-events: none;
        transition: opacity 0.2s, transform 0.2s;
      }
      #library:has(.paper-row:hover) .mblot {
        opacity: 0;
      }
      .lib-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 30px;
        position: relative;
      }
      .lib-kicker {
        font-family: "Cormorant Garamond", serif;
        font-size: 10px;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 12px;
      }
      .lib-title {
        font-family: "Cormorant", serif;
        font-weight: 400;
        font-size: 60px;
        letter-spacing: -0.03em;
        color: white;
        mix-blend-mode: difference;
      }
      .lib-count {
        font-family: "Cormorant Garamond", serif;
        font-size: 10px;
        letter-spacing: 0.36em;
        text-transform: uppercase;
        color: var(--ink3);
      }

      .search-bar {
        display: flex;
        align-items: center;
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 999px;
        overflow: hidden;
        margin-bottom: 22px;
      }
      .s-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 18px;
        color: var(--ink3);
        flex: 1;
        min-height: 54px;
      }
      .s-input {
        border: none;
        outline: none;
        width: 100%;
        font-family: "Lora", serif;
        font-size: 14px;
        background: transparent;
      }
      .s-sep {
        display: none;
      }
      .f-sel {
        border: none;
        outline: none;
        padding: 0 18px;
        font-family: "Cormorant Garamond", serif;
        font-size: 11px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--ink3);
        background: transparent;
        min-width: 150px;
        cursor: pointer;
        height: 54px;
        border-left: 1px solid var(--border);
      }

      .papers-list {
        display: flex;
        flex-direction: column;
        position: relative;
      }
      .paper-row {
        display: grid;
        grid-template-columns: 52px 1fr 200px;
        gap: 18px;
        padding: 22px 6px;
        border-bottom: 1px solid var(--border);
        cursor: pointer;
        transition: background 0.2s, padding-left 0.2s;
      }
      .paper-row:first-child {
        border-top: 1px solid var(--border);
      }
      .paper-row:hover {
        background: var(--off);
        padding-left: 10px;
      }
      .row-n {
        font-family: "Cormorant Garamond", serif;
        font-size: 12px;
        letter-spacing: 0.2em;
        color: var(--ink3);
        transition: color 0.2s;
      }
      .paper-row:hover .row-n {
        color: var(--gold);
      }
      .row-body {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .row-cat {
        font-family: "Cormorant Garamond", serif;
        font-size: 10px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--ink3);
      }
      .row-title {
        font-family: "Cormorant", serif;
        font-weight: 500;
        font-size: 26px;
        letter-spacing: -0.02em;
        color: var(--ink);
        transition: color 0.2s;
      }
      .paper-row:hover .row-title {
        color: var(--gold3);
      }
      .row-kws {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }
      .row-kw {
        font-family: "Cormorant Garamond", serif;
        font-size: 9.5px;
        letter-spacing: 0.26em;
        text-transform: uppercase;
        color: var(--ink3);
        border: 1px solid var(--border);
        padding: 3px 8px;
      }
      .row-preview {
        font-size: 14px;
        color: var(--ink3);
        line-height: 1.7;
      }
      .row-aside {
        display: flex;
        flex-direction: column;
        gap: 8px;
        align-items: flex-end;
        text-align: right;
      }
      .row-date {
        font-family: "Cormorant Garamond", serif;
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ink3);
      }
      .row-time {
        font-family: "Cormorant Garamond", serif;
        font-size: 10px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--ink3);
      }
      .row-arrow {
        font-size: 18px;
        color: var(--ink3);
        transition: color 0.2s, transform 0.2s;
      }
      .paper-row:hover .row-arrow {
        color: var(--gold);
        transform: translateX(5px);
      }
      .no-results {
        padding: 40px 0;
        color: var(--ink3);
        text-align: center;
        font-style: italic;
      }

      #author {
        position: relative;
        display: flex;
        background: var(--white);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        min-height: 520px;
        overflow: hidden;
      }
      .author-portrait {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 44%;
        background: var(--ink);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .portrait-ph {
        font-family: "Cormorant Garamond", serif;
        font-size: 10.5px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.36);
      }
      .author-portrait img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .portrait-drips {
        position: absolute;
        right: 56%;
        top: 0;
        height: 100%;
        pointer-events: none;
      }
      .author-content {
        margin-left: 44%;
        padding: 82px 52px 72px 6%;
        position: relative;
      }
      .author-kicker {
        font-family: "Cormorant Garamond", serif;
        font-size: 10px;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 18px;
      }
      .author-name {
        font-family: "Cormorant", serif;
        font-weight: 400;
        font-size: 54px;
        color: white;
        mix-blend-mode: difference;
        letter-spacing: -0.03em;
        margin-bottom: 10px;
      }
      .author-name strong {
        font-weight: 700;
        font-style: italic;
      }
      .author-role {
        font-family: "Cormorant Garamond", serif;
        font-size: 11px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--ink3);
        margin-bottom: 22px;
      }
      .author-bio {
        font-size: 15px;
        line-height: 1.8;
        color: var(--ink2);
        margin-bottom: 18px;
        max-width: 560px;
      }
      .int-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 24px 0 36px;
      }
      .int-tag {
        font-family: "Cormorant Garamond", serif;
        font-size: 11px;
        color: var(--ink3);
        border: 1px solid var(--border);
        padding: 5px 14px;
        letter-spacing: 0.06em;
        transition: border-color 0.2s, color 0.2s;
        cursor: default;
      }
      .int-tag:hover {
        border-color: var(--gold);
        color: var(--gold);
      }

      footer {
        background: var(--ink);
        padding: 26px 52px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
      }
      footer p {
        font-family: "Cormorant Garamond", serif;
        font-size: 10.5px;
        letter-spacing: 0.2em;
        color: rgba(255, 255, 255, 0.22);
      }

      #overlay {
        position: fixed;
        inset: 0;
        z-index: 9000;
        background: var(--white);
        transform: translateY(100%);
        transition: transform 0.62s cubic-bezier(0.76, 0, 0.24, 1);
        overflow-y: auto;
      }
      #overlay.open {
        transform: translateY(0);
      }
      .ov-nav {
        position: sticky;
        top: 0;
        background: rgba(250, 250, 247, 0.96);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 52px;
        z-index: 10;
      }
      .ov-close {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-family: "Cormorant Garamond", serif;
        font-size: 11px;
        letter-spacing: 0.26em;
        text-transform: uppercase;
        color: var(--ink3);
        background: transparent;
        border: none;
        cursor: pointer;
        transition: color 0.2s, gap 0.2s;
      }
      .ov-close:hover {
        color: var(--gold);
        gap: 14px;
      }
      .ov-label {
        font-family: "Cormorant Garamond", serif;
        font-size: 10px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--ink3);
      }
      .ov-body {
        padding: 64px 52px 90px;
        max-width: 980px;
        margin: 0 auto;
      }
      .ov-kicker {
        font-family: "Cormorant Garamond", serif;
        font-size: 10px;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 14px;
      }
      .ov-title {
        font-family: "Cormorant", serif;
        font-weight: 400;
        font-size: clamp(38px, 6vw, 86px);
        letter-spacing: -0.03em;
        margin-bottom: 22px;
      }
      .ov-subtitle {
        margin: -8px 0 22px;
        max-width: 42rem;
        font-size: 18px;
        line-height: 1.7;
        color: var(--ink2);
      }
      .ov-meta {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 12px;
        padding: 18px 0 26px;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        margin-bottom: 28px;
      }
      .ov-mc {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .ov-ml {
        font-family: "Cormorant Garamond", serif;
        font-size: 9.5px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--ink3);
      }
      .ov-mv {
        font-size: 14px;
        color: var(--ink2);
      }
      .ov-cite {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        background: var(--off);
        border: 1px solid var(--border);
        padding: 18px;
        margin-bottom: 26px;
      }
      .ov-cite-body {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .ov-cite-lbl {
        font-family: "Cormorant Garamond", serif;
        font-size: 9.5px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--ink3);
      }
      .ov-cite-txt {
        font-size: 14px;
        color: var(--ink2);
      }
      .ov-cite-styles {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }
      .cs-btn {
        border: 1px solid var(--border);
        background: transparent;
        font-family: "Cormorant Garamond", serif;
        font-size: 10px;
        letter-spacing: 0.26em;
        text-transform: uppercase;
        padding: 8px 12px;
        cursor: pointer;
        color: var(--ink3);
        transition: border-color 0.2s, color 0.2s;
      }
      .cs-btn.active,
      .cs-btn:hover {
        border-color: var(--gold);
        color: var(--gold);
      }
      .ov-abstract {
        margin-bottom: 26px;
      }
      .ov-abs-lbl {
        font-family: "Cormorant Garamond", serif;
        font-size: 10px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--ink3);
        margin-bottom: 10px;
      }
      .ov-abstract p {
        font-size: 15px;
        line-height: 1.9;
        color: var(--ink2);
        margin-bottom: 18px;
      }
      .ov-text {
        font-size: 16px;
        line-height: 1.9;
        color: var(--ink2);
      }
      .ov-text h2 {
        font-family: "Cormorant", serif;
        font-weight: 500;
        font-size: 26px;
        color: var(--ink);
        margin: 44px 0 16px;
        letter-spacing: -0.01em;
      }
      .ov-text p {
        margin-bottom: 22px;
      }
      .ov-text blockquote {
        border-left: 2px solid var(--gold);
        padding: 2px 0 2px 24px;
        margin: 32px 0;
        color: var(--ink);
        font-style: italic;
        font-size: 17px;
        line-height: 1.7;
      }
      .sec-mark {
        font-family: "Cormorant Garamond", serif;
        font-size: 10.5px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--gold);
        display: block;
        margin-bottom: 8px;
        opacity: 0.7;
      }
      .ov-dls {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        padding-top: 38px;
        border-top: 1px solid var(--border);
      }
      .btn-dl {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: "Cormorant Garamond", serif;
        font-size: 11px;
        letter-spacing: 0.26em;
        text-transform: uppercase;
        padding: 12px 26px;
        cursor: pointer;
        background: transparent;
        border: 1px solid;
        text-decoration: none;
        transition: all 0.2s;
      }
      .btn-dl:disabled {
        opacity: 0.45;
        cursor: not-allowed;
        border-color: var(--border);
        color: var(--ink3);
      }
      .btn-dl:disabled:hover {
        background: transparent;
      }
      .dl-pdf {
        color: var(--ink);
        border-color: var(--ink2);
      }
      .dl-pdf:hover {
        background: var(--ink);
        color: var(--white);
      }
      .dl-txt {
        color: var(--green);
        border-color: var(--green);
      }
      .dl-txt:hover {
        background: var(--green);
        color: #fff;
      }
      .dl-cit {
        color: var(--gold);
        border-color: var(--gold);
      }
      .dl-cit:hover {
        background: var(--gold);
        color: #fff;
      }

      @media (max-width: 1080px) {
        #nav,
        #library,
        .sd,
        footer {
          padding-left: 32px;
          padding-right: 32px;
        }
        .hero-content,
        .feat-content {
          padding-left: 32px;
          padding-right: 32px;
        }
        .feat-controls {
          left: 32px;
          right: 32px;
        }
        .feat-title {
          max-width: 80%;
        }
        .author-content {
          padding: 72px 40px 72px 4%;
        }
        .lib-ink {
          width: 75%;
        }
      }
      @media (max-width: 760px) {
        .hero-ink {
          opacity: 0.5;
          transform: translateX(22%) scale(0.96);
          transform-origin: 100% 50%;
        }
        .hero-title {
          white-space: normal;
          font-size: clamp(48px, 12vw, 80px);
        }
        .feat-title {
          max-width: 100%;
          font-size: clamp(28px, 6vw, 48px);
        }
        .feat-ghost {
          font-size: 140px;
        }
        .search-bar {
          flex-direction: column;
          align-items: stretch;
          border-radius: 18px;
        }
        .f-sel {
          border-left: none;
          border-top: 1px solid var(--border);
          min-width: 100%;
        }
        .paper-row {
          grid-template-columns: 36px 1fr;
        }
        .row-aside {
          display: none;
        }
        #author {
          flex-direction: column;
          align-items: stretch;
        }
        .author-portrait {
          position: relative;
          width: 100%;
          height: 280px;
          flex-shrink: 0;
        }
        .portrait-drips {
          display: none;
        }
        .author-content {
          padding: 48px 32px;
          margin-left: 0;
        }
        .ov-body {
          padding: 48px 24px 80px;
        }
        .ov-cite {
          flex-direction: column;
        }
        .lib-ink {
          width: 100%;
        }
        .sd-blot {
          width: 20px !important;
          height: 20px !important;
          opacity: 0.34;
        }
        .mblot {
          display: block;
          opacity: 0.06;
        }
        .mblot-east {
          right: -34px !important;
          top: 260px !important;
          width: 108px !important;
          height: 92px !important;
        }
        .mblot-west {
          left: -28px !important;
          top: 560px !important;
          width: 78px !important;
          height: 126px !important;
        }
        .mblot-south {
          right: -24px !important;
          bottom: 58px !important;
          width: 92px !important;
          height: 78px !important;
        }
      }
      @media (max-width: 560px) {
        :root {
          --nav-h: 54px;
        }
        .hero-ink {
          opacity: 0.44;
          transform: translateX(34%) scale(0.92);
          transform-origin: 100% 48%;
        }
        #nav {
          padding: 0 14px;
        }
        .nav-back {
          gap: 6px;
          letter-spacing: 0.2em;
          font-size: 9px;
        }
        .nav-label {
          display: none;
        }
        .hero-content {
          padding: 60px 14px 80px;
        }
        .hero-kicker {
          letter-spacing: 0.32em;
          margin-bottom: 18px;
        }
        .hero-divider {
          margin: 26px 0 10px;
        }
        .hero-tw-wrap {
          min-height: 50px;
        }
        .hero-scroll-hint {
          left: 14px;
          bottom: 22px;
          letter-spacing: 0.28em;
        }
        .hero-byline {
          right: 14px;
          bottom: 22px;
        }
        .hero-byline-name {
          font-size: 18px;
        }
        .sd {
          padding: 14px 14px;
          gap: 12px;
        }
        .feat-content {
          padding: 48px 14px 96px;
        }
        .feat-controls {
          left: 14px;
          right: 14px;
        }
        #library {
          padding: 44px 14px 64px;
        }
        .sd-blot {
          width: 16px !important;
          height: 16px !important;
          opacity: 0.3;
        }
        .lib-head {
          gap: 16px;
          align-items: flex-start;
          flex-direction: column;
        }
        .lib-title {
          font-size: clamp(38px, 14vw, 56px);
        }
        .paper-row {
          grid-template-columns: 1fr;
          gap: 8px;
          padding: 14px 2px;
        }
        .mblot {
          opacity: 0.05;
        }
        .mblot-east {
          right: -42px !important;
          top: 232px !important;
          width: 88px !important;
          height: 76px !important;
        }
        .mblot-west {
          left: -30px !important;
          top: 520px !important;
          width: 66px !important;
          height: 106px !important;
        }
        .mblot-south {
          right: -28px !important;
          bottom: 44px !important;
          width: 78px !important;
          height: 64px !important;
        }
        .row-n {
          display: none;
        }
        .row-title {
          font-size: 24px;
        }
        .row-preview {
          font-size: 13px;
          line-height: 1.55;
        }
        .ov-nav {
          padding: 0 14px;
        }
        .ov-body {
          padding: 40px 14px 64px;
        }
        .ov-h1 {
          font-size: clamp(30px, 10vw, 42px);
        }
      }
      @media (max-width: 400px) {
        .feat-ghost {
          font-size: 105px;
          right: 2%;
        }
        .search-bar {
          border-radius: 12px;
        }
        .s-wrap {
          padding: 12px 12px;
          min-height: 48px;
        }
        .btn-read {
          width: 100%;
          text-align: center;
        }
      }
    </style>
  </head>
  <body>

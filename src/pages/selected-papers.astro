          />
          <circle cx="410" cy="214" r="7" fill="#111110" opacity="0.36" />
          <circle cx="396" cy="226" r="4" fill="#111110" opacity="0.23" />
          <circle cx="385" cy="236" r="2.2" fill="#111110" opacity="0.14" />
          <path

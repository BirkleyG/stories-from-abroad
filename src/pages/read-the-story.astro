---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteCopy } from "../content/siteCopy";

const base = import.meta.env.BASE_URL ?? "/";
const basePath = base.endsWith("/") ? base : `${base}/`;
const copy = siteCopy.readStory;
---

<BaseLayout
  title={copy.meta.title}
  description={copy.meta.description}
  navMode="single"
  navLabel={copy.header.label}
  showSubscribe={false}
>
  <section class="page-header">
    <span class="section-label">{copy.header.label}</span>
    <h1>{copy.header.title}</h1>
    <p>{copy.header.subtitle}</p>
  </section>

  <section class="about-wrap">
    <div class="container-wide">
      <div class="about-grid">
        <div class="about-portrait">
          <div class="portrait-frame">
            <div class="portrait-placeholder">{copy.body.portraitLabel}</div>
          </div>
        </div>
        <div class="about-body">
          <h2>{copy.body.title}</h2>
          {copy.body.paragraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
          <div class="about-cta">
            <button class="btn-ghost" type="button" data-modal-open="subscribe">{copy.buttons.primary}</button>
            <a class="btn-solid" href={`${basePath}selected-papers/`}>{copy.buttons.secondary}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .about-wrap {
      padding: 4rem 0 6rem;
    }

    .about-grid {
      display: grid;
      grid-template-columns: minmax(240px, 320px) 1fr;
      gap: 3.5rem;
      align-items: start;
    }

    .portrait-frame {
      border: 1px solid var(--rule);
      padding: 0.8rem;
      background: var(--bg-warm);
    }

    .portrait-placeholder {
      background: linear-gradient(135deg, var(--bg-dark), var(--bg-warm));
      aspect-ratio: 3 / 4;
      display: grid;
      place-items: center;
      font-family: var(--font-sc);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .about-body h2 {
      font-family: var(--font-title);
      font-size: clamp(1.8rem, 3.6vw, 2.8rem);
      margin-bottom: 1rem;
    }

    .about-body p {
      margin-bottom: 1.2rem;
      color: var(--text-mid);
    }

    .about-cta {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin-top: 1.5rem;
    }

    @media (max-width: 900px) {
      .about-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>

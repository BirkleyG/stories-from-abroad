---
const base = import.meta.env.BASE_URL ?? "/";
const basePath = base.endsWith("/") ? base : `${base}/`;
const publicFirestoreConfigJson = JSON.stringify({
  projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID ?? "",
  apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY ?? "",
});
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Birkley — Photography</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --k:#080808;--w:#F0EFEB;
  --g1:#111;--g2:#1A1A1A;--g3:#282828;--g4:#505050;--g5:#888;
  --pk:#FF2D78;--bl:#1478FF;--or:#FF6500;
  --nav-h:60px;
  --ctrl-h:54px; /* featured controls + progress bar height */
  --font-d:'Bebas Neue',sans-serif;
  --font-b:'Cormorant Garamond',serif;
  --font-m:'IBM Plex Mono',monospace;
  --a:#FF2D78;
  --dot-color:#FF2D78; /* FIX 1: changes dynamically */
}
html,body{height:100%;overflow-x:hidden}
body{background:var(--k);color:var(--w);font-family:var(--font-b);-webkit-font-smoothing:antialiased}
body::after{content:"";position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size:180px;opacity:.028}
img{display:block}

/* ── NAV ── */
.nav{position:fixed;top:0;left:0;right:0;z-index:600;height:var(--nav-h);display:flex;align-items:center;justify-content:space-between;padding:0 40px;background:rgba(8,8,8,.93);backdrop-filter:blur(16px);border-bottom:1px solid var(--g2)}
.nav::after{content:"";position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--pk),var(--bl),var(--or));opacity:.55}
.nav-logo{font-family:var(--font-d);font-size:17px;letter-spacing:5px;cursor:pointer;user-select:none;text-decoration:none;color:var(--w)}
.nav-right{display:flex;gap:28px;align-items:center}
.nav-link{font-family:var(--font-m);font-size:9px;letter-spacing:2.5px;text-transform:uppercase;color:var(--g4);cursor:pointer;transition:color .2s;user-select:none}
.nav-link:hover,.nav-link.cur{color:var(--w)}
/* FIX 1: dot color driven by CSS var, transitions smoothly */
.nav-dot{
  width:5px;height:5px;border-radius:50%;
  background:var(--dot-color);
  transition:background .5s ease;
}

/* ── PAGE SYSTEM ── */
.page{display:none;padding-top:var(--nav-h);position:relative;z-index:1}
.page.active{display:block}

/* ── SHARED ── */
.sec-label{font-family:var(--font-m);font-size:8.5px;letter-spacing:5px;text-transform:uppercase;color:var(--g4);margin-bottom:10px}
.sec-title{font-family:var(--font-d);font-size:54px;letter-spacing:1px;color:var(--w);line-height:1}
.footer{border-top:1px solid var(--g2);padding:32px 40px;display:flex;justify-content:space-between;align-items:center}
.foot-l{font-family:var(--font-d);font-size:15px;letter-spacing:5px;color:var(--g3)}
.foot-r{font-family:var(--font-m);font-size:8.5px;letter-spacing:2px;color:var(--g4)}

/* ══════════════════════════════════════════
   FEATURED ROTATOR
   FIX 2: .feat is flex-column. Track gets remaining
   height after controls, so photos never clip behind them.
══════════════════════════════════════════ */
.feat{
  border-bottom:1px solid var(--g2);
  overflow:hidden;background:var(--k);position:relative;
  display:flex;
  flex-direction:column;
  height:calc(100vh - var(--nav-h)); /* full viewport minus nav */
}

/* SEEN/FELT/KEPT — flex-direction:column, words stack top-to-bottom */
.feat-mantra{
  position:absolute;top:50%;transform:translateY(-50%);
  right:20px;
  display:flex;flex-direction:column;
  align-items:flex-end;gap:0;line-height:.82;
  z-index:1;pointer-events:none;
}
.feat-mantra .mw{
  font-family:var(--font-d);
  font-size:clamp(80px,11vw,148px);
  letter-spacing:-2px;display:block;
  color:transparent;
  -webkit-text-stroke:1.5px rgba(240,239,235,.07);
  transition:-webkit-text-stroke-color .45s ease;
}
.feat-mantra .mw.m-on{
  -webkit-text-stroke:1.5px var(--dot-color); /* matches dot color */
}

/* Track takes all remaining space; controls sit below */
.feat-track{
  flex:1;          /* fills available height */
  min-height:0;    /* prevents flex blowout */
  position:relative;
  overflow:hidden;
}

.fslide{position:absolute;inset:0;display:flex;align-items:center;padding:0 48px;opacity:0;pointer-events:none;transition:opacity .75s cubic-bezier(.4,0,.2,1)}
.fslide.active{opacity:1;pointer-events:auto}
.fslide.r{flex-direction:row}
.fslide.r .fs-img-wrap{flex:0 0 70%}
.fslide.r .fs-title-block{margin-left:-56px;align-items:flex-start;text-align:left}
.fslide.l{flex-direction:row-reverse}
.fslide.l .fs-img-wrap{flex:0 0 70%}
.fslide.l .fs-title-block{margin-right:-56px;align-items:flex-end;text-align:right}

/* Image wrapper — landscape default */
.fs-img-wrap{
  display:block;position:relative;
  height:100%;
  max-height:82vh;
  overflow:hidden;z-index:1;flex-shrink:0;cursor:pointer;
}
.fs-img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .8s cubic-bezier(.25,.46,.45,.94)}
.fs-img-wrap:hover .fs-img{transform:scale(1.025)}

/* Portrait slide: narrower wrapper so tall images aren't forced into landscape crop.
   The wrapper is ~48vh wide (portrait aspect), object-fit:cover fills it correctly. */
.fslide.portrait .fs-img-wrap{
  flex:0 0 auto;
  width:clamp(280px,34vw,480px); /* narrow column — portrait aspect */
  max-height:88vh;
  height:88vh;
}
/* Portrait layout mirrors normal: title block still overlaps the image edge */
.fslide.r.portrait{justify-content:flex-start}
.fslide.l.portrait{justify-content:flex-end}

.fs-title-block{flex:0 0 auto;width:340px;display:flex;flex-direction:column;background:var(--k);padding:36px 28px;position:relative;z-index:2;box-shadow:-40px 0 80px rgba(8,8,8,.97),40px 0 80px rgba(8,8,8,.97)}
.fs-eyebrow{font-family:var(--font-m);font-size:8.5px;letter-spacing:3.5px;text-transform:uppercase;color:var(--accent);margin-bottom:18px}
.fs-title{font-family:var(--font-d);font-size:clamp(50px,5.5vw,88px);line-height:.88;color:var(--accent);margin-bottom:30px}
.fs-cta{font-family:var(--font-m);font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--w);border-bottom:1px solid var(--accent);padding-bottom:3px;display:inline-flex;gap:7px;transition:color .2s;cursor:pointer;width:fit-content}
.fs-cta:hover{color:var(--accent)}

/* Controls sit at bottom of .feat, outside the track */
.feat-controls{
  flex-shrink:0;
  display:flex;align-items:center;justify-content:center;gap:20px;
  padding:14px 0 10px;
  background:var(--k);
}
.feat-arr{background:none;border:none;font-family:var(--font-m);font-size:15px;color:var(--g4);cursor:pointer;padding:6px 12px;transition:color .2s}
.feat-arr:hover{color:var(--w)}
.feat-dots{display:flex;gap:8px;align-items:center}
.feat-dot{width:6px;height:6px;border-radius:50%;background:var(--g3);border:none;padding:0;cursor:pointer;transition:background .3s,transform .3s}
.feat-dot.active{background:var(--w);transform:scale(1.4)}
.feat-prog{flex-shrink:0;height:2px;background:var(--g1)}
.feat-prog-fill{height:100%;background:linear-gradient(90deg,var(--pk),var(--bl),var(--or));width:0%}

/* ── SHOOTS GRID ── */
.shoots{border-top:1px solid var(--g2)}
.shoots-head{padding:64px 40px 40px}
.shoots-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.sc{display:block;background:var(--g1);overflow:hidden;transition:transform .35s cubic-bezier(.25,.46,.45,.94);cursor:pointer}
.sc:hover{transform:translateY(-6px)}
.sc-img-w{overflow:hidden;aspect-ratio:3/4;background:var(--g1)}
.sc-img{width:100%;height:100%;object-fit:cover;filter:brightness(.85);transition:transform .55s cubic-bezier(.25,.46,.45,.94),filter .35s}
.sc:hover .sc-img{transform:scale(1.05);filter:brightness(1)}
.sc-body{padding:18px 20px 8px}
.sc-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.sc-date{font-family:var(--font-m);font-size:8.5px;letter-spacing:2px;color:var(--g4)}
.sc-ct{font-family:var(--font-m);font-size:7.5px;letter-spacing:2px;text-transform:uppercase;padding:2px 8px;color:var(--accent);border:1px solid var(--accent)}
.sc-title{font-family:var(--font-d);font-size:26px;letter-spacing:1px;color:var(--w);margin-bottom:7px}
.sc-desc{font-family:var(--font-b);font-size:13px;font-style:italic;color:var(--g5);margin-bottom:14px;line-height:1.55}
.sc-tags{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:12px}
.sc-tag{font-family:var(--font-m);font-size:7.5px;letter-spacing:1px;text-transform:uppercase;padding:3px 8px;border:1px solid var(--g3);color:var(--g4)}
.sc-loc{font-family:var(--font-m);font-size:8.5px;letter-spacing:1.5px;color:var(--g4);margin-bottom:18px}
.sc-bar{height:3px;background:var(--accent);transition:height .25s}
.sc:hover .sc-bar{height:5px}

/* ══════════════════════════════════════════
   SHOOT GALLERY
   FIX 2: sg-wrap bottom:0 already accounts for no footer.
   sg-photos height:100% works because sg-wrap is fixed.
   sg-tile uses inset:0 so it fills sg-photos exactly.
══════════════════════════════════════════ */
#page-shoot{padding-top:0;min-height:0}
.sg-wrap{position:fixed;top:var(--nav-h);left:0;right:0;bottom:0;display:flex;overflow:hidden}

.sg-photos{position:relative;overflow:hidden;flex:1;min-width:0;height:100%}

@keyframes kbA{from{transform:scale(1) translate(0,0)}to{transform:scale(1.025) translate(-0.5%,0.3%)}}
@keyframes kbB{from{transform:scale(1) translate(0,0)}to{transform:scale(1.025) translate(0.5%,-0.3%)}}
.kb-play{animation:kbA 12s ease-out forwards}
.kb-b .kb-play{animation:kbB 12s ease-out forwards}

.sg-tile{
  position:absolute;inset:0;
  display:flex;align-items:center;justify-content:center;
  background:var(--k);
  transition:transform .62s cubic-bezier(.77,0,.18,1),opacity .45s ease;
  will-change:transform;overflow:hidden;
}
.sg-title-tile{flex-direction:column;justify-content:center;align-items:flex-start;padding:64px 56px;overflow:hidden}

/* Photos: width+height 100%, contain, pure black bg */
.sg-photo-tile img{
  width:100%;height:100%;
  object-fit:contain;
  display:block;
  background:var(--k);
}

.sg-scrollbar{position:absolute;left:0;top:0;bottom:0;width:2px;background:var(--g2);z-index:10}
.sg-scrollbar-fill{width:100%;transition:height .4s cubic-bezier(.25,.46,.45,.94)}

/* Right panel */
.sg-panel{width:300px;flex-shrink:0;display:flex;flex-direction:column;border-left:1px solid var(--g2);overflow-y:auto;padding:36px 28px 36px 32px;background:#0A0A0A}
.sg-panel::-webkit-scrollbar{width:2px}
.sg-panel::-webkit-scrollbar-thumb{background:var(--g3)}
.sg-counter{margin-bottom:32px}
.cnt-editorial{font-family:var(--font-d);font-size:72px;line-height:1;letter-spacing:-2px;color:var(--g2);display:flex;align-items:baseline;gap:4px}
.cnt-editorial .cur{color:var(--a)}
.cnt-editorial .sep,.cnt-editorial .tot{font-size:40px}
.cnt-documentary{font-family:var(--font-m);font-size:10px;letter-spacing:4px;color:var(--a);display:flex;align-items:center;gap:6px}
.cnt-documentary .sep,.cnt-documentary .tot{color:var(--g4)}
.cnt-cinematic{display:flex;align-items:flex-end;gap:8px}
.cnt-cinematic .cur{font-family:var(--font-b);font-size:52px;font-style:italic;font-weight:300;color:var(--a);line-height:1}
.cnt-cinematic .sep{display:none}
.cnt-cinematic .tot{font-family:var(--font-b);font-size:18px;color:var(--g3);font-style:italic;padding-bottom:6px}
.sg-pc{display:flex;flex-direction:column;flex:1;transition:opacity .22s}
.sg-pc.fading{opacity:0}
.sg-frame-title{margin-bottom:10px}
.ft-editorial{font-family:var(--font-d);font-size:28px;letter-spacing:1px;color:var(--a);line-height:1}
.ft-documentary{font-family:var(--font-m);font-size:10px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:var(--a)}
.ft-cinematic{font-family:var(--font-b);font-size:22px;font-style:italic;font-weight:300;color:var(--a);line-height:1.1}
.sg-caption{margin-bottom:0}
.cap-editorial{font-family:var(--font-b);font-size:15px;font-style:italic;color:var(--w);line-height:1.6;opacity:.75}
.cap-documentary{font-family:var(--font-m);font-size:10px;color:var(--w);line-height:1.8;opacity:.65}
.cap-cinematic{font-family:var(--font-b);font-size:15px;font-style:italic;color:var(--w);line-height:1.65;opacity:.7}
.sg-divider{height:1px;background:var(--g2);margin:20px 0}
.sg-meta-group{margin-bottom:12px}
.sg-meta-label{font-family:var(--font-m);font-size:7.5px;letter-spacing:3px;text-transform:uppercase;color:var(--g3);margin-bottom:4px}
.sg-meta-val{font-family:var(--font-b);font-size:15px;color:var(--a)}
.sg-exif-label{font-family:var(--font-m);font-size:7.5px;letter-spacing:4px;text-transform:uppercase;color:var(--g3);margin-bottom:12px}
.sg-exif-grid{display:flex;flex-direction:column;gap:10px}
.sg-exif-row{display:flex;justify-content:space-between;align-items:baseline}
.sg-exif-k{font-family:var(--font-m);font-size:7.5px;letter-spacing:2px;text-transform:uppercase;color:var(--g3)}
.sg-exif-v{font-family:var(--font-b);font-size:15px;color:var(--a)}
.sg-note{font-family:var(--font-b);font-size:13px;font-style:italic;line-height:1.6;margin-top:auto;padding-top:20px;border-top:1px solid var(--g2);color:var(--g4)}
.panel-accent-line{margin-top:20px;height:3px}
.panel-accent-mono{font-family:var(--font-m);font-size:7px;letter-spacing:4px;margin-top:auto;padding-top:20px;word-break:break-all;line-height:1.8;opacity:.15}
.panel-accent-dots{display:flex;gap:6px;flex-wrap:wrap;margin-top:auto;padding-top:20px}
.pdot{width:5px;height:5px;border-radius:50%;background:var(--g2);display:inline-block;transition:background .3s,transform .3s}
.pdot.active{background:var(--a);transform:scale(1.4)}

.mob-bar{display:none;position:fixed;bottom:0;left:0;right:0;height:46px;z-index:700;background:rgba(8,8,8,.92);backdrop-filter:blur(12px);border-top:1px solid var(--g2);align-items:center;padding:0 20px;gap:10px}
.mob-bar-num{font-family:var(--font-m);font-size:9px;letter-spacing:3px;flex-shrink:0}
.mob-bar-sep{width:1px;height:16px;background:var(--g3);flex-shrink:0}
.mob-bar-title{font-family:var(--font-b);font-size:16px;font-style:italic;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* ── ABOUT ── */
.ab-header{padding:72px 40px 64px;border-bottom:1px solid var(--g2)}
.ab-tag{font-family:var(--font-m);font-size:9px;letter-spacing:6px;text-transform:uppercase;color:var(--pk);margin-bottom:28px;display:flex;align-items:center;gap:12px}
.ab-tag::before{content:"";display:inline-block;width:32px;height:1px;background:var(--pk)}
.ab-name{font-family:var(--font-d);font-size:clamp(72px,11vw,148px);line-height:.88;letter-spacing:-1px;margin-bottom:36px}
.ab-name-oline{-webkit-text-stroke:1.5px var(--w);color:transparent}
.ab-role{display:flex;align-items:center;gap:16px;flex-wrap:wrap}
.ab-pill{font-family:var(--font-m);font-size:9px;letter-spacing:3px;text-transform:uppercase;padding:5px 14px;border:1px solid currentColor}
.ab-bio{display:grid;grid-template-columns:200px 1fr;gap:0 64px;padding:64px 40px;align-items:start}
.bio-p{font-family:var(--font-b);font-size:20px;line-height:1.72;color:var(--g5);margin-bottom:28px}
.bio-p em{font-style:italic;color:var(--w)}
.bio-p.closing{color:var(--g4);font-size:18px;font-style:italic;padding-top:10px;border-top:1px solid var(--g2);margin-top:10px}
.ab-rule{border:none;border-top:1px solid var(--g2);margin:0 40px}
.ab-current{padding:48px 40px;display:grid;grid-template-columns:200px 1fr;gap:0 64px;align-items:start}
.ab-cur-grid{display:flex;flex-direction:column}
.ab-cur-row{display:flex;gap:32px;padding:16px 0;border-bottom:1px solid var(--g2);align-items:baseline}
.ab-cur-row:first-child{border-top:1px solid var(--g2)}
.ab-cur-k{font-family:var(--font-m);font-size:8.5px;letter-spacing:3px;text-transform:uppercase;color:var(--g4);min-width:88px}
.ab-cur-v{font-family:var(--font-b);font-size:17px;color:var(--w)}
.ab-photos{padding:48px 40px 56px}
.ab-photos-head{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:32px}
.ab-photos-link{font-family:var(--font-m);font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--g4);border-bottom:1px solid var(--g3);padding-bottom:3px;transition:color .2s,border-color .2s;cursor:pointer;margin-bottom:4px}
.ab-photos-link:hover{color:var(--or);border-color:var(--or)}
.ab-photos-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:3px;margin-bottom:16px}
.ab-shoot-card{position:relative;overflow:hidden;aspect-ratio:3/4;background:var(--g1);cursor:pointer;display:block}
.ab-shoot-card img{width:100%;height:100%;object-fit:cover;filter:brightness(.75);transition:transform .6s cubic-bezier(.25,.46,.45,.94),filter .4s;display:block}
.ab-shoot-card:hover img{transform:scale(1.05);filter:brightness(.95)}
.ab-shoot-card-over{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:16px 18px;background:linear-gradient(to top,rgba(8,8,8,.75) 0%,transparent 60%);opacity:0;transition:opacity .35s}
.ab-shoot-card:hover .ab-shoot-card-over{opacity:1}
.ab-shoot-card-title{font-family:var(--font-d);font-size:22px;letter-spacing:1px;color:var(--w);line-height:1}
.ab-shoot-card-loc{font-family:var(--font-m);font-size:7.5px;letter-spacing:2px;text-transform:uppercase;color:rgba(240,239,235,.55);margin-top:4px}
.ab-shoot-card-bar{position:absolute;bottom:0;left:0;right:0;height:3px;transition:height .25s}
.ab-shoot-card:hover .ab-shoot-card-bar{height:5px}
.ab-photos-note{font-family:var(--font-b);font-size:14px;font-style:italic;color:var(--g4)}
.ab-contact{padding:64px 40px 72px;display:flex;gap:80px;align-items:flex-start;overflow:hidden}
.ab-contact-inner{flex:1;max-width:560px}
.ab-contact-h{font-family:var(--font-d);font-size:clamp(56px,8vw,110px);line-height:.88;letter-spacing:-1px;margin:20px 0 28px}
.ab-contact-oline{-webkit-text-stroke:1.5px var(--w);color:transparent}
.ab-contact-sub{font-family:var(--font-b);font-size:18px;font-style:italic;color:var(--g4);line-height:1.65;margin-bottom:40px;max-width:440px}
.ab-contact-links{display:flex;flex-direction:column}
.ab-clink{display:flex;align-items:baseline;gap:24px;padding:18px 0;border-bottom:1px solid var(--g2);transition:border-color .2s;cursor:pointer}
.ab-clink:first-child{border-top:1px solid var(--g2)}
.ab-clink:hover{border-bottom-color:var(--pk)}
.ab-clink-label{font-family:var(--font-m);font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--g4);min-width:48px}
.ab-clink-val{font-family:var(--font-b);font-size:18px;color:var(--w);transition:color .2s}
.ab-clink:hover .ab-clink-val{color:var(--pk)}
.ab-contact-deco{width:32px;align-self:stretch;display:flex;flex-direction:column;gap:3px;margin-left:auto;flex-shrink:0}
.deco-bar{width:100%;border-radius:1px;opacity:.55}

/* ── MOBILE ── */
@media(max-width:768px){
  .nav{padding:0 20px}.nav-right{gap:16px}
  .feat{height:calc(100svh - var(--nav-h))}
  .fslide{padding:0;flex-direction:column !important;justify-content:flex-end;align-items:stretch}
  .fslide .fs-img-wrap{flex:0 0 100%;height:100%;max-height:none;position:absolute;inset:0;z-index:1}

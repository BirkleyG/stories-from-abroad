  {
    slug: "tokyo-fragments",
    title: "Tokyo Fragments",
    desc: "Quiet moments in a city that never stops moving.",
    date: "Nov 2024",
    loc: "Tokyo, Japan",
    tags: ["street", "night", "japan"],
    accent: "#FF2D78",
    cover: "https://picsum.photos/seed/tky/480/620",
    count: 12,
  },
  {
    slug: "shanghai-nights",
    title: "Shanghai After Dark",
    desc: "The city transforms when the lights come on.",
    date: "Sep 2024",
    loc: "Shanghai, China",
    tags: ["architecture", "neon"],
    accent: "#1478FF",
    cover: "https://picsum.photos/seed/shg/480/620",
    count: 10,
  },
  {
    slug: "desert-bloom",
    title: "Desert Bloom",
    desc: "Silence, scale, and impossible color.",
    date: "Mar 2024",
    loc: "Mojave, USA",
    tags: ["landscape", "golden hour"],
    accent: "#FF6500",
    cover: "https://picsum.photos/seed/dsr/480/620",
    count: 8,
  },
  {
    slug: "pacific-coast",
    title: "Pacific Coast",
    desc: "Highway 1, from the top to the bottom.",
    date: "Jul 2024",
    loc: "California, USA",
    tags: ["road trip", "ocean"],
    accent: "#1478FF",
    cover: "https://picsum.photos/seed/pac/480/620",
    count: 9,
  },
  {
    slug: "studio-series",
    title: "Studio Series I",
    desc: "Controlled light, unguarded moments.",
    date: "Jan 2025",

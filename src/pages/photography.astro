<script is:inline>
/* ─────────────────────────────────────────────────────
   DATA
   order: 1=most recent. FIX 3: (order-1)%3 → 0=SEEN, 1=FELT, 2=KEPT
───────────────────────────────────────────────────── */
const SHOOTS = {
  kyoto:    {order:1,title:"Kyoto in Winter",    location:"Kyoto, Japan",          date:"February 2025",  intro:"The temples are less crowded when it's cold. You can actually hear the gravel under your feet. It changes things.",                                                               tags:["travel","temples","winter"],   accent:"#FF6500",camera:"Fujifilm GFX100S",lens:"63mm f/2.8",   template:"cinematic",   titles:["Torii","Temple Ground","The Monk","Stone Garden","Last Snow"],           captions:["Orange against pale winter sky.","Gravel and quiet.","He passed without looking up.","Raked every morning, regardless.","It melted by noon."],                cover:"https://picsum.photos/seed/kyt/480/620"},
  studio:   {order:2,title:"Studio Series I",    location:"New York, USA",          date:"January 2025",   intro:"Remove the location. Remove the context. What's left is just a person and a light source and whatever they decide to do with the space between them.",                               tags:["portrait","studio","fashion"], accent:"#1478FF",camera:"Hasselblad X2D",  lens:"90mm f/2.2",   template:"documentary", titles:["Subject I","The Look","Between Takes","Unguarded","Resolution"],        captions:["Before she knew I was ready.","Some people own the frame.","The moments between moments.","Dropped the mask for a second.","What the light found."],        cover:"https://picsum.photos/seed/std/480/620"},
  tokyo:    {order:3,title:"Tokyo Fragments",    location:"Tokyo, Japan",           date:"November 2024",  intro:"The city has a way of making you feel both invisible and entirely seen. These are the moments that fell through the cracks between trains.",                                          tags:["street","night","japan"],      accent:"#FF2D78",camera:"Sony A7IV",       lens:"35mm f/1.8",   template:"editorial",   titles:["2am, Shibuya","The Salary Man","Rain on Glass","Vending Light","Last Train"],   captions:["Shibuya crossing, long after the crowds left.","Waiting for a train that might not come.","Reflections worth stopping for.","The city's quiet glow.","End of the line."],     cover:"https://picsum.photos/seed/tky/480/620"},
  shanghai: {order:4,title:"Shanghai After Dark", location:"Shanghai, China",       date:"September 2024", intro:"There's a particular quality to the light at 11pm on the Bund. Neon hitting water makes the city feel like a myth about itself.",                                                       tags:["architecture","neon","china"], accent:"#1478FF",camera:"Leica M11",       lens:"28mm f/2.8",   template:"documentary", titles:["The Bund","Neon Puddle","Tower Lights","Night Market","The Crossing"],     captions:["Where old Shanghai watches the new.","Puddles remember everything.","Glass and light, competing.","The market never truly sleeps.","Thousands cross here every hour."],  cover:"https://picsum.photos/seed/shg/480/620"},
  pacific:  {order:5,title:"Pacific Coast",       location:"Highway 1, California", date:"July 2024",      intro:"There's no bad hour to drive Highway 1. We left at 4am anyway, because dawn light on the Pacific doesn't negotiate.",                                                                  tags:["road trip","ocean"],           accent:"#FF2D78",camera:"Sony A7IV",       lens:"16-35mm f/2.8",template:"editorial",   titles:["Before Dawn","The Pull","Fog Line","Cliff Edge","Due West"],              captions:["The sky before it decided what to do.","Water you could almost touch.","The fog had its own ideas.","Standing here changes your sense of scale.","Everything west of here is ocean."],cover:"https://picsum.photos/seed/pac/480/620"},
  desert:   {order:6,title:"Desert Bloom",        location:"Mojave Desert, USA",    date:"March 2024",     intro:"You drive for two hours and don't see anything. Then the light shifts, and suddenly there's so much to look at you have to stop the car.",                                                tags:["landscape","golden hour"],     accent:"#FF6500",camera:"Canon R5",        lens:"24-70mm f/2.8",template:"cinematic",   titles:["First Light","The Valley","Roadside","Bloom","Dusk Falls"],               captions:["Before the heat arrived.","Scale you can feel.","Something grows here anyway.","Against all odds, colour.","The desert earns its beauty."],                   cover:"https://picsum.photos/seed/dsr/480/620"},
};

// Mixed seeds — portrait and landscape for variety
const SEEDS = [
  {w:900,  h:1200},   // portrait
  {w:1300, h:750},    // landscape
  {w:800,  h:1100},   // portrait
  {w:1300, h:820},    // landscape
  {w:900,  h:1300},   // portrait
];
const SHUT  = ["1/125s","1/250s","1/60s","1/500s","1/30s"];
const APT   = ["f/1.8","f/2.8","f/1.4","f/5.6","f/2.0"];
const ISO   = [400,800,1600,200,640];
const NOTES = ["Shot hand-held, leaning against a wall.","Waited 20 minutes for this moment.","The colour barely needed touching in post.","This one surprised me in edit.","Golden hour — about 4 minutes left."];

/* ─────────────────────────────────────────────────────
   FIX 1: Set nav dot + CSS --dot-color globally
───────────────────────────────────────────────────── */
function setDotColor(color){
  document.documentElement.style.setProperty('--dot-color', color);
}

/* ─────────────────────────────────────────────────────
   About archive — 3 most recent shoots
───────────────────────────────────────────────────── */
(function(){
  const sorted = Object.entries(SHOOTS).sort((a,b)=>a[1].order-b[1].order).slice(0,3);
  const grid = document.getElementById('ab-photos-grid');
  grid.innerHTML = sorted.map(([slug,s])=>`
    <div class="ab-shoot-card" onclick="showShoot('${slug}')">
      <img src="${s.cover}" alt="${s.title}" loading="lazy"/>
      <div class="ab-shoot-card-over">
        <div class="ab-shoot-card-title">${s.title}</div>
        <div class="ab-shoot-card-loc">${s.location}</div>
      </div>
      <div class="ab-shoot-card-bar" style="background:${s.accent}"></div>
    </div>`).join('');
})();

/* ─────────────────────────────────────────────────────
   AUDIO
───────────────────────────────────────────────────── */
let audioCtx=null;
function getACtx(){if(!audioCtx)audioCtx=new(window.AudioContext||window.webkitAudioContext)();if(audioCtx.state==='suspended')audioCtx.resume();return audioCtx;}
function playShutter(){
  try{
    const ctx=getACtx(),now=ctx.currentTime;
    const mkN=d=>{const b=ctx.createBuffer(1,ctx.sampleRate*d,ctx.sampleRate),a=b.getChannelData(0);for(let i=0;i<a.length;i++)a[i]=(Math.random()*2-1)*Math.pow(1-i/a.length,2.5);return b;};
    const t=ctx.createBufferSource();t.buffer=mkN(.04);
    const tf=ctx.createBiquadFilter();tf.type='lowpass';tf.frequency.value=400;
    const tg=ctx.createGain();tg.gain.setValueAtTime(.18,now);tg.gain.exponentialRampToValueAtTime(.001,now+.04);
    t.connect(tf);tf.connect(tg);tg.connect(ctx.destination);t.start(now);
    const s=ctx.createBufferSource();s.buffer=mkN(.025);
    const sf=ctx.createBiquadFilter();sf.type='highpass';sf.frequency.value=3000;
    const sg=ctx.createGain();sg.gain.setValueAtTime(.08,now+.006);sg.gain.exponentialRampToValueAtTime(.001,now+.03);
    s.connect(sf);sf.connect(sg);sg.connect(ctx.destination);s.start(now+.006);
  }catch(e){}
}

/* ─────────────────────────────────────────────────────
   ROUTING
───────────────────────────────────────────────────── */
function showPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  if(id!=='shoot'){
    window.scrollTo(0,0);
    if(window.innerWidth <= 768) document.getElementById('mob-bar').style.display='none';
    // Reset dot to pink when leaving shoot
    if(id==='index') setDotColor('#FF2D78');
    if(id==='about') setDotColor('#FF2D78');
  }
  document.querySelectorAll('.nav-link').forEach(l=>l.classList.remove('cur'));
  if(id==='index'||id==='shoot') document.getElementById('nav-photo').classList.add('cur');
  if(id==='about') document.getElementById('nav-about').classList.add('cur');
}

/* ─────────────────────────────────────────────────────
   FEATURED ROTATOR
───────────────────────────────────────────────────── */
(function(){
  const INTERVAL = 5000;
  const slides   = Array.from(document.querySelectorAll('.fslide'));
  const dots     = Array.from(document.querySelectorAll('.feat-dot'));
  const fill     = document.getElementById('feat-prog-fill');
  const mantra   = document.getElementById('feat-mantra');
  const mWords   = ['mw0','mw1','mw2'].map(id=>document.getElementById(id));
  let slideIdx=0, timer=null, progRaf=null, progStart=null;

  function updateMantra(accent, isLeft){
    // FIX 1: set nav dot to current slide accent
    setDotColor(accent);

    // Active word = slideIdx % 3, outlined in accent color
    const active = slideIdx % 3;
    mWords.forEach((w,i)=>{
      w.style.webkitTextStroke = i===active
        ? `1.5px ${accent}`
        : '1.5px rgba(240,239,235,0.07)';
      i===active ? w.classList.add('m-on') : w.classList.remove('m-on');
    });

    // Mantra sits in opposite margin to title block
    mantra.style.right      = isLeft ? 'auto' : '20px';
    mantra.style.left       = isLeft ? '20px' : 'auto';
    mantra.style.alignItems = isLeft ? 'flex-start' : 'flex-end';
  }

  function startProg(){
    cancelAnimationFrame(progRaf);
    progStart = performance.now();
    (function step(now){
      const pct = Math.min(((now-progStart)/INTERVAL)*100, 100);
      fill.style.width = pct+'%';
      if(pct<100) progRaf = requestAnimationFrame(step);
    })(progStart);
  }

  function goTo(n){
    slides[slideIdx].classList.remove('active'); dots[slideIdx].classList.remove('active');
    slideIdx = ((n%slides.length)+slides.length)%slides.length;
    slides[slideIdx].classList.add('active');   dots[slideIdx].classList.add('active');
    const accent = slides[slideIdx].style.getPropertyValue('--accent').trim()||'#FF2D78';
    const isLeft = slides[slideIdx].classList.contains('l');
    updateMantra(accent, isLeft);
    startProg();
  }

  function startTimer(){ clearInterval(timer); timer=setInterval(()=>goTo(slideIdx+1),INTERVAL); }

  goTo(0); startTimer();
  document.getElementById('feat-prev').onclick = ()=>{ goTo(slideIdx-1); startTimer(); };
  document.getElementById('feat-next').onclick = ()=>{ goTo(slideIdx+1); startTimer(); };
  dots.forEach(d=>d.addEventListener('click',()=>{ goTo(+d.dataset.i); startTimer(); }));
})();

/* ─────────────────────────────────────────────────────
   SHOOT GALLERY
───────────────────────────────────────────────────── */
let shootCleanup = null;

function showShoot(slug){
  const s = SHOOTS[slug]; if(!s) return;
  if(shootCleanup){ shootCleanup(); shootCleanup=null; }

  // FIX 1: update nav dot to this shoot's accent
  setDotColor(s.accent);

  document.getElementById('page-shoot').style.setProperty('--a', s.accent);

  // Photo data
  const photos = s.titles.map((title,i)=>({
    idx:i, src:`https://picsum.photos/seed/${slug}_f${i}/${SEEDS[i%SEEDS.length].w}/${SEEDS[i%SEEDS.length].h}`,
    title, caption:s.captions[i]||'', note:NOTES[i%NOTES.length],
    location:s.location, date:s.date, camera:s.camera, lens:s.lens,
    shutter:SHUT[i%SHUT.length], aperture:APT[i%APT.length], iso:ISO[i%ISO.length],
  }));

  // Template helpers
  const tmpl = s.template;
  const tFS  = tmpl==='editorial'?'clamp(64px,9vw,130px)':tmpl==='documentary'?'clamp(28px,4vw,56px)':'clamp(52px,8vw,120px)';
  const tFam = tmpl==='documentary'?"'IBM Plex Mono',monospace":tmpl==='cinematic'?"'Cormorant Garamond',serif":"'Bebas Neue',sans-serif";
  const tExt = tmpl==='cinematic'?'font-style:italic;font-weight:300;letter-spacing:-2px;line-height:.9':tmpl==='documentary'?'font-weight:500;letter-spacing:-1px;line-height:1.1':'letter-spacing:-1px;line-height:.88';
  const iFam = tmpl==='documentary'?"'IBM Plex Mono',monospace":"'Cormorant Garamond',serif";
  const iSz  = tmpl==='documentary'?'11px':tmpl==='cinematic'?'22px':'20px';
  const iIt  = tmpl!=='documentary'?'font-style:italic':'';
  const tgSt = tmpl==='documentary'?`font-family:'IBM Plex Mono',monospace;font-size:7.5px;letter-spacing:2px;text-transform:uppercase;padding:3px 10px;background:#1A1A1A;color:${s.accent}`:tmpl==='cinematic'?`font-family:'Cormorant Garamond',serif;font-size:12px;font-style:italic;padding:2px 10px;border-bottom:1px solid #282828;color:#505050`:`font-family:'IBM Plex Mono',monospace;font-size:7.5px;letter-spacing:1px;text-transform:uppercase;padding:3px 8px;border:1px solid #282828;color:#505050`;

  /*
    FIX 3: SEEN/FELT/KEPT word highlighted = (s.order-1) % 3
    order:1 → 0 → SEEN highlighted
    order:2 → 1 → FELT highlighted
    order:3 → 2 → KEPT highlighted
    order:4 → 0 → SEEN highlighted (cycles)
  */
  const mantraActive = (s.order - 1) % 3;
  const mantraWords  = ['SEEN','FELT','KEPT'];
  const mantraHTML   = mantraWords.map((w,i)=>`
    <span style="font-family:'Bebas Neue',sans-serif;font-size:clamp(60px,8vw,110px);letter-spacing:-2px;color:transparent;-webkit-text-stroke:1.5px ${i===mantraActive ? s.accent : 'rgba(240,239,235,.07)'};display:block">${w}</span>
  `).join('');

  const photosEl = document.getElementById('sg-photos');

  const titleHTML = `<div class="sg-tile sg-title-tile" data-is-title="1" style="position:relative;overflow:hidden">
    <div style="position:absolute;right:28px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;align-items:flex-end;gap:0;pointer-events:none;z-index:0;line-height:.82">
      ${mantraHTML}
    </div>
    <div style="position:relative;z-index:1;max-width:680px">
      <span style="font-family:'IBM Plex Mono',monospace;font-size:8.5px;letter-spacing:3px;text-transform:uppercase;color:var(--g4);cursor:pointer;margin-bottom:44px;display:inline-block;transition:color .2s"
        onmouseenter="this.style.color='#F0EFEB'" onmouseleave="this.style.color='#505050'"
        onclick="showPage('index')">← Photography</span>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:5px;text-transform:uppercase;color:${s.accent};margin-bottom:20px">${s.location} · ${s.date}</div>
      <h1 style="font-family:${tFam};font-size:${tFS};${tExt};color:#F0EFEB;margin-bottom:28px">${s.title}</h1>
      <p style="font-family:${iFam};font-size:${iSz};${iIt};color:#505050;line-height:1.65;max-width:560px;margin-bottom:28px">${s.intro}</p>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:36px">${s.tags.map(t=>`<span style="${tgSt}">${t}</span>`).join('')}</div>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:8px;letter-spacing:3px;text-transform:uppercase;color:${s.accent};display:flex;align-items:center;gap:12px">
        Scroll to enter
        <span style="display:block;width:1px;height:40px;background:linear-gradient(to bottom,${s.accent},transparent)"></span>
      </div>
    </div>
  </div>`;

  const photoHTML = photos.map((p,i)=>`
  <div class="sg-tile sg-photo-tile${i%2===1?' kb-b':''}"
    data-index="${i}"
    data-title="${encodeURIComponent(p.title)}"
    data-caption="${encodeURIComponent(p.caption)}"
    data-note="${encodeURIComponent(p.note)}"
    data-location="${encodeURIComponent(p.location)}"
    data-date="${encodeURIComponent(p.date)}"
    data-camera="${p.camera}" data-lens="${p.lens}"
    data-shutter="${p.shutter}" data-aperture="${p.aperture}" data-iso="${p.iso}">
    <img src="${p.src}" alt="${p.title}" loading="${i<2?'eager':'lazy'}"/>
  </div>`).join('');

  const endHTML = `<div class="sg-tile" data-is-end="1" style="flex-direction:column">
    <div style="text-align:center">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:8.5px;letter-spacing:5px;text-transform:uppercase;color:#282828;margin-bottom:16px">End of shoot</div>
      <div style="font-family:'Bebas Neue',sans-serif;font-size:clamp(40px,6vw,80px);color:#F0EFEB;line-height:1;margin-bottom:8px">${s.title}</div>
      <div style="font-family:'Cormorant Garamond',serif;font-size:15px;font-style:italic;color:#505050;margin-bottom:44px">${photos.length} frames · ${s.location}</div>
      <div style="display:flex;gap:12px;justify-content:center">
        <button onclick="showPage('index')" style="font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:3px;text-transform:uppercase;padding:12px 22px;background:${s.accent};color:#080808;border:none;cursor:pointer">← All shoots</button>
        <button id="sg-restart" style="font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:3px;text-transform:uppercase;padding:12px 22px;background:transparent;border:1px solid #282828;color:#505050;cursor:pointer">↑ Back to start</button>
      </div>
    </div>
  </div>`;

  photosEl.innerHTML = `<div class="sg-scrollbar"><div class="sg-scrollbar-fill" id="sg-scrollbar-fill" style="height:0%"></div></div>${titleHTML}${photoHTML}${endHTML}`;

  // Panel
  const panel = document.getElementById('sg-panel');
  panel.style.borderLeft = tmpl==='documentary' ? `2px solid ${s.accent}` : '1px solid #1A1A1A';
  const counter = document.getElementById('sg-counter');
  if(tmpl==='editorial')        counter.innerHTML=`<div class="cnt-editorial"><span class="cur">—</span><span class="sep">/</span><span class="tot">${String(photos.length).padStart(2,'0')}</span></div>`;
  else if(tmpl==='documentary') counter.innerHTML=`<div class="cnt-documentary"><span class="cur">—</span><span class="sep">/</span><span class="tot">${String(photos.length).padStart(2,'0')}</span></div>`;
  else                          counter.innerHTML=`<div class="cnt-cinematic"><span class="cur">—</span><span class="sep">/</span><span class="tot">${String(photos.length).padStart(2,'0')}</span></div>`;
  document.getElementById('sg-frame-title').className = `sg-frame-title ft-${tmpl}`;
  document.getElementById('sg-caption').className     = `sg-caption cap-${tmpl}`;
  const acc = document.getElementById('sg-panel-accent');
  if(tmpl==='editorial')        acc.innerHTML=`<div class="panel-accent-line" style="background:${s.accent}"></div>`;
  else if(tmpl==='documentary') acc.innerHTML=`<div class="panel-accent-mono" style="color:${s.accent}">0110 1111 0110 0010</div>`;
  else                          acc.innerHTML=`<div class="panel-accent-dots">${photos.map((_,i)=>`<span class="pdot${i===0?' active':''}" data-i="${i}"></span>`).join('')}</div>`;

  document.getElementById('mob-bar-num').style.color   = s.accent;
  document.getElementById('mob-bar-title').style.color = s.accent;

  // Snap engine
  const allTiles = Array.from(photosEl.querySelectorAll('.sg-tile'));
  const total    = allTiles.length;
  let current=0, snapping=false, accumulated=0;
  const THRESH = 100;

  function restartKB(tile){
    const img = tile.querySelector('img'); if(!img) return;
    img.classList.remove('kb-play'); void img.offsetWidth; img.classList.add('kb-play');
  }

  function positionTiles(idx, animate){
    allTiles.forEach((tile,i)=>{
      tile.style.transition = animate ? 'transform .62s cubic-bezier(.77,0,.18,1),opacity .45s ease' : 'none';
      if(i===idx){
        tile.style.transform='translateY(0)'; tile.style.opacity='1'; tile.style.zIndex='2';
        if(!tile.dataset.isTitle&&!tile.dataset.isEnd) restartKB(tile);
      } else if(i<idx){
        tile.style.transform='translateY(-100%)'; tile.style.opacity='0'; tile.style.zIndex='1';
      } else {
        tile.style.transform='translateY(100%)'; tile.style.opacity='0'; tile.style.zIndex='1';
      }
    });
    const pct = total>1 ? (idx/(total-1))*100 : 0;
    const fillEl = document.getElementById('sg-scrollbar-fill');
    if(fillEl) fillEl.style.height = pct+'%';
    const tile    = allTiles[idx];
    const isPhoto = !tile.dataset.isTitle && !tile.dataset.isEnd;
    document.getElementById('sg-pc').style.opacity      = isPhoto ? '1' : '0.12';
    document.getElementById('sg-counter').style.opacity = isPhoto ? '1' : '0';
    if(isPhoto){
      const d=tile.dataset, n=parseInt(d.index);
      updatePanel(d,n);
      document.getElementById('mob-bar-num').textContent   = String(n+1).padStart(2,'0');
      document.getElementById('mob-bar-title').textContent = decodeURIComponent(d.title);
      // Only show mob-bar on mobile — on desktop it was eating 46px off the bottom of photos
      if(window.innerWidth <= 768) document.getElementById('mob-bar').style.display = 'flex';
    } else {
      if(window.innerWidth <= 768){
        document.getElementById('mob-bar').style.display = tile.dataset.isTitle ? 'none' : 'flex';
      }
      if(tile.dataset.isEnd){
        document.getElementById('mob-bar-num').textContent   = '';
        document.getElementById('mob-bar-title').textContent = 'End of shoot';
      }
    }
  }

  function snapTo(n, animate=true){
    if(snapping) return;
    const next = Math.max(0, Math.min(n, total-1));
    if(next===current){ snapping=false; return; }
    if(!allTiles[next].dataset.isTitle&&!allTiles[next].dataset.isEnd) playShutter();
    snapping=true; current=next;
    positionTiles(current, animate);
    setTimeout(()=>{ snapping=false; }, 700);
  }

  positionTiles(0, false);

  function onWheel(e){ e.preventDefault(); if(snapping)return; accumulated+=e.deltaY; if(accumulated>THRESH){accumulated=0;snapTo(current+1);}else if(accumulated<-THRESH){accumulated=0;snapTo(current-1);} }
  let ty=null;
  function onTS(e){ ty=e.touches[0].clientY; }
  function onTE(e){ if(ty===null)return; const dy=ty-e.changedTouches[0].clientY; if(Math.abs(dy)>55)snapTo(dy>0?current+1:current-1); ty=null; }
  function onKey(e){ if(!document.getElementById('page-shoot').classList.contains('active'))return; if(e.key==='ArrowDown'||e.key==='ArrowRight')snapTo(current+1); if(e.key==='ArrowUp'||e.key==='ArrowLeft')snapTo(current-1); if(e.key==='Escape')showPage('index'); }

  photosEl.addEventListener('wheel',onWheel,{passive:false});
  photosEl.addEventListener('touchstart',onTS,{passive:true});
  photosEl.addEventListener('touchend',onTE,{passive:true});
  window.addEventListener('keydown',onKey);
  document.getElementById('sg-restart')?.addEventListener('click',()=>snapTo(0));

  shootCleanup = ()=>{
    photosEl.removeEventListener('wheel',onWheel);
    photosEl.removeEventListener('touchstart',onTS);
    photosEl.removeEventListener('touchend',onTE);
    window.removeEventListener('keydown',onKey);
  };

  showPage('shoot');
}

function updatePanel(d, n){
  const pc = document.getElementById('sg-pc');
  pc.classList.add('fading');
  setTimeout(()=>{
    const cur = document.querySelector('.cnt-editorial .cur,.cnt-documentary .cur,.cnt-cinematic .cur');
    if(cur) cur.textContent = String(n+1).padStart(2,'0');
    document.getElementById('sg-frame-title').textContent = decodeURIComponent(d.title);
    document.getElementById('sg-caption').textContent     = decodeURIComponent(d.caption);
    document.getElementById('sg-note').textContent        = decodeURIComponent(d.note);
    document.getElementById('sg-location').textContent    = decodeURIComponent(d.location);
    document.getElementById('sg-date').textContent        = decodeURIComponent(d.date);
    document.getElementById('sg-camera').textContent      = d.camera;
    document.getElementById('sg-lens').textContent        = d.lens;
    document.getElementById('sg-shutter').textContent     = d.shutter;
    document.getElementById('sg-aperture').textContent    = d.aperture;
    document.getElementById('sg-iso').textContent         = d.iso;
    document.querySelectorAll('.pdot').forEach((dot,i)=>dot.classList.toggle('active',i===n));
    pc.classList.remove('fading');
  }, 160);
}
</script>

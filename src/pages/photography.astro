---

<PhotographyLayout title="Photography" activePage="photography">
  <section class="feat" id="featured" aria-label="Featured photographs">
    <div class="feat-intro">
      <div class="fi-label">Photography</div>
      <h1 class="fi-h1">
        SEEN<br />
        <span class="fi-oline">FELT</span><br />
        <span class="fi-accent">KEPT</span>
      </h1>
      <p class="fi-sub">Scroll to move through the work.</p>
      <div class="scroll-hint" aria-hidden="true">
        <span></span>
      </div>
    </div>

    {featured.map((photo, i) => (
      <div
        class="fp"
        data-index={i}
        data-accent={photo.accent}
        style={`--accent: ${photo.accent};`}
      >
        <div
          class="fp-bg"
          style={`background-image: url('${photo.demo}');`}
          aria-hidden="true"
        ></div>

        <div class="fp-veil"></div>

        <div class="fp-caption">
          <div class="fp-cap-inner">
            <div class="fp-cap-loc">{photo.location}</div>
            <div class="fp-cap-title">{photo.title}</div>
            <a class="fp-cap-link" href="#shoots">View shoot <span>&rarr;</span></a>
          </div>
        </div>

        <div class="fp-idx" aria-hidden="true">
          {String(i + 1).padStart(2, "0")} / {String(featured.length).padStart(2, "0")}
        </div>
      </div>
    ))}
  </section>

  <section class="shoots" id="shoots">
    <div class="shoots-head">
      <div class="sec-label">Archive</div>
      <div class="sec-title">All Shoots</div>
    </div>

    <div class="shoots-grid">
      {shoots.map((s) => (
        <a class="sc" href="#shoots" style={`--accent: ${s.accent};`}>
          <div class="sc-img-w">
            <img class="sc-img" src={s.cover} alt={s.title} loading="lazy" />
          </div>
          <div class="sc-body">
            <div class="sc-top">
              <span class="sc-date">{s.date}</span>
              <span class="sc-ct">{s.count} frames</span>
            </div>
            <div class="sc-title">{s.title}</div>
            <div class="sc-desc">{s.desc}</div>
            <div class="sc-tags">
              {s.tags.map((t) => (
                <span class="tag">{t}</span>
              ))}
            </div>
            <div class="sc-loc">{s.loc}</div>
          </div>
          <div class="sc-bar"></div>
        </a>
      ))}
    </div>
  </section>

  <footer class="footer">
    <div class="foot-l">SFA</div>
    <div class="foot-r">Copyright 2026. All rights reserved.</div>
  </footer>

  <style>
    .feat {
      position: relative;
    }

    .feat-intro {
      height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 0 40px;
      border-bottom: 1px solid #1a1a1a;
      position: relative;
    }

    .fi-label {
      font-family: "IBM Plex Mono", monospace;
      font-size: 9px;
      letter-spacing: 6px;
      text-transform: uppercase;
      color: #ff2d78;
      margin-bottom: 22px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .fi-label::before {
      content: "";
      display: inline-block;
      width: 32px;
      height: 1px;
      background: #ff2d78;
    }

    .fi-h1 {
      font-family: "Bebas Neue", sans-serif;
      font-size: clamp(80px, 13vw, 168px);
      line-height: 0.88;
      letter-spacing: -1px;
      animation: fadeUp 0.8s ease both;
    }

    .fi-oline {
      -webkit-text-stroke: 1.5px #f0efeb;
      color: transparent;
    }

    .fi-accent {
      color: #ff2d78;
    }

    .fi-sub {
      font-family: "Cormorant Garamond", serif;
      font-size: 16px;
      font-style: italic;
      color: #505050;
      margin-top: 32px;
      animation: fadeUp 0.8s 0.2s ease both;
    }

    .scroll-hint {
      position: absolute;
      bottom: 36px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
    }

    .scroll-hint span {
      display: block;
      width: 1px;
      height: 56px;
      background: linear-gradient(to bottom, #505050, transparent);
      animation: scrollPulse 2s ease infinite;
    }

    @keyframes scrollPulse {
      0%,
      100% {
        opacity: 0.3;
        transform: scaleY(1);
      }
      50% {
        opacity: 1;
        transform: scaleY(1.15);
      }
    }

    .fp {
      position: relative;
      height: 100vh;
      overflow: hidden;
      cursor: crosshair;
    }

    .fp-bg {
      position: absolute;
      inset: -20% 0;
      background-size: cover;
      background-position: center;
      will-change: transform;
      transition: filter 0.4s;
    }

    .fp-veil {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(8, 8, 8, 0.15) 0%,
        rgba(8, 8, 8, 0.05) 40%,
        rgba(8, 8, 8, 0.45) 100%
      );
      transition: background 0.4s;
    }

    .fp-caption {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: flex-end;
      padding: 48px 44px;
      opacity: 0;
      transition: opacity 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .fp:hover .fp-caption {
      opacity: 1;
    }

    .fp:hover .fp-veil {
      background: linear-gradient(
        to bottom,
        rgba(8, 8, 8, 0.2) 0%,
        rgba(8, 8, 8, 0.1) 35%,
        rgba(8, 8, 8, 0.72) 100%
      );
    }

    .fp-cap-inner {
      transform: translateY(10px);
      transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .fp:hover .fp-cap-inner {
      transform: translateY(0);
    }

    .fp-cap-loc {
      font-family: "IBM Plex Mono", monospace;
      font-size: 9px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 8px;
    }

    .fp-cap-title {
      font-family: "Bebas Neue", sans-serif;
      font-size: clamp(42px, 6vw, 80px);
      line-height: 0.9;
      letter-spacing: 1px;
      color: #f0efeb;
      margin-bottom: 20px;
    }

    .fp-cap-link {
      font-family: "IBM Plex Mono", monospace;
      font-size: 9px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #f0efeb;
      border-bottom: 1px solid var(--accent);
      padding-bottom: 2px;
      display: inline-flex;
      gap: 6px;
      transition: color 0.2s;
    }

    .fp-cap-link:hover {
      color: var(--accent);
    }

    .fp-idx {
      position: absolute;
      top: 24px;
      right: 32px;
      font-family: "IBM Plex Mono", monospace;
      font-size: 9px;
      letter-spacing: 3px;
      color: rgba(240, 239, 235, 0.3);
    }

    .fp::after {
      content: "";
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--accent);
      opacity: 0.7;
    }

    .shoots {
      border-top: 1px solid #1a1a1a;
    }

    .shoots-head {
      padding: 64px 40px 40px;
    }

    .shoots-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      padding: 0 0 0 0;
    }

    .sc {
      display: block;
      background: #111;
      overflow: hidden;
      transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      text-decoration: none;
    }

    .sc:hover {
      transform: translateY(-6px);
    }

    .sc-img-w {
      overflow: hidden;
    }

    .sc-img {
      width: 100%;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      filter: brightness(0.85);
      transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94), filter 0.35s;
    }

    .sc:hover .sc-img {
      transform: scale(1.05);
      filter: brightness(1);
    }

    .sc-body {
      padding: 18px 20px 8px;
    }

    .sc-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }

    .sc-date {
      font-family: "IBM Plex Mono", monospace;
      font-size: 8.5px;
      letter-spacing: 2px;
      color: #505050;
    }

    .sc-ct {
      font-family: "IBM Plex Mono", monospace;
      font-size: 7.5px;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 2px 8px;
      color: var(--accent);
      border: 1px solid var(--accent);
    }

    .sc-title {
      font-family: "Bebas Neue", sans-serif;
      font-size: 26px;
      letter-spacing: 1px;
      color: #f0efeb;
      margin-bottom: 7px;
    }

    .sc-desc {
      font-family: "Cormorant Garamond", serif;
      font-size: 13px;
      font-style: italic;
      color: #888;
      margin-bottom: 14px;
      line-height: 1.55;
    }

    .sc-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
      margin-bottom: 12px;
    }

    .sc-loc {
      font-family: "IBM Plex Mono", monospace;
      font-size: 8.5px;
      letter-spacing: 1.5px;
      color: #505050;
      margin-bottom: 18px;
    }

    .sc-bar {
      height: 3px;
      background: var(--accent);
      transition: height 0.25s;
    }

    .sc:hover .sc-bar {
      height: 5px;
    }

    @media (max-width: 900px) {
      .shoots-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 640px) {
      .shoots-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    (function () {
      const panels = document.querySelectorAll(".fp");

      function onScroll() {
        const winH = window.innerHeight;

        panels.forEach((panel) => {
          const rect = panel.getBoundingClientRect();
          if (rect.bottom < -winH || rect.top > winH * 2) return;

          const center = rect.top + rect.height / 2 - winH / 2;
          const progress = center / winH;
          const shift = progress * 40;

          const bg = panel.querySelector(".fp-bg");
          if (bg) bg.style.transform = `translateY(${shift}px)`;
        });
      }

      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    })();
  </script>
</PhotographyLayout>

<div class="page" id="page-about">
  <section class="ab-header">
    <div class="ab-tag">About</div>
    <h1 class="ab-name">BIRKLEY<br><span class="ab-name-oline">FOURIE</span></h1>
    <div class="ab-role">
      <span class="ab-pill" style="color:#FF2D78">South African</span>
      <span style="color:#282828;font-family:'IBM Plex Mono',monospace;font-size:12px">—</span>
      <span class="ab-pill" style="color:#1478FF">Student</span>
      <span style="color:#282828;font-family:'IBM Plex Mono',monospace;font-size:12px">—</span>

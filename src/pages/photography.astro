---
const base = import.meta.env.BASE_URL ?? "/";
const basePath = base.endsWith("/") ? base : `${base}/`;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Photography | Coming Soon</title>
    <meta name="description" content="Photography is coming soon to Stories From Abroad." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #060606;
        --text: #f4efe5;
        --line: rgba(244, 239, 229, 0.16);
        --accent: #ff5a00;
        --accent2: #ff2d78;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; }
      body {
        background:
          radial-gradient(circle at 16% 14%, rgba(255, 45, 120, 0.14), transparent 35rem),
          radial-gradient(circle at 86% 84%, rgba(255, 90, 0, 0.14), transparent 34rem),
          var(--bg);
        color: var(--text);
        font-family: "Space Mono", monospace;
      }

      .topbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 10;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.4rem;
        border-bottom: 1px solid var(--line);
        background: rgba(6, 6, 6, 0.9);
        backdrop-filter: blur(10px);
      }

      .topbar a {
        color: inherit;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 0.72rem;
      }

      .topbar strong {
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.3rem;
        letter-spacing: 0.2em;
      }

      .shell {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 6rem 1.4rem 2rem;
      }

      .card {
        width: min(40rem, 100%);
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.02);
        padding: 1.4rem;
      }

      .kicker {
        margin: 0;
        color: var(--accent2);
        text-transform: uppercase;
        letter-spacing: 0.28em;
        font-size: 0.7rem;
      }

      h1 {
        margin: 0.75rem 0 0;
        font-family: "Bebas Neue", sans-serif;
        font-size: clamp(2.4rem, 10vw, 5.3rem);
        letter-spacing: 0.05em;
        line-height: 0.92;
      }

      p {
        margin: 0.8rem 0 0;
        color: rgba(244, 239, 229, 0.74);
        line-height: 1.7;
      }

      .bar {
        margin-top: 1.1rem;
        height: 2px;
        background: linear-gradient(90deg, var(--accent2), var(--accent));
      }
    </style>
  </head>
  <body>
    <header class="topbar">
      <a href={`${basePath}`}>Back Home</a>
      <strong>SFA</strong>
    </header>

    <main class="shell">
      <section class="card">
        <p class="kicker">Photography</p>
        <h1>Coming Soon</h1>
        <p>
          The new photography experience is in progress. Check back soon for the full launch.
        </p>
        <div class="bar"></div>
      </section>
    </main>
  </body>
</html>

---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Travel Stories" description="Writing from the road, honest accounts of getting somewhere.">
  <section class="page-header">
    <span class="section-label">Field Notes</span>
    <h1>Travel Stories</h1>
    <p>Writing from the road &mdash; honest accounts of getting somewhere.</p>
  </section>

  <section class="travel-wrap">
    <div class="container-wide">
      <div class="travel-feed" id="travel-feed"></div>
    </div>
  </section>

  <script type="module">
    import { collection, getDocs } from "firebase/firestore";
    import { db, firestoreReady } from "../lib/firebaseClient";
    import { fallbackTravel } from "../lib/fallbackData";

    const feed = document.getElementById("travel-feed");

    function normalizeTravel(p, idx) {
      return {
        id: p.id ?? `travel-${idx}`,
        month: p.month ?? "",
        year: Number(p.year) || new Date().getFullYear(),
        location: p.location ?? "",
        title: p.title ?? "Untitled",
        excerpt: p.excerpt ?? "",
        image: p.image ?? "",
        hasPhoto: Boolean(p.hasPhoto),
      };
    }

    async function loadTravel() {
      if (!firestoreReady || !db) {
        return fallbackTravel.map(normalizeTravel);
      }
      try {
        const snap = await getDocs(collection(db, "travel"));
        const data = snap.docs.map((doc, idx) => normalizeTravel({ id: doc.id, ...doc.data() }, idx));
        return data.length ? data : fallbackTravel.map(normalizeTravel);
      } catch (err) {
        console.warn("Firestore unavailable, using fallback.", err);
        return fallbackTravel.map(normalizeTravel);
      }
    }

    function renderTravel(items) {
      feed.innerHTML = items
        .map((entry) => {
          const thumbStyle = entry.image
            ? `background-image:url('${entry.image}');`
            : "";
          const thumb = entry.hasPhoto || entry.image
            ? `<div class=\"travel-thumb\" style=\"${thumbStyle}\">&#9675;</div>`
            : "";
          return `
            <article class="travel-entry">
              <div class="travel-date-col">
                <span class="month">${entry.month}</span>
                <span class="year">${entry.year}</span>
              </div>
              <div class="travel-entry-body">
                <div class="travel-location">&#9671; ${entry.location}</div>
                <h2>${entry.title}</h2>
                <p>${entry.excerpt}</p>
                ${thumb}
              </div>
            </article>
          `;
        })
        .join("");
    }

    loadTravel().then(renderTravel);
  </script>

  <style>
    .travel-wrap {
      padding: 3rem 0 6rem;
    }

    .travel-feed {
      display: flex;
      flex-direction: column;
      gap: 28px;
    }

    .travel-entry {
      display: grid;
      grid-template-columns: 90px 1fr;
      gap: 32px;
      padding: 28px 24px;
      background: var(--bg-warm);
      border: 1px solid var(--rule);
      transition: border-color 0.3s ease, transform 0.3s ease;
    }

    .travel-entry:hover {
      border-color: var(--green);
      transform: translateY(-4px);
    }

    .travel-date-col {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-family: var(--font-sc);
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: var(--text-muted);
      font-size: 0.7rem;
    }

    .travel-date-col .month {
      font-size: 1rem;
      color: var(--green);
    }

    .travel-entry-body h2 {
      font-family: var(--font-title);
      font-size: 1.6rem;
      margin-bottom: 8px;
    }

    .travel-entry-body p {
      color: var(--text-mid);
      font-size: 1rem;
      margin-bottom: 12px;
    }

    .travel-location {
      font-family: var(--font-sc);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: var(--text-muted);
      margin-bottom: 10px;
    }

    .travel-thumb {
      width: 120px;
      height: 120px;
      border-radius: 60px;
      background: var(--bg-dark);
      display: grid;
      place-items: center;
      color: rgba(255, 255, 255, 0.6);
      background-size: cover;
      background-position: center;
      margin-top: 12px;
    }

    @media (max-width: 900px) {
      .travel-entry {
        grid-template-columns: 1fr;
      }

      .travel-date-col {
        flex-direction: row;
        gap: 12px;
        justify-content: flex-start;
      }
    }
  </style>
</BaseLayout>

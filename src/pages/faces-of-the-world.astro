async function buildMap() {
  const cachedWorld = readCacheEntry(CACHE_KEYS.worldAtlas, CACHE_TTL_MS.worldAtlas);
  if (cachedWorld?.objects?.countries) {
    worldData = cachedWorld;
    renderMapFromWorldData();
    return;
  }

  try {
    worldData = await fetchWorldAtlasData();
    writeCacheEntry(CACHE_KEYS.worldAtlas, worldData);
    renderMapFromWorldData();
  } catch(e) {
    document.getElementById('map-loading').textContent = 'Map unavailable.';
    console.error(e);
  }
}

async function fetchWorldAtlasData() {
  let lastError = null;
  for (const url of WORLD_ATLAS_URLS) {
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), MAP_FETCH_TIMEOUT_MS);
    try {
      const response = await fetch(url, { cache: 'force-cache', signal: controller.signal });
      if (!response.ok) throw new Error('World map request failed: ' + response.status + ' (' + url + ')');
      return response.json();
    } catch (error) {
      lastError = error;
    } finally {
      clearTimeout(timeout);
    }
  }
  throw lastError || new Error('World map request failed.');
}


---
import "../styles/global.css";
import { siteCopy } from "../content/siteCopy";

const copy = siteCopy.global;

const {
  title = copy.siteTitle,
  description = copy.defaultDescription,
  bodyClass = "",
  navMode = "home",
  navLabel = "",
  showSubscribe = true,
} = Astro.props;

const base = import.meta.env.BASE_URL ?? "/";
const basePath = base.endsWith("/") ? base : `${base}/`;
const currentPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

const navItems = copy.nav.items.map((item) => {
  const path = item.path ? `${item.path}/` : "";
  return {
    label: item.label,
    href: `${basePath}${path}`,
    route: `/${path}`,
  };
});

const currentRoute = currentPath.startsWith(basePath)
  ? `/${currentPath.slice(basePath.length)}`.replace(/\/+/g, "/")
  : currentPath;

const pageTitle = title ? `${title} | ${copy.siteTitle}` : copy.siteTitle;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Cormorant+SC:wght@300;400;500&family=Cormorant:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Lora:ital,wght@0,400;0,500;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={bodyClass}>
    <header class="site-nav" id="site-nav">
      {navMode === "single" ? (
        <>
          <a class="nav-back" href={basePath}>{copy.nav.backLabel}</a>
          <div class="nav-single-right">
            <span class="nav-single-label">{navLabel || copy.nav.items[0]?.label}</span>
            {showSubscribe ? (
              <button class="nav-cta" type="button" data-modal-open="subscribe">{copy.nav.cta}</button>
            ) : null}
          </div>
        </>
      ) : (
        <>
          <a class="nav-wordmark" href={basePath}>{copy.nav.wordmark}</a>
          <nav>
            <ul class="nav-links">
              {navItems.map((item) => (
                <li>
                  <a href={item.href} class={currentRoute === item.route ? "active" : ""}>
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
          {showSubscribe ? (
            <button class="nav-cta" type="button" data-modal-open="subscribe">{copy.nav.cta}</button>
          ) : null}
        </>
      )}
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span class="footer-wordmark">{copy.footer.wordmark}</span>
      {navMode === "home" ? (
        <div class="footer-links">
          {copy.footer.homeLinks.map((link) => (
            <a href={`${basePath}${link.path ? `${link.path}/` : ""}`}>{link.label}</a>
          ))}
        </div>
      ) : null}
      <hr />
      <p class="footer-copy">{copy.footer.copyright}</p>
    </footer>

    <div class="modal-overlay" id="subscribe-modal" data-modal="subscribe">
      <div class="modal">
        <button class="modal-close" type="button" data-modal-close>{copy.subscribeModal.closeLabel}</button>
        <div id="modal-form-view">
          <div class="modal-ornament"></div>
          <h2 class="modal-title">{copy.subscribeModal.title}</h2>
          <p class="modal-sub">{copy.subscribeModal.subtitle}</p>
          <div class="form-group">
            <label class="form-label" for="sub-email">{copy.subscribeModal.emailLabel}</label>
            <input type="email" class="form-input" id="sub-email" placeholder={copy.subscribeModal.emailPlaceholder} />
          </div>
          <div class="form-group">
            <label class="form-label" for="sub-name">{copy.subscribeModal.nameLabel}</label>
            <input type="text" class="form-input" id="sub-name" placeholder={copy.subscribeModal.namePlaceholder} />
          </div>
          <span class="pref-label">{copy.subscribeModal.preferenceLabel}</span>
          <div class="checkboxes">
            <label class="checkbox-row">
              <input type="checkbox" id="pref-all" checked /> <span>{copy.subscribeModal.checkboxes[0]}</span>
            </label>
            <label class="checkbox-row">
              <input type="checkbox" id="pref-articles" /> <span>{copy.subscribeModal.checkboxes[1]}</span>
            </label>
            <label class="checkbox-row">
              <input type="checkbox" id="pref-photo" /> <span>{copy.subscribeModal.checkboxes[2]}</span>
            </label>
            <label class="checkbox-row">
              <input type="checkbox" id="pref-faces" /> <span>{copy.subscribeModal.checkboxes[3]}</span>
            </label>
            <label class="checkbox-row">
              <input type="checkbox" id="pref-travel" /> <span>{copy.subscribeModal.checkboxes[4]}</span>
            </label>
          </div>
          <button class="btn-ghost modal-submit" type="button" id="modal-submit">
            {copy.subscribeModal.submitLabel}
          </button>
          <p class="modal-status" id="modal-status" aria-live="polite"></p>
        </div>
        <div class="modal-success" id="modal-success-view">
          <div class="modal-check">{copy.subscribeModal.success.title}</div>
          <h3 id="modal-success-title">{copy.subscribeModal.success.subtitle}</h3>
          <p id="modal-success-body">{copy.subscribeModal.success.body}</p>
        </div>
      </div>
    </div>

    <script type="module">
      import { firestoreReady } from "../lib/firebaseClient";
      import {
        completeSubscriberSignInFromLink,
        fallbackNameFromEmail,
        getSubscriberRecord,
        normalizeEmail,
        onSubscriberAuthChange,
        sendSubscriberSignInLink,
        upsertSubscriberRecord,
      } from "../lib/subscriberClient";

      const nav = document.getElementById("site-nav");
      if (nav) {
        const onScroll = () => {
          nav.classList.toggle("scrolled", window.scrollY > 30);
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      }

      const modal = document.getElementById("subscribe-modal");
      const modalSubmit = document.getElementById("modal-submit");
      const formView = document.getElementById("modal-form-view");
      const successView = document.getElementById("modal-success-view");
      const statusEl = document.getElementById("modal-status");
      const emailInput = document.getElementById("sub-email");
      const nameInput = document.getElementById("sub-name");
      const successTitle = document.getElementById("modal-success-title");
      const successBody = document.getElementById("modal-success-body");
      const prefAll = document.getElementById("pref-all");
      const prefArticles = document.getElementById("pref-articles");
      const prefPhoto = document.getElementById("pref-photo");
      const prefFaces = document.getElementById("pref-faces");
      const prefTravel = document.getElementById("pref-travel");

      let authUser = null;

      function setStatus(message, tone = "muted") {
        if (!statusEl) return;
        statusEl.textContent = message;
        if (tone === "error") {
          statusEl.style.color = "var(--red)";
        } else if (tone === "ok") {
          statusEl.style.color = "var(--green)";
        } else {
          statusEl.style.color = "var(--text-muted)";
        }
      }

      function collectPreferences() {
        const out = [];
        if (prefAll?.checked) out.push("all");
        if (prefArticles?.checked) out.push("articles");
        if (prefPhoto?.checked) out.push("photography");
        if (prefFaces?.checked) out.push("faces");
        if (prefTravel?.checked) out.push("travel");
        return out;
      }

      function showSuccess(title, body) {
        if (successTitle) successTitle.textContent = title;
        if (successBody) successBody.textContent = body;
        if (formView && successView) {
          formView.style.display = "none";
          successView.style.display = "block";
        }
      }

      function openModal() {
        if (!modal) return;
        modal.classList.add("open");
        document.body.style.overflow = "hidden";
        setStatus("");
        if (emailInput) emailInput.classList.remove("input-error");
      }

      function closeModal() {
        if (!modal) return;
        modal.classList.remove("open");
        document.body.style.overflow = "";
        if (formView && successView) {
          formView.style.display = "";
          successView.style.display = "none";
        }
        setStatus("");
      }

      document.querySelectorAll("[data-modal-open='subscribe']").forEach((btn) => {
        btn.addEventListener("click", openModal);
      });

      if (modal) {
        modal.addEventListener("click", (event) => {
          if (event.target === modal) closeModal();
        });
      }

      document.querySelectorAll("[data-modal-close]").forEach((btn) => {
        btn.addEventListener("click", closeModal);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeModal();
      });

      if (prefAll) {
        prefAll.addEventListener("change", () => {
          const checked = prefAll.checked;
          [prefArticles, prefPhoto, prefFaces, prefTravel].forEach((el) => {
            if (!el) return;
            el.checked = false;
            el.disabled = checked;
          });
        });
      }

      if (prefAll?.checked) {
        [prefArticles, prefPhoto, prefFaces, prefTravel].forEach((el) => {
          if (!el) return;
          el.disabled = true;
        });
      }

      [prefArticles, prefPhoto, prefFaces, prefTravel].forEach((el) => {
        if (!el) return;
        el.addEventListener("change", () => {
          if (!prefAll) return;
          if (el.checked) prefAll.checked = false;
          const lock = prefAll.checked;
          [prefArticles, prefPhoto, prefFaces, prefTravel].forEach((item) => {
            if (!item) return;
            item.disabled = lock;
          });
        });
      });

      if (nameInput && !nameInput.value && authUser?.email) {
        nameInput.value = fallbackNameFromEmail(authUser.email);
      }

      onSubscriberAuthChange(async (user) => {
        authUser = user;
        if (!user?.uid || !nameInput) return;
        const profile = await getSubscriberRecord(user.uid);
        const preferredName = profile?.name || fallbackNameFromEmail(user.email || "");
        if (preferredName && !nameInput.value.trim()) {
          nameInput.value = preferredName;
        }
      });

      completeSubscriberSignInFromLink()
        .then(async ({ completed, user }) => {
          if (!completed || !user?.uid) return;
          const profile = await getSubscriberRecord(user.uid);
          const title = profile?.name ? "Subscription received" : "Subscription confirmed";
          showSuccess(title, "Your subscriber account is active and ready for comments.");
        })
        .catch(() => {
          // Ignore silent auth-completion errors in global layout.
        });

      if (modalSubmit) {
        modalSubmit.addEventListener("click", async () => {
          if (!(emailInput instanceof HTMLInputElement)) return;
          const normalizedEmail = normalizeEmail(emailInput.value);
          if (!normalizedEmail.includes("@")) {
            emailInput.focus();
            emailInput.classList.add("input-error");
            setStatus("Please enter a valid email.", "error");
            return;
          }

          emailInput.classList.remove("input-error");
          setStatus("");

          if (!firestoreReady) {
            setStatus("Subscriber services are not configured yet.", "error");
            return;
          }

          const name = nameInput instanceof HTMLInputElement ? nameInput.value : "";
          const preferences = collectPreferences();

          if (modalSubmit instanceof HTMLButtonElement) {
            modalSubmit.disabled = true;
          }

          try {
            if (authUser?.uid && normalizeEmail(authUser.email) === normalizedEmail) {
              await upsertSubscriberRecord(authUser, {
                name,
                preferences,
                source: "global_modal",
              });
              showSuccess("Subscription confirmed", "Your subscriber account is active.");
              return;
            }

            const result = await sendSubscriberSignInLink({
              email: normalizedEmail,
              name,
              preferences,
              source: "global_modal",
              redirectUrl: window.location.href,
            });

            if (!result.ok) {
              setStatus("Unable to send sign-in link. Please try again.", "error");
              return;
            }

            if (result.linked) {
              showSuccess("Subscription confirmed", "Your subscriber account is active.");
              return;
            }

            showSuccess("Check your inbox", "Use the sign-in link to confirm your subscription.");
          } catch (error) {
            setStatus("Subscription failed. Please retry in a moment.", "error");
          } finally {
            if (modalSubmit instanceof HTMLButtonElement) {
              modalSubmit.disabled = false;
            }
          }
        });
      }
    </script>
  </body>
</html>

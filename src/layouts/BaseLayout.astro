---
import "../styles/global.css";

const {
  title = "Stories From Abroad",
  description = "Essays, images, and fiction from somewhere else.",
  bodyClass = "",
} = Astro.props;

const base = import.meta.env.BASE_URL ?? "/";
const basePath = base.endsWith("/") ? base : `${base}/`;
const currentPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

const navItems = [
  { label: "About", href: `${basePath}read-the-story/`, route: "/read-the-story/" },
  { label: "Articles", href: `${basePath}selected-papers/`, route: "/selected-papers/" },
  { label: "Photography", href: `${basePath}photography/`, route: "/photography/" },
  { label: "Faces", href: `${basePath}faces-of-the-world/`, route: "/faces-of-the-world/" },
  { label: "Travel", href: `${basePath}travel-stories/`, route: "/travel-stories/" },
];

const currentRoute = currentPath.startsWith(basePath)
  ? `/${currentPath.slice(basePath.length)}`.replace(/\/+/g, "/")
  : currentPath;

const pageTitle = title ? `${title} | Stories From Abroad` : "Stories From Abroad";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Cormorant+SC:wght@300;400;500&family=Cormorant:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Lora:ital,wght@0,400;0,500;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={bodyClass}>
    <header class="site-nav" id="site-nav">
      <a class="nav-wordmark" href={basePath}>SFA</a>
      <nav>
        <ul class="nav-links">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class={currentRoute === item.route ? "active" : ""}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <button class="nav-cta" type="button" data-modal-open="subscribe">Subscribe</button>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span class="footer-wordmark">Stories From Abroad</span>
      <div class="footer-links">
        <a href={basePath}>Home</a>
        <a href={`${basePath}selected-papers/`}>Selected Papers</a>
        <a href={`${basePath}photography/`}>Photography</a>
      </div>
      <hr />
      <p class="footer-copy">&copy; 2026 Stories From Abroad. All rights reserved.</p>
    </footer>

    <div class="modal-overlay" id="subscribe-modal" data-modal="subscribe">
      <div class="modal">
        <button class="modal-close" type="button" data-modal-close>Close</button>
        <div id="modal-form-view">
          <div class="modal-ornament"></div>
          <h2 class="modal-title">Subscribe to Dispatches</h2>
          <p class="modal-sub">
            No algorithms. No advertising. Just writing, when it is ready.
          </p>
          <div class="form-group">
            <label class="form-label" for="sub-email">Email Address *</label>
            <input type="email" class="form-input" id="sub-email" placeholder="your@email.com" />
          </div>
          <div class="form-group">
            <label class="form-label" for="sub-name">Name (Optional)</label>
            <input type="text" class="form-input" id="sub-name" placeholder="How shall I address you?" />
          </div>
          <span class="pref-label">I am interested in</span>
          <div class="checkboxes">
            <label class="checkbox-row"><input type="checkbox" id="pref-all" checked /> <span>All updates</span></label>
            <label class="checkbox-row"><input type="checkbox" id="pref-articles" /> <span>Articles and Op-Eds</span></label>
            <label class="checkbox-row"><input type="checkbox" id="pref-photo" /> <span>Photography</span></label>
            <label class="checkbox-row"><input type="checkbox" id="pref-faces" /> <span>Faces of the World</span></label>
            <label class="checkbox-row"><input type="checkbox" id="pref-travel" /> <span>Travel</span></label>
          </div>
          <button class="btn-ghost modal-submit" type="button" id="modal-submit">
            Subscribe to the Letter
          </button>
        </div>
        <div class="modal-success" id="modal-success-view">
          <div class="modal-check">Welcome</div>
          <h3>Subscription received</h3>
          <p>A confirmation email is on its way.</p>
        </div>
      </div>
    </div>

    <script is:inline>
      const nav = document.getElementById("site-nav");
      if (nav) {
        const onScroll = () => {
          nav.classList.toggle("scrolled", window.scrollY > 30);
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      }

      const modal = document.getElementById("subscribe-modal");
      const modalSubmit = document.getElementById("modal-submit");
      const formView = document.getElementById("modal-form-view");
      const successView = document.getElementById("modal-success-view");

      function openModal() {
        if (!modal) return;
        modal.classList.add("open");
        document.body.style.overflow = "hidden";
      }

      function closeModal() {
        if (!modal) return;
        modal.classList.remove("open");
        document.body.style.overflow = "";
        if (formView && successView) {
          formView.style.display = "";
          successView.style.display = "none";
        }
      }

      document.querySelectorAll("[data-modal-open='subscribe']").forEach((btn) => {
        btn.addEventListener("click", openModal);
      });

      if (modal) {
        modal.addEventListener("click", (event) => {
          if (event.target === modal) closeModal();
        });
      }

      document.querySelectorAll("[data-modal-close]").forEach((btn) => {
        btn.addEventListener("click", closeModal);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeModal();
      });

      if (modalSubmit) {
        modalSubmit.addEventListener("click", () => {
          const email = document.getElementById("sub-email");
          if (email && !email.value.includes("@")) {
            email.focus();
            email.classList.add("input-error");
            return;
          }
          if (formView && successView) {
            formView.style.display = "none";
            successView.style.display = "block";
          }
        });
      }
    </script>
  </body>
</html>

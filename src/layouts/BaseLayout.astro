---
import "../styles/global.css";
import { siteCopy } from "../content/siteCopy";

const copy = siteCopy.global;

const {
  title = copy.siteTitle,
  description = copy.defaultDescription,
  bodyClass = "",
  navMode = "home",
  navLabel = "",
  showSubscribe = true,
} = Astro.props;

const base = import.meta.env.BASE_URL ?? "/";
const basePath = base.endsWith("/") ? base : `${base}/`;
const currentPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

const navItems = copy.nav.items.map((item) => {
  const path = item.path ? `${item.path}/` : "";
  return {
    label: item.label,
    href: `${basePath}${path}`,
    route: `/${path}`,
  };
});

const currentRoute = currentPath.startsWith(basePath)
  ? `/${currentPath.slice(basePath.length)}`.replace(/\/+/g, "/")
  : currentPath;

const pageTitle = title ? `${title} | ${copy.siteTitle}` : copy.siteTitle;
const publicFirebaseConfigJson = JSON.stringify({
  apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY ?? "",
  authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN ?? "",
  projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID ?? "",
  appId: import.meta.env.PUBLIC_FIREBASE_APP_ID ?? "",
});
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Cormorant+SC:wght@300;400;500&family=Cormorant:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Lora:ital,wght@0,400;0,500;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={bodyClass}>
    <header class="site-nav" id="site-nav">
      {navMode === "single" ? (
        <>
          <a class="nav-back" href={basePath}>{copy.nav.backLabel}</a>
          <div class="nav-single-right">
            <span class="nav-single-label">{navLabel || copy.nav.items[0]?.label}</span>
            {showSubscribe ? (
              <button class="nav-cta" type="button" data-modal-open="subscribe">{copy.nav.cta}</button>
            ) : null}
          </div>
        </>
      ) : (
        <>
          <a class="nav-wordmark" href={basePath}>{copy.nav.wordmark}</a>
          <nav>
            <ul class="nav-links">
              {navItems.map((item) => (
                <li>
                  <a href={item.href} class={currentRoute === item.route ? "active" : ""}>
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
          {showSubscribe ? (
            <button class="nav-cta" type="button" data-modal-open="subscribe">{copy.nav.cta}</button>
          ) : null}
        </>
      )}
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span class="footer-wordmark">{copy.footer.wordmark}</span>
      {navMode === "home" ? (
        <div class="footer-links">
          {copy.footer.homeLinks.map((link) => (
            <a href={`${basePath}${link.path ? `${link.path}/` : ""}`}>{link.label}</a>
          ))}
        </div>
      ) : null}
      <hr />
      <p class="footer-copy">{copy.footer.copyright}</p>
    </footer>

    <div class="modal-overlay" id="subscribe-modal" data-modal="subscribe">
      <div class="modal">
        <div class="modal-scroll">
          <button class="modal-close" type="button" data-modal-close><span aria-hidden="true">×</span>{copy.subscribeModal.closeLabel}</button>
          <div id="modal-form-view">
            <div class="modal-topline">
              <span></span>
              <strong>&amp;</strong>
              <span></span>
            </div>
            <h2 class="modal-title">
              <span>Subscribe to</span>
              <em>Dispatches</em>
            </h2>
            <p class="modal-sub">{copy.subscribeModal.subtitle}</p>
            <div class="form-group">
              <label class="form-label" for="sub-email">{copy.subscribeModal.emailLabel}</label>
              <input type="email" class="form-input" id="sub-email" placeholder={copy.subscribeModal.emailPlaceholder} />
            </div>
            <div class="form-group">
              <label class="form-label" for="sub-name">{copy.subscribeModal.nameLabel}</label>
              <input type="text" class="form-input" id="sub-name" placeholder={copy.subscribeModal.namePlaceholder} />
            </div>
            <span class="pref-label">{copy.subscribeModal.preferenceLabel}</span>
            <div class="checkboxes">
              <label class="checkbox-row">
                <input type="checkbox" id="pref-all" checked /> <span>{copy.subscribeModal.checkboxes[0]}</span>
              </label>
              <label class="checkbox-row">
                <input type="checkbox" id="pref-articles" /> <span>{copy.subscribeModal.checkboxes[1]}</span>
              </label>
              <label class="checkbox-row">
                <input type="checkbox" id="pref-photo" /> <span>{copy.subscribeModal.checkboxes[2]}</span>
              </label>
              <label class="checkbox-row">
                <input type="checkbox" id="pref-faces" /> <span>{copy.subscribeModal.checkboxes[3]}</span>
              </label>
              <label class="checkbox-row">
                <input type="checkbox" id="pref-travel" /> <span>{copy.subscribeModal.checkboxes[4]}</span>
              </label>
            </div>
            <button class="btn-ghost modal-submit" type="button" id="modal-submit">
              {copy.subscribeModal.submitLabel}
            </button>
            <p class="modal-status" id="modal-status" aria-live="polite"></p>
          </div>
          <div class="modal-success" id="modal-success-view">
            <div class="modal-check">{copy.subscribeModal.success.title}</div>
            <h3 id="modal-success-title">{copy.subscribeModal.success.subtitle}</h3>
            <p id="modal-success-body">{copy.subscribeModal.success.body}</p>
          </div>
        </div>
      </div>
    </div>

    <script id="public-firebase-config" type="application/json" set:html={publicFirebaseConfigJson}></script>
    <script type="module">
      import { initializeApp, getApps, getApp } from "https://www.gstatic.com/firebasejs/11.10.0/firebase-app.js";
      import {
        browserLocalPersistence,
        getAuth,
        isSignInWithEmailLink,
        onAuthStateChanged,
        sendSignInLinkToEmail,
        setPersistence,
        signInWithEmailLink,
      } from "https://www.gstatic.com/firebasejs/11.10.0/firebase-auth.js";
      import { doc, getDoc, getFirestore, serverTimestamp, setDoc } from "https://www.gstatic.com/firebasejs/11.10.0/firebase-firestore.js";

      const nav = document.getElementById("site-nav");
      if (nav) {
        const onScroll = () => {
          nav.classList.toggle("scrolled", window.scrollY > 30);
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      }

      const modal = document.getElementById("subscribe-modal");
      const modalSubmit = document.getElementById("modal-submit");
      const formView = document.getElementById("modal-form-view");
      const successView = document.getElementById("modal-success-view");
      const statusEl = document.getElementById("modal-status");
      const emailInput = document.getElementById("sub-email");
      const nameInput = document.getElementById("sub-name");
      const successTitle = document.getElementById("modal-success-title");
      const successBody = document.getElementById("modal-success-body");
      const prefAll = document.getElementById("pref-all");
      const prefArticles = document.getElementById("pref-articles");
      const prefPhoto = document.getElementById("pref-photo");
      const prefFaces = document.getElementById("pref-faces");
      const prefTravel = document.getElementById("pref-travel");
      const configEl = document.getElementById("public-firebase-config");

      let firebaseConfig = {};
      try {
        firebaseConfig = JSON.parse(configEl?.textContent || "{}");
      } catch (error) {
        firebaseConfig = {};
      }

      const firebaseReady = Boolean(firebaseConfig.apiKey && firebaseConfig.authDomain && firebaseConfig.projectId && firebaseConfig.appId);
      const firebaseApp = firebaseReady ? (getApps().length ? getApp() : initializeApp(firebaseConfig)) : null;
      const auth = firebaseApp ? getAuth(firebaseApp) : null;
      const db = firebaseApp ? getFirestore(firebaseApp) : null;
      const pendingKey = "sfa-pending-subscriber-v2";

      let authUser = null;

      if (auth) {
        setPersistence(auth, browserLocalPersistence).catch(() => undefined);
      }

      function normalizeString(value) {
        return String(value ?? "").trim();
      }

      function normalizeEmail(value) {
        return normalizeString(value).toLowerCase();
      }

      function fallbackNameFromEmail(email) {
        const local = normalizeEmail(email).split("@")[0] || "";
        if (!local) return "Subscriber";
        return local.replace(/[._-]+/g, " ").replace(/\s+/g, " ").trim().slice(0, 80);
      }

      function collectPreferences() {
        const out = [];
        if (prefAll?.checked) out.push("all");
        if (prefArticles?.checked) out.push("articles");
        if (prefPhoto?.checked) out.push("photography");
        if (prefFaces?.checked) out.push("faces");
        if (prefTravel?.checked) out.push("travel");
        return out;
      }

      function flagsFromPreferences(preferences) {
        const set = new Set(Array.isArray(preferences) ? preferences : []);
        return {
          wantsAllUpdates: set.has("all"),
          wantsPapers: set.has("articles") || set.has("papers"),
          wantsPhotography: set.has("photography"),
          wantsFaces: set.has("faces") || set.has("stories"),
          wantsTravel: set.has("travel"),
        };
      }

      function writePendingSubscriber(next) {
        try {
          window.localStorage.setItem(pendingKey, JSON.stringify(next));
        } catch (error) {}
      }

      function readPendingSubscriber() {
        try {
          return JSON.parse(window.localStorage.getItem(pendingKey) || "null");
        } catch (error) {
          return null;
        }
      }

      function clearPendingSubscriber() {
        try {
          window.localStorage.removeItem(pendingKey);
        } catch (error) {}
      }

      async function getSubscriberRecord(uid) {
        if (!db || !uid) return null;
        try {
          const snap = await getDoc(doc(db, "subscribers", uid));
          return snap.exists() ? snap.data() : null;
        } catch (error) {
          return null;
        }
      }

      async function upsertSubscriberRecord(user, options = {}) {
        if (!db || !user?.uid || !user?.email) return null;
        const existing = await getSubscriberRecord(user.uid);
        const preferences = Array.isArray(options.preferences) && options.preferences.length
          ? options.preferences
          : Array.isArray(existing?.preferences)
            ? existing.preferences
            : [];
        const flags = flagsFromPreferences(preferences);
        const payload = {
          email: user.email,
          emailLower: normalizeEmail(user.email),
          name: normalizeString(options.name) || normalizeString(existing?.name) || fallbackNameFromEmail(user.email),
          verified: true,
          status: "active",
          preferences,
          wantsAllUpdates: flags.wantsAllUpdates,
          wantsPapers: flags.wantsPapers,
          wantsPhotography: flags.wantsPhotography,
          wantsFaces: flags.wantsFaces,
          wantsTravel: flags.wantsTravel,
          source: normalizeString(options.source) || normalizeString(existing?.source) || "global_modal",
          updatedAt: serverTimestamp(),
        };
        if (!existing) payload.createdAt = serverTimestamp();
        await setDoc(doc(db, "subscribers", user.uid), payload, { merge: true });
        return payload;
      }

      function setStatus(message, tone = "muted") {
        if (!statusEl) return;
        statusEl.textContent = message;
        if (tone === "error") {
          statusEl.style.color = "var(--red)";
        } else if (tone === "ok") {
          statusEl.style.color = "var(--green)";
        } else {
          statusEl.style.color = "var(--text-muted)";
        }
      }

      function showSuccess(title, body) {
        if (successTitle) successTitle.textContent = title;
        if (successBody) successBody.textContent = body;
        if (formView && successView) {
          formView.style.display = "none";
          successView.style.display = "block";
        }
      }

      function openModal() {
        if (!modal) return;
        modal.classList.add("open");
        document.body.style.overflow = "hidden";
        setStatus("");
        if (emailInput) emailInput.classList.remove("input-error");
      }

      function closeModal() {
        if (!modal) return;
        modal.classList.remove("open");
        document.body.style.overflow = "";
        if (formView && successView) {
          formView.style.display = "";
          successView.style.display = "none";
        }
        setStatus("");
      }

      document.querySelectorAll("[data-modal-open='subscribe']").forEach((btn) => {
        btn.addEventListener("click", openModal);
      });

      if (modal) {
        modal.addEventListener("click", (event) => {
          if (event.target === modal) closeModal();
        });
      }

      document.querySelectorAll("[data-modal-close]").forEach((btn) => {
        btn.addEventListener("click", closeModal);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeModal();
      });

      if (prefAll) {
        prefAll.addEventListener("change", () => {
          const checked = prefAll.checked;
          [prefArticles, prefPhoto, prefFaces, prefTravel].forEach((el) => {
            if (!el) return;
            el.checked = false;
            el.disabled = checked;
          });
        });
      }

      if (prefAll?.checked) {
        [prefArticles, prefPhoto, prefFaces, prefTravel].forEach((el) => {
          if (!el) return;
          el.disabled = true;
        });
      }

      [prefArticles, prefPhoto, prefFaces, prefTravel].forEach((el) => {
        if (!el) return;
        el.addEventListener("change", () => {
          if (!prefAll) return;
          if (el.checked) prefAll.checked = false;
          const lock = prefAll.checked;
          [prefArticles, prefPhoto, prefFaces, prefTravel].forEach((item) => {
            if (!item) return;
            item.disabled = lock;
          });
        });
      });

      if (nameInput && !nameInput.value && authUser?.email) {
        nameInput.value = fallbackNameFromEmail(authUser.email);
      }

      if (auth) {
        onAuthStateChanged(auth, async (user) => {
          authUser = user;
          if (!user?.uid || !(nameInput instanceof HTMLInputElement)) return;
          const profile = await getSubscriberRecord(user.uid);
          const preferredName = profile?.name || fallbackNameFromEmail(user.email || "");
          if (preferredName && !nameInput.value.trim()) nameInput.value = preferredName;
        });
      }

      async function completeSubscriberSignInFromLink() {
        if (!auth || !window || !isSignInWithEmailLink(auth, window.location.href)) return { completed: false };
        const pending = readPendingSubscriber();
        const email = normalizeEmail(pending?.email || window.localStorage.getItem("sfa-last-email-link") || window.prompt("Confirm your email to finish sign-in:") || "");
        if (!email) return { completed: false, error: "missing_email" };
        const credential = await signInWithEmailLink(auth, email, window.location.href);
        window.localStorage.setItem("sfa-last-email-link", email);
        await upsertSubscriberRecord(credential.user, {
          name: pending?.name,
          preferences: Array.isArray(pending?.preferences) ? pending.preferences : [],
          source: pending?.source || "global_modal",
        });
        clearPendingSubscriber();
        try {
          const clean = new URL(window.location.href);
          clean.search = "";
          window.history.replaceState({}, document.title, clean.pathname + clean.hash);
        } catch (error) {}
        return { completed: true, user: credential.user };
      }

      completeSubscriberSignInFromLink().then(async ({ completed, user }) => {
        if (!completed || !user?.uid) return;
        const profile = await getSubscriberRecord(user.uid);
        const title = profile?.name ? "Subscription received" : "Subscription confirmed";
        showSuccess(title, "Your subscriber account is active and ready for comments.");
      }).catch(() => {});

      if (modalSubmit) {
        modalSubmit.addEventListener("click", async () => {
          if (!(emailInput instanceof HTMLInputElement)) return;
          const normalizedEmail = normalizeEmail(emailInput.value);
          if (!normalizedEmail.includes("@")) {
            emailInput.focus();
            emailInput.classList.add("input-error");
            setStatus("Please enter a valid email.", "error");
            return;
          }

          emailInput.classList.remove("input-error");
          setStatus("");

          if (!firebaseReady || !auth || !db) {
            setStatus("Subscriber services are not configured yet.", "error");
            return;
          }

          const name = nameInput instanceof HTMLInputElement ? nameInput.value : "";
          const preferences = collectPreferences();

          if (modalSubmit instanceof HTMLButtonElement) {
            modalSubmit.disabled = true;
          }

          try {
            if (authUser?.uid && normalizeEmail(authUser.email) === normalizedEmail) {
              await upsertSubscriberRecord(authUser, {
                name,
                preferences,
                source: "global_modal",
              });
              showSuccess("Subscription confirmed", "Your subscriber account is active.");
              return;
            }

            await sendSignInLinkToEmail(auth, normalizedEmail, {
              url: window.location.href,
              handleCodeInApp: true,
            });
            writePendingSubscriber({
              email: normalizedEmail,
              name: normalizeString(name).slice(0, 80),
              preferences,
              source: "global_modal",
            });
            showSuccess("Check your inbox", "Use the sign-in link to confirm your subscription.");
          } catch (error) {
            setStatus("Subscription failed. Please retry in a moment.", "error");
          } finally {
            if (modalSubmit instanceof HTMLButtonElement) {
              modalSubmit.disabled = false;
            }
          }
        });
      }
    </script>
  </body>
</html>
